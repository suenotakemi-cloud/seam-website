  "type_resolution": {
    "description": "発火ルールから16 Hair DNAタイプを決定する手順",
    "strategy": "weighted_vote",
    "steps": [
      "1. fired_rules を priority×confidence で降順ソート",
      "2. 上位N(=3)ルールの primary_types を取得",
      "3. 各タイプに weight × confidence を加算（同タイプは合算）",
      "4. 最高スコアのタイプを Primary DNA とする",
      "5. 2位のタイプを Sub DNA とする（スコア差が0.2以内のとき）",
      "6. 該当なし／全 q4=s0 のときは Crystal Bloom（予防）または Midnight Silk（健康）を返す"
    ],
    "fallback_type": "Crystal Bloom"
  }
