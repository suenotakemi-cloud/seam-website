// ※ 表示色の優先度: 主要効果は gold、サポート的なものは grey
const PRIMARY_TAG_PRIORITY = [
  'damage-repair','internal-repair','bond-care','bonding','ppt-repair','cmc-care',
  'heat-protect','color-protect','color-lock','color-fade-prevent',
  'scalp-care','scalp-clean','scalp-moisture','scalp-anti-aging','soothing',
  'humidity-control','frizz-control','wave-care',
  'aging-care','hair-growth','hairloss-care','volume-up','lift-root',
  'moisture','moisturize','hydration','tame','smoothing','softening',
  'shine','elasticity','intensive','for-fine-hair',
  'leave-in','hair-mask','styling-base',
];

function getProductChips(p, max = 4) {
  if (!p) return [];
  const tags = p.functionTags || [];
  // 優先度順に並べる
  const ordered = [
    ...PRIMARY_TAG_PRIORITY.filter(t => tags.includes(t)),
    ...tags.filter(t => !PRIMARY_TAG_PRIORITY.includes(t)),
  ];
  // 日本語ラベル化（未定義は空にスキップ）
  const chips = [];
  const seen = new Set();
  for (const t of ordered) {
    const label = FUNCTION_TAG_JP[t];
    if (!label || seen.has(label)) continue;
    seen.add(label);
    chips.push(label);
    if (chips.length >= max) break;
  }
  return chips;
}

/* ---------- buildUserTags — Mode B 回答からタグセットを生成 ---------- */
function buildUserTags(answers, scores) {
  const a = answers || {};
  const s = scores || {};
  const tags = { base:[], state:[], goal:[], scalp:[], heat:[], color:[], perm:[], age:[] };

  // 髪の太さ
  if (a.thickness === 'thin')   tags.base.push('fine_hair');
  if (a.thickness === 'normal') tags.base.push('medium_hair');
  if (a.thickness === 'thick')  tags.base.push('coarse_hair');

  // 髪の量・密度
  if (a.density === 'low')    tags.base.push('low_density');
  if (a.density === 'normal') tags.base.push('medium_density');
  if (a.density === 'high')   tags.base.push('high_density');

  // クセ
  if (['none','straightened'].includes(a.wave)) tags.base.push('straight');
  else if (['humid','surface','midEnd','root'].includes(a.wave)) tags.base.push('wave');
  else if (a.wave === 'whole') tags.base.push('curl');

  // 根元ボリューム
  if (a.rootVolume === 'flat' || a.rootVolume === 'tendFlat') tags.scalp.push('top_volume_low');

  // 頭皮
  if (a.scalpType === 'dry'       || a.scalpType === 'tendDry')     tags.scalp.push('scalp_dry');
  if (a.scalpType === 'normal')                                       tags.scalp.push('scalp_normal');
  if (a.scalpType === 'oily'      || a.scalpType === 'tendOily')    tags.scalp.push('scalp_oily');
  if (a.scalpSensitivity === 'veryHigh' || a.scalpSensitivity === 'high') tags.scalp.push('scalp_sensitive');

  // 年代
  if (a.age) tags.age.push(`age_${a.age}`);
  if (a.age === '40s' || a.age === '50plus') tags.state.push('aging');

  // 薄毛・抜け毛(頭皮ケア系のニーズ)
  if ((a.concerns || []).includes('thinning')) {
    tags.state.push('hair_thinning');
    tags.scalp.push('scalp_growth_need');
  }
  if ((a.concerns || []).includes('volumeDown') || (a.concerns || []).includes('topFlat')) {
    tags.scalp.push('top_volume_low');
  }

  // ととのえたい時間(wellness)
  const wellness = a.wellness || [];
  if (wellness.length > 0 && !wellness.includes('well')) {
    tags.state.push('headspa_need');
  }

  // カラー
  if (a.color && a.color !== 'none') {
    tags.color.push('color_history');
    if (a.colorFreq === 'monthly' || a.colorFreq === 'six') {
      tags.color.push('color_freq_high');
      tags.state.push('scalp_load_color');
    }
  }
  if (a.grayHair === 'yes') {
    tags.color.push('gray_color');
    if (['half','three','monthly'].includes(a.grayFreq)) {
      tags.color.push('gray_color_freq_high');
      tags.state.push('scalp_load_color');
    }
  }

  // ブリーチ — color質問から派生(旧 bleach 質問は廃止済み)
  const bleachLevel = (typeof deriveBleach === 'function') ? deriveBleach(a) : (a.bleach || null);
  if (bleachLevel) {
    tags.state.push('bleach_history');
    if (a.bleachLocation === 'ends' || a.bleachLocation === 'midEnds') {
      tags.state.push('bleach_residual', 'bleach_ends');
    } else if (a.bleachLocation === 'whole') {
      tags.state.push('bleach_residual', 'bleach_high');
    } else if (a.bleachLocation === 'partial') {
      tags.state.push('bleach_partial');
    }
    // 連続ブリーチ / 直近ブリーチ → bleach_high
    if (bleachLevel === 'multi' || bleachLevel === 'within3m' || bleachLevel === 'within1m') {
      tags.state.push('bleach_high');
    }
    // ハイライト / インナーカラー
    if (bleachLevel === 'highlight') tags.state.push('bleach_partial');
  }
  // 黒染め (color === 'dark_strong') — 色抜けにくい・ベース重め扱い
  if (a.color === 'dark_strong') tags.color.push('black_dye');

  // 矯正
  if (a.straighten && a.straighten !== 'none') tags.state.push('straight_residual');

  // パーマ
  // 「past」(過去にパーマしていたが今はストレート) は perm 系商品の推奨対象外
  if (a.perm && a.perm !== 'none' && a.perm !== 'past') {
    tags.perm.push('perm_history');
    if (a.permType === 'digital' || a.permType === 'both') tags.perm.push('perm_digital');
    else if (a.permType === 'normal') tags.perm.push('perm_normal');
    if (a.permLoose === 'veryEasy' || a.permLoose === 'easy') tags.perm.push('perm_loose');
  }

  // 熱
  const tools = (a.styling?.tools) || [];
  const temp  = a.styling?.temp;
  if (tools.includes('ironDaily') || tools.includes('curlerDaily')) tags.heat.push('heat_daily');
  if (tools.includes('ironWeekly') || tools.includes('curlerWeekly')) tags.heat.push('heat_weekly');
  if (temp === 't200') tags.heat.push('heat_high', 'heat_extreme');
  else if (temp === 't180') tags.heat.push('heat_high');
  // heatProtect は配列になった。'none' だけ選んでいる or 何も入っていなければ無防備
  const hpArr = Array.isArray(a.heatProtect) ? a.heatProtect : (a.heatProtect ? [a.heatProtect] : []);
  if ((hpArr.length === 0 || hpArr.includes('none')) && tags.heat.length) tags.heat.push('heat_unprotected');

  // ゴール (Mode A の goalTexture から)
  const goalMap = {
    smooth:'goal_silky_straight', moist:'goal_moist_gloss',
    glossy:'goal_moist_gloss',    firm:'goal_soft_volume',
    airy:'goal_soft_volume',      soft:'goal_repair_smooth',
  };
  if (a.goalTexture && goalMap[a.goalTexture]) tags.goal.push(goalMap[a.goalTexture]);

  // 集計
  return tags;
}

/* ---------- HARD RULES — 7つの強制表示ルール ---------- */
function checkHardRules(userTags, answers, scores) {
  const fired = [];
  const a = answers || {};
  const s = scores || {};

  // A: カラー高頻度 → 頭皮ケア強化
  if (userTags.color.includes('color_freq_high') || userTags.color.includes('gray_color_freq_high')) {
    fired.push({ id:'colorHighFreq', boostCategory:'scalp-essence', boost: 40, message:'カラー後数日間の頭皮保湿ケアをおすすめ' });
  }

  // B: 白髪染め高頻度 × 頭皮敏感 → 頭皮美容液最優先
  if (userTags.color.includes('gray_color_freq_high') && userTags.scalp.includes('scalp_sensitive')) {
    fired.push({ id:'graySensitive', boostCategory:'scalp-essence', boost: 60, message:'頭皮環境の整備を優先' });
  }

  // C: アイロン高温×高頻度 → 熱保護必須
  if (userTags.heat.includes('heat_high') && (userTags.heat.includes('heat_daily') || userTags.heat.includes('heat_weekly'))) {
    fired.push({ id:'heatHigh', boostFunction:'heat-protect', boost: 50, message:'熱保護アイテムを毎日のルーティンに' });
  }

  // D: ブリーチ残存 → 毛先集中ケア
  if (userTags.state.includes('bleach_residual')) {
    fired.push({ id:'bleachResidual', boostConcern:'bleach', boost: 45, message:'毛先集中ケアの優先度を上げる' });
  }

  // E: 細毛×熱×ぺたん → 軽量ミスト/ミルク優先
  if (userTags.base.includes('fine_hair') && userTags.scalp.includes('top_volume_low') &&
      (userTags.heat.includes('heat_daily') || userTags.heat.includes('heat_weekly'))) {
    fired.push({ id:'fineFlatHeat', boostCategory:'leave-in-mist', boost: 35, penaltyTexture:'rich', message:'軽さを保つアイテムを優先' });
  }

  // F: パーマだれ → カール維持優先
  if (userTags.perm.includes('perm_loose')) {
    fired.push({ id:'permLoose', boostFunction:'perm-keep', boost: 30, penaltyFinish:'moist-heavy', message:'カール維持を優先、しっとり重め減点' });
  }

  // G: トップ気になる → スカルプ強化
  if (userTags.scalp.includes('top_volume_low') || (s.volumeLoss || 0) >= 3 || (s.aging || 0) >= 3) {
    fired.push({ id:'topVolume', boostCategory:'scalp-essence', boost: 25, boostFunction:'aging-care', message:'根元立ち上がりとハリ・コシを強化' });
  }

  // H: 薄毛・抜け毛 → 頭皮ケア系スカルプエッセンス最優先
  if (userTags.state.includes('hair_thinning')) {
    fired.push({
      id:'hairThinning',
      boostCategory:'scalp-essence',
      boostFunction:'hair-growth',
      boostConcern:'thinning',
      boost: 70,
      message:'頭皮環境を整えるスカルプエッセンスを最優先',
    });
  }

  return fired;
}

/* ---------- PENALTY RULES — 減点ルール ---------- */
function applyPenalties(product, userTags) {
  let penalty = 0;
  const finishArr = Array.isArray(product.finishTags) ? product.finishTags : (product.finishTags?.finish || []);
  const concernArr = product.concernTags || [];
  const cautionArr = product.cautionTags || [];
  const weight = product.finishTags?.weight;

  // 細毛 × 重め/オイル系
  if (userTags.base.includes('fine_hair')) {
    if (weight === 'rich' || weight === 'heavy') penalty += 15;
    if (finishArr.includes('rich')) penalty += 8;
    if (cautionArr.includes('may_flatten_fine_hair')) penalty += 20;
  }

  // オイリー頭皮 × 乾燥特化
  if (userTags.scalp.includes('scalp_oily') &&
      concernArr.includes('scalp-dry') && !concernArr.includes('scalp-oily')) {
    penalty += 12;
  }

  // デジパ × ストレート特化
  if (userTags.perm.includes('perm_digital') && cautionArr.includes('not_for_perm')) penalty += 15;

  // ブリーチ多 × ダメージタグ弱い
  if (userTags.state.includes('bleach_high') && !concernArr.includes('damage') && !concernArr.includes('bleach')) {
    penalty += 18;
  }

  // トップぺたん × 根元フラット注意
  if (userTags.scalp.includes('top_volume_low') && cautionArr.includes('root_flatten')) penalty += 15;

  return penalty;
}

/* ---------- scoreProductDeep — userTagsで追加スコア ---------- */
function scoreProductDeep(product, userTags, hardRules) {
  let boost = 0;
  const concernArr = product.concernTags || [];
  const functionArr = product.functionTags || [];
  const finishArr = Array.isArray(product.finishTags) ? product.finishTags : (product.finishTags?.finish || []);

  // ハードルール適用
  for (const rule of (hardRules || [])) {
    if (rule.boostCategory && product.category === rule.boostCategory) boost += rule.boost;
    if (rule.boostFunction && functionArr.includes(rule.boostFunction)) boost += rule.boost;
    if (rule.boostConcern  && concernArr.includes(rule.boostConcern))   boost += rule.boost;
  }

  // ベース一致
  if (userTags.base.includes('fine_hair') && functionArr.includes('lightweight')) boost += 8;
  if (userTags.base.includes('coarse_hair') && finishArr.includes('rich'))         boost += 6;

  // ゴール一致
  if (userTags.goal.includes('goal_moist_gloss') && finishArr.includes('glossy'))  boost += 10;
  if (userTags.goal.includes('goal_moist_gloss') && finishArr.includes('moist'))   boost += 8;
  if (userTags.goal.includes('goal_silky_straight') && finishArr.includes('smooth')) boost += 10;
  if (userTags.goal.includes('goal_soft_volume') && finishArr.includes('airy'))    boost += 10;
  if (userTags.goal.includes('goal_repair_smooth') && concernArr.includes('damage')) boost += 8;

  // 頭皮タグ
  if (userTags.scalp.includes('scalp_dry')       && concernArr.includes('scalp-dry'))  boost += 12;
  if (userTags.scalp.includes('scalp_oily')      && concernArr.includes('scalp-oily')) boost += 12;
  if (userTags.scalp.includes('scalp_sensitive') && functionArr.includes('low-irritation')) boost += 8;

  // 状態タグ
  if (userTags.state.includes('bleach_residual') && (concernArr.includes('bleach') || concernArr.includes('damage'))) boost += 15;
  if (userTags.state.includes('aging')           && functionArr.includes('aging-care')) boost += 10;

  // ブリーチ毛・ハイダメージ専用ケアの強ブースト(Miracle / Bond / Lipid / Fibreplex 系)
  if (userTags.state.includes('bleach_residual') || userTags.state.includes('bleach_high')) {
    const productName = ((product.name || '') + ' ' + (product.line || '')).toLowerCase();
    const isBondCare =
      /miracle|bond|lipid\s*booster|fibreplex|fiberplex|olaplex|hahonico\s*lala|tokio.*ie|inkarami|sublimic\s*adapt|ke?rastase\s*blond/i.test(productName) ||
      (functionArr.includes('bond-care') || functionArr.includes('lipid-care'));
    if (isBondCare) boost += 35;
    // ブリーチ専用アウトバス
    if ((product.category === 'leave-in-oil' || product.category === 'leave-in-milk' || product.category === 'leave-in-mist') &&
        (concernArr.includes('bleach') || /bleach|ブリーチ|ハイトーン|highlift/i.test(productName))) {
      boost += 22;
    }
    // 集中マスクは最強
    if ((product.category === 'hair-mask' || product.category === 'mask') &&
        (concernArr.includes('bleach') || concernArr.includes('damage'))) {
      boost += 28;
    }
  }

  // 薄毛・抜け毛
  if (userTags.state.includes('hair_thinning')) {
    if (concernArr.includes('thinning'))                            boost += 25;
    if (product.category === 'scalp-essence')                       boost += 20;
    if (functionArr.includes('hair-growth') || functionArr.includes('scalp-anti-aging') || functionArr.includes('aging-care')) boost += 15;
  }

  // 熱タグ
  if (userTags.heat.includes('heat_high')        && functionArr.includes('heat-protect')) boost += 15;
  if (userTags.heat.includes('heat_unprotected') && functionArr.includes('heat-protect')) boost += 10;

  // パーマタグ
  if (userTags.perm.includes('perm_loose')       && functionArr.includes('perm-keep'))  boost += 12;

  return boost;
}

/* ---------- BLOCK CATEGORIZATION ---------- */
const CATEGORY_TO_BLOCK = {
  'leave-in-mist':   'urgent',
  'leave-in-milk':   'enhancement',
  'leave-in-oil':    'enhancement',
  'hair-mask':       'enhancement',
  'mask':            'enhancement',
  'scalp-essence':   'urgent',
  'scalp-shampoo':   'daily',
  'shampoo':         'daily',
  'treatment':       'daily',
  'salon-menu':      'salon',
};

function blockForProduct(p, hardRules) {
  // ハードルールに引っかかっている product は urgent に昇格
  for (const rule of (hardRules || [])) {
    if (rule.boostCategory && p.category === rule.boostCategory) return 'urgent';
    if (rule.boostFunction && (p.functionTags || []).includes(rule.boostFunction)) return 'urgent';
    if (rule.boostConcern  && (p.concernTags  || []).includes(rule.boostConcern))  return 'urgent';
  }
  return CATEGORY_TO_BLOCK[p.category] || 'enhancement';
}

const BLOCK_DEFS = {
  urgent:      { id:'urgent',      title:'今すぐ取り入れたい',   eyebrow:'01 Urgent',     desc:'いまのあなたに、もっとも優先したいケアです。', },
  daily:       { id:'daily',       title:'毎日の土台',           eyebrow:'02 Daily',      desc:'これまでの土台を整えるアイテムです。', },
  enhancement: { id:'enhancement', title:'悩みに合わせて',       eyebrow:'03 Enhancement',desc:'集中的に変えたい部分に。', },
  salon:       { id:'salon',       title:'サロンでのおすすめ',   eyebrow:'04 Salon',      desc:'店頭でできる、より深いケア。', },
};

