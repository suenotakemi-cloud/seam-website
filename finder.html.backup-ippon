        </div>
      </article>
    </div>
  );
}

/* ---------- Collection — 図鑑ビュー ---------- */
function Collection({ onBackHome, myKarte, onPickAsMine }) {
  const [filter, setFilter] = useState('all');
  const [sortMode, setSortMode] = useState('rare-asc'); // rare-asc / rare-desc / direction
  const [open, setOpen] = useState(null);
  const myId = myKarte?.originId;

  // 自分のタイプ動物
  const myAnimal = myId ? { id: myId, ...KARTE_ORIGIN_ANIMALS[myId] } : null;

  // フィルタ + ソート
  const list = useMemo(() => {
    let arr = listAnimalsForCollection(filter);
    if (sortMode === 'rare-asc')  arr = [...arr].sort((a, b) => (a.rarity||0) - (b.rarity||0));
    if (sortMode === 'rare-desc') arr = [...arr].sort((a, b) => (b.rarity||0) - (a.rarity||0));
    if (sortMode === 'direction') {
      // A→B→C→D 順で並べる(全体の場合のみ意味あり)
      const order = ['A','B','C','D'];
      const dirOf = (a) => order.indexOf((a.targets && Object.keys(a.targets).find(d => order.includes(d))) || 'A');
      arr = [...arr].sort((a, b) => dirOf(a) - dirOf(b));
    }
    return arr;
  }, [filter, sortMode]);

  return (
    <div className="min-h-[100svh] bg-finder relative pb-24">
      <TopBar />
      <main className="relative z-10 mx-auto max-w-5xl px-5 sm:px-8 pt-28 pb-12 sm:pt-32">

        {/* ── Hero ── */}
        <div className="anim-fade-up">
          <div className="flex items-center gap-3 mb-5">
            <span className="font-mono tracking-widest2 text-[10px] uppercase text-gold">Karte Collection</span>
            <span className="h-px w-10 bg-gold/40" />
            <span className="font-mono tracking-widest2 text-[10px] uppercase text-charcoal/55">18 Types</span>
          </div>
          <h1 className="font-serif text-[36px] sm:text-[56px] leading-[1.05] text-ink tracking-tight">
            ヘアタイプ図鑑
          </h1>
          <p className="mt-4 font-serif text-[15px] sm:text-[17px] text-charcoal/85 leading-[1.85] max-w-xl">
            18の髪のかたちを、ひとつずつ見ていきましょう。<br />
            あなたの隣に、まだ知らない髪の姿があります。
          </p>
        </div>

        {/* ── あなたのタイプ(自分のタイプを最上部に大きく) ── */}
        {myAnimal && (
          <article
            className="mt-8 sm:mt-10 anim-fade-up text-ink rounded-[2px] p-6 sm:p-8 relative overflow-hidden border border-gold/25"
            style={{ animationDelay: '60ms', background: 'linear-gradient(155deg, #FBF7EF 0%, #F5EDDD 55%, #EEE2CB 100%)' }}
          >
            <div className="absolute inset-0 pointer-events-none"
                 style={{ background:'radial-gradient(60% 50% at 80% 20%, rgba(184,148,90,0.18), transparent 60%), radial-gradient(50% 40% at 10% 110%, rgba(217,190,147,0.12), transparent 60%)' }} />
            <div className="relative grid sm:grid-cols-[1fr_auto] gap-5 sm:gap-7 items-start">
              <div>
                <p className="font-mono tracking-widest2 text-[10px] uppercase text-gold">— Your Type</p>
                <h2 className="mt-2 font-serif text-[28px] sm:text-[36px] text-ink leading-tight">{myAnimal.name}</h2>
                <p className="mt-1.5 font-mono tracking-widest2 text-[10.5px] uppercase text-charcoal/55">
                  {myAnimal.nameEn} · <span className="text-gold">{myAnimal.code}</span>
                </p>
                {myAnimal.personality && (
                  <p className="mt-4 text-[13.5px] sm:text-[14.5px] leading-[1.95] text-charcoal/85 max-w-2xl">
                    {myAnimal.personality.slice(0, 110)}…
                  </p>
                )}
                <button
                  type="button"
                  onClick={() => setOpen(myAnimal)}
                  className="mt-5 inline-flex items-center gap-2 font-mono tracking-widest2 text-[10.5px] uppercase text-ivory bg-ink px-4 py-2.5 rounded-[1px] hover:bg-charcoal transition-colors"
                >
                  詳しく見る →
                </button>
              </div>
              <div className="hidden sm:block shrink-0">
                <div className="w-[140px] h-[140px] karte-mark-accent">
                  <KarteAnimalMark size={140} accent code={myAnimal.code} />
                </div>
              </div>
            </div>
          </article>
        )}

        {/* ── フィルタ + ソート ── */}
        <div className="mt-10 anim-fade-up" style={{ animationDelay:'80ms' }}>
          <div className="flex flex-wrap items-center gap-2 pb-3 border-b border-line">
            {['all','A','B','C','D'].map(key => (
              <button
                key={key}
                type="button"
                onClick={() => setFilter(key)}
                className={[
                  'px-3 sm:px-4 py-1.5 text-[10.5px] sm:text-[11px] font-mono tracking-widest2 uppercase rounded-[1px] transition-colors',
                  filter === key
                    ? 'bg-ink text-ivory'
                    : 'bg-white/70 border border-line text-charcoal/65 hover:text-ink hover:border-ink',
                ].join(' ')}
              >
                {key === 'all' ? 'All Types' : `${key} · ${KARTE_DIRECTION_LABEL[key].replace('タイプ','')}`}
