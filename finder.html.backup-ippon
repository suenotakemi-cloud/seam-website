/* 商品 → DEEP_CATEGORY マッピング */
function deepCategoryForProduct(p) {
  if (!p) return null;
  const cat = (p.category || '').toLowerCase();
  const fns = p.functionTags || [];
  // 仕上げ系オーバーライド: styling/finishタグ持ち or styling-* カテゴリ
  if (cat.startsWith('styling') || fns.includes('styling') || fns.includes('finish')) {
    return 'finish';
  }
  // 個別ID: カラーモーション ルミナススプレー(仕上げ用ツヤスプレー)
  if (p.id === 'colormotion-luminous-spray') return 'finish';
  // 通常マッピング
  for (const def of Object.values(DEEP_CATEGORY_DEFS)) {
    if (def.cats.includes(cat)) return def.id;
  }
  return null;
}

