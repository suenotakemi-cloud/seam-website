const RESERVATION_STORES = [
  { id:'ginza',      city:'Tokyo',    name:'銀座',       hpb:'https://beauty.hotpepper.jp/slnH000802192/' },
  { id:'omotesando', city:'Tokyo',    name:'表参道',     hpb:'https://beauty.hotpepper.jp/slnH000802192/' },
  { id:'osaka',      city:'Osaka',    name:'大阪 堀江',  hpb:'https://beauty.hotpepper.jp/slnH000791476/' },
  { id:'nagoya',     city:'Nagoya',   name:'名古屋 栄',  hpb:'https://beauty.hotpepper.jp/slnH000800028/' },
  { id:'fukuoka',    city:'Fukuoka',  name:'福岡 天神',  hpb:'https://beauty.hotpepper.jp/slnH000734442/' },
  { id:'sapporo',    city:'Sapporo',  name:'札幌 大通',  hpb:'https://beauty.hotpepper.jp/slnH000417753/' },
  { id:'gigi',       city:'Utsunomiya', name:'宇都宮 Gigi', hpb:'https://beauty.hotpepper.jp/' },
];

function ReservationModal({ open, onClose }) {
  const [step, setStep] = useState(1);
  const [selectedStore, setSelectedStore] = useState(null);

  useEffect(() => {
    if (!open) return;
    document.body.style.overflow = 'hidden';
    return () => { document.body.style.overflow = ''; };
  }, [open]);

  useEffect(() => {
    if (!open) {
      // モーダル閉じたらリセット
      const id = setTimeout(() => { setStep(1); setSelectedStore(null); }, 300);
      return () => clearTimeout(id);
    }
  }, [open]);

  if (!open) return null;

  return (
    <div
      className="fixed inset-0 z-[9100] flex items-center justify-center px-4 no-print"
      style={{ background: 'rgba(15,14,13,0.86)' }}
      onClick={(e) => { if (e.target === e.currentTarget) onClose(); }}
    >
      <div className="bg-ivory w-full max-w-[560px] max-h-[90vh] overflow-y-auto rounded-[2px] relative anim-fade-up">
        <div className="bg-ink text-ivory px-6 sm:px-7 py-5 relative">
          <p className="font-mono tracking-widest2 text-[10px] uppercase text-goldLight">— Online Reservation</p>
          <h3 className="mt-1.5 font-serif text-[18px]">ご予約</h3>
          <button
            onClick={onClose}
            className="absolute top-4 right-5 text-ivory/55 hover:text-ivory text-[22px] leading-none"
            aria-label="閉じる"
          >×</button>
        </div>
        <div className="px-6 sm:px-7 py-7">
          <div className="flex items-center gap-0 mb-6">
            <div className={`flex-1 text-center pb-2 border-b-2 font-mono tracking-widest2 text-[10px] uppercase ${step === 1 ? 'border-ink text-ink' : 'border-line text-gold'}`}>
              Step 1 — エリア
            </div>
            <div className={`flex-1 text-center pb-2 border-b-2 font-mono tracking-widest2 text-[10px] uppercase ${step === 2 ? 'border-ink text-ink' : 'border-line text-charcoal/45'}`}>
              Step 2 — メニュー
            </div>
          </div>

          {step === 1 && (
            <div className="anim-fade-up">
              <p className="text-[12.5px] text-charcoal/70 mb-4 leading-relaxed">ご来店の店舗エリアをお選びください</p>
              <div className="grid grid-cols-3 gap-2.5">
                {RESERVATION_STORES.map(s => (
                  <button
                    key={s.id}
                    type="button"
                    onClick={() => { setSelectedStore(s); setStep(2); }}
                    className="border border-line bg-white py-4 px-2 hover:bg-ink hover:text-ivory group transition-colors"
                  >
                    <span className="block font-mono tracking-widest2 text-[8.5px] uppercase text-charcoal/55 group-hover:text-goldLight">{s.city}</span>
                    <span className="block font-serif text-[14px] mt-1 text-ink group-hover:text-ivory">{s.name}</span>
                  </button>
                ))}
              </div>
            </div>
          )}

          {step === 2 && selectedStore && (
            <div className="anim-fade-up">
              <button
                onClick={() => setStep(1)}
                className="flex items-center gap-1.5 font-mono tracking-widest2 text-[10px] uppercase text-charcoal/65 hover:text-ink mb-5"
              >← 店舗を選び直す</button>
              <p className="font-serif text-[18px] text-ink">{selectedStore.name}</p>
              <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-gold mt-1 mb-6">{selectedStore.city}</p>
              <p className="text-[12.5px] text-charcoal/70 mb-4 leading-relaxed">ご希望のメニューをお選びください</p>
              <div className="grid grid-cols-2 gap-2.5">
                <a
                  href={selectedStore.hpb}
                  target="_blank"
                  rel="noopener noreferrer"
                  className="border border-line bg-white p-6 text-center hover:bg-ink hover:text-ivory transition-colors group"
                >
                  <p className="font-serif text-[15px] text-ink group-hover:text-ivory">ヘアサロン</p>
                  <p className="font-mono tracking-widest2 text-[9px] uppercase text-charcoal/55 group-hover:text-goldLight mt-2">Hair Salon</p>
                </a>
                <a
                  href={selectedStore.hpb}
                  target="_blank"
                  rel="noopener noreferrer"
                  className="border border-line bg-white p-6 text-center hover:bg-ink hover:text-ivory transition-colors group"
                >
                  <p className="font-serif text-[15px] text-ink group-hover:text-ivory">ヘッドスパ</p>
                  <p className="font-mono tracking-widest2 text-[9px] uppercase text-charcoal/55 group-hover:text-goldLight mt-2">Head Spa</p>
                </a>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

/* ---------- CHARACTER_PROFILE — 18 体のキャラ属性 (Element / Mood / Season) ---------- */
const CHARACTER_PROFILE = {
  ASR: { element:'霧',  elementEn:'Mist',     mood:'やわらか', moodEn:'Soft',       season:'早春',   seasonEn:'Early Spring' },
  SSD: { element:'光',  elementEn:'Light',    mood:'やさしい', moodEn:'Gentle',     season:'初夏',   seasonEn:'Early Summer' },
  ASF: { element:'風',  elementEn:'Air',      mood:'凛',       moodEn:'Crisp',      season:'春',     seasonEn:'Spring' },
  MSF: { element:'水',  elementEn:'Water',    mood:'静謐',     moodEn:'Quiet',      season:'晩冬',   seasonEn:'Late Winter' },
  VCC: { element:'夜',  elementEn:'Night',    mood:'静謐',     moodEn:'Quiet',      season:'晩秋',   seasonEn:'Late Autumn' },
  SBS: { element:'土',  elementEn:'Earth',    mood:'朗らか',   moodEn:'Bright',     season:'秋',     seasonEn:'Autumn' },
  ABM: { element:'土',  elementEn:'Earth',    mood:'朗らか',   moodEn:'Bright',     season:'初夏',   seasonEn:'Early Summer' },
  VSC: { element:'夜',  elementEn:'Night',    mood:'艶やか',   moodEn:'Lustrous',   season:'冬',     seasonEn:'Winter' },
  VBP: { element:'夜',  elementEn:'Night',    mood:'凛',       moodEn:'Crisp',      season:'冬',     seasonEn:'Winter' },
  RSS: { element:'光',  elementEn:'Light',    mood:'凛',       moodEn:'Crisp',      season:'早春',   seasonEn:'Early Spring' },
  AWS: { element:'風',  elementEn:'Air',      mood:'ふんわり', moodEn:'Airy',       season:'初夏',   seasonEn:'Early Summer' },
  RBL: { element:'火',  elementEn:'Fire',     mood:'凛',       moodEn:'Crisp',      season:'晩秋',   seasonEn:'Late Autumn' },
  MWA: { element:'水',  elementEn:'Water',    mood:'やわらか', moodEn:'Soft',       season:'春',     seasonEn:'Spring' },
  AWP: { element:'風',  elementEn:'Air',      mood:'やさしい', moodEn:'Gentle',     season:'春',     seasonEn:'Spring' },
  SCA: { element:'風',  elementEn:'Air',      mood:'静謐',     moodEn:'Quiet',      season:'秋',     seasonEn:'Autumn' },
  ACS: { element:'雪',  elementEn:'Snow',     mood:'やわらか', moodEn:'Soft',       season:'冬',     seasonEn:'Winter' },
  MSP: { element:'月',  elementEn:'Moon',     mood:'神秘',     moodEn:'Mystic',     season:'晩秋',   seasonEn:'Late Autumn' },
  ASB: { element:'水',  elementEn:'Water',    mood:'透明',     moodEn:'Translucent', season:'春',    seasonEn:'Spring' },
};

const CURRENT_CONDITION_BY_AXIS = {
  '透明感': 'キューティクルを整えると、光の通り方が変わる時期。',
  '艶':     '保湿を整えると、ツヤが本来の姿で現れる時期。',
  'まとまり':'内側の水分を整えると、まとまりが感じられやすくなる時期。',
  '華やぎ': '軽やかに立ち上げるケアで、本来の表情が現れる時期。',
  '頭皮':   '頭皮ケアを取り入れると、髪の根元から変わる時期。',
};

function buildCurrentCondition(radar) {
  if (!radar || radar.length !== 5) return null;
  const labels = ['透明感', '艶', 'まとまり', '華やぎ', '頭皮'];
  const items = labels.map((l, i) => ({ label: l, score: (radar[i] || 0) * 20 }));
  const sorted = [...items].sort((a, b) => a.score - b.score);
  const lowest = sorted[0];
  if (!lowest) return null;
  if (lowest.score >= 40) {
    return '整いやすい土台ができている、整えるほど映える状態。';
  }
  return CURRENT_CONDITION_BY_AXIS[lowest.label] || '本来の質を取り戻していく時期。';
}

/* ---------- ResultHero — Pokémon カード風 図鑑プロフィールカード ---------- */
function ResultHero({ karte, onSaveImage, onShare, onSavePdf }) {
  if (!karte) return null;
  const { origin, radar, mainGoal } = karte;
  // セクション間をジャンプするヘルパー
  const jump = (id) => {
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };
  return (
    <section id="result-hero" className="anim-fade-up relative -mx-5 sm:-mx-8 mt-6 sm:mt-8 mb-10 sm:mb-12 overflow-hidden">
      <div className="relative px-5 sm:px-8 py-10 sm:py-12 max-w-3xl mx-auto">
        {(() => {
          const profile = CHARACTER_PROFILE[origin.code] || {};
          const typeNumber = (typeof TYPE_NUMBER_MAP !== 'undefined') ? (TYPE_NUMBER_MAP[origin.code] || '—') : '—';
          return (
            <>
              {/* ━━━━ 図鑑タイトルバー ━━━━ */}
              <div className="flex items-center gap-3 mb-5 max-w-md mx-auto">
                <span className="font-mono tracking-widest2 text-[9px] uppercase text-gold">— SEAM Hair Encyclopedia</span>
                <span className="h-px flex-1 bg-gold/30" />
                <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55 nums">No. {typeNumber} / 18</span>
              </div>

              {/* ━━━━ Profile Card (1枚スクショ可) ━━━━ */}
              <article
                id="result-hero-card"
                className="relative mx-auto max-w-md rounded-[3px] border border-gold/40 overflow-hidden"
                style={{
                  background: 'linear-gradient(155deg, #FBF7EF 0%, #F4ECDA 60%, #EEE2CB 100%)',
                  boxShadow: '0 2px 6px rgba(26,24,21,0.05), 0 18px 50px -28px rgba(26,24,21,0.18)',
                }}
              >
                {/* corner ornaments */}
                <span aria-hidden className="absolute top-2 left-2 w-3 h-3 border-t border-l border-gold/60" />
                <span aria-hidden className="absolute top-2 right-2 w-3 h-3 border-t border-r border-gold/60" />
                <span aria-hidden className="absolute bottom-2 left-2 w-3 h-3 border-b border-l border-gold/60" />
                <span aria-hidden className="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-gold/60" />

                {/* gold radial highlight */}
                <div aria-hidden className="absolute inset-0 pointer-events-none"
                     style={{ background:'radial-gradient(50% 38% at 50% 12%, rgba(184,148,90,0.18), transparent 60%)' }} />

                <div className="relative px-5 sm:px-7 pt-6 sm:pt-8 pb-6 sm:pb-8 text-center">
                  {/* Specimen header */}
                  <div className="flex items-center justify-between text-[9.5px] font-mono tracking-widest2 uppercase nums">
                    <span className="text-gold">Specimen · {typeNumber}</span>
                    <span className="text-charcoal/50">{origin.code}</span>
                  </div>
                  <span className="block mt-3 mx-auto w-10 h-px bg-gold/40" />

                  {/* Character image */}
                  <div className="mt-5 inline-block karte-mark-accent relative" style={{ width: 168, height: 168 }}>
                    <span className="karte-mark-glow" aria-hidden />
                    <img
                      src={`images/characters/${origin.code}.png`}
                      alt={origin.name}
                      width={168}
                      height={168}
                      className="relative w-full h-full object-contain karte-mark-anim"
                      onError={(e) => { e.target.style.display = 'none'; }}
                    />
                  </div>

                  {/* Name */}
                  <h1 className="mt-5 font-serif text-[24px] sm:text-[30px] leading-[1.2] text-ink" style={{ wordBreak:'keep-all', overflowWrap:'break-word' }}>
                    {origin.name}
                  </h1>
                  <p className="mt-2 font-mono tracking-widest2 text-[10px] sm:text-[10.5px] uppercase text-charcoal/55 nums">
                    {origin.nameEn} <span className="text-gold">· {origin.code}</span>
                  </p>

                  {/* ━━━━━ RPGステータスカード ━━━━━ */}
                  {(() => {
                    const typeShort = (typeof TYPE_SHORT_NAME !== 'undefined') ? TYPE_SHORT_NAME[origin.code] : null;
                    const rarity = origin.rarity;
                    // 出現率 → ★レアリティ変換 (10%超=★★, 5-10%=★★★, 3-5%=★★★★, 3%未満=★★★★★)
                    let stars = '★★★';
                    if (typeof rarity === 'number') {
                      if (rarity < 3) stars = '★★★★★';
                      else if (rarity < 5) stars = '★★★★';
                      else if (rarity < 10) stars = '★★★';
                      else stars = '★★';
                    }
                    // TRAIT (3 keywords) — strengthsから抽出
                    const traits = (origin.strengths || []).slice(0,3).map(s => s.title).filter(Boolean);
                    // 性格本文 (最初の文だけ)
                    const personality = origin.personality || '';
                    return (
                      <div className="mt-5 mx-auto max-w-md text-left bg-white/70 border border-gold/30 rounded-[2px] p-4 sm:p-5">
                        {/* TYPE / RARITY 横並び */}
                        <div className="grid grid-cols-[1fr_auto] gap-3 items-start pb-3 border-b border-gold/20">
                          <div>
                            <p className="font-mono tracking-widest2 text-[9px] uppercase text-gold mb-1">— TYPE</p>
                            <p className="font-serif text-[14.5px] sm:text-[15.5px] text-ink leading-snug" style={{ fontWeight: 600 }}>{typeShort?.jp || '—'}</p>
                          </div>
                          <div className="text-right">
                            <p className="font-mono tracking-widest2 text-[9px] uppercase text-gold mb-1">— RARITY</p>
                            <p className="font-serif text-[14px] sm:text-[15px] text-gold leading-snug" style={{ letterSpacing: '0.08em' }}>{stars}</p>
                          </div>
                        </div>
                        {/* TRAIT chips */}
                        {traits.length > 0 && (
                          <div className="mt-3 pb-3 border-b border-gold/20">
                            <p className="font-mono tracking-widest2 text-[9px] uppercase text-gold mb-2">— TRAIT</p>
                            <div className="flex flex-wrap gap-1.5">
                              {traits.map((t, i) => (
                                <span key={i} className="inline-flex items-center px-2.5 py-1 text-[11px] sm:text-[11.5px] bg-cream/60 border border-gold/25 rounded-full text-charcoal" style={{ fontWeight: 500 }}>
                                  {t}
                                </span>
                              ))}
                            </div>
                          </div>
                        )}
                        {/* PERSONALITY */}
                        {personality && (
                          <div className="mt-3">
                            <p className="font-mono tracking-widest2 text-[9px] uppercase text-gold mb-1.5">— PERSONALITY</p>
                            <p className="font-serif text-[12.5px] sm:text-[13.5px] leading-[1.95] text-charcoal/85">
                              {personality}
                            </p>
                          </div>
                        )}
                        {/* CONDITION (今の状態) */}
                        {(() => {
                          const cond = buildCurrentCondition(radar);
                          if (!cond) return null;
                          return (
                            <div className="mt-3 pt-3 border-t border-gold/20">
                              <p className="font-mono tracking-widest2 text-[9px] uppercase text-gold mb-1.5">— CONDITION</p>
                              <p className="font-serif text-[12.5px] sm:text-[13.5px] leading-[1.85] text-charcoal/85">
                                {cond}
                              </p>
                            </div>
                          );
                        })()}
                      </div>
                    );
                  })()}

                  {/* Mini radar (5 axes) */}
                  {radar && radar.length === 5 && (
                    <div className="mt-5 pt-4 border-t border-gold/25">
                      <p className="font-mono tracking-widest2 text-[9px] uppercase text-gold mb-1">— STATS · PENTAGON</p>
                      <div className="flex justify-center">
                        <KartePentagon values={radar} />
                      </div>
                    </div>
                  )}

                  {/* Charm caption (selfHint は最上部 hero に持ち上がったため、ここでは charmHint で重複回避) */}
                  {origin.charmHint && (
                    <div className="mt-5 pt-4 border-t border-gold/25">
                      <p className="font-mono tracking-widest2 text-[9px] uppercase text-gold mb-2">— Charm</p>
                      <p className="font-serif italic text-[13.5px] sm:text-[14.5px] text-charcoal/85 leading-[1.85] max-w-md mx-auto">
                        {origin.charmHint}
                      </p>
                    </div>
                  )}

                  {/* Footer: brand + goal */}
                  <div className="mt-5 pt-4 border-t border-gold/25 flex items-center justify-between text-[9.5px] font-mono tracking-widest2 uppercase">
                    <span className="text-charcoal/45">SEAM · {new Date().getFullYear()}</span>
                    {mainGoal && (
                      <span className="text-charcoal/55">Goal · <span className="text-gold">{mainGoal.name}</span></span>
                    )}
                  </div>
                </div>
              </article>

              {/* charmHint は Profile Card 内に統合済み (重複排除) */}
            </>
          );
        })()}
        {/* Re-center the rest of original content */}
        <div className="text-center mt-2">

        {/* Index ナビは撤去済み (タスク #165 でモバイル安定性のため) */}

        {/* シェア・保存ボタン */}
        <div className="no-print mt-6 flex flex-wrap gap-2 justify-center">
          <button
            type="button"
            onClick={() => onSaveImage && onSaveImage('square')}
            className="inline-flex items-center gap-1.5 px-4 py-2.5 bg-white/70 border border-line text-charcoal/80 hover:border-ink hover:text-ink transition-colors font-mono tracking-widest2 text-[10px] uppercase rounded-[1px]"
          >
            画像で保存
          </button>
          <button
            type="button"
            onClick={() => onSaveImage && onSaveImage('story')}
            className="inline-flex items-center gap-1.5 px-4 py-2.5 bg-white/70 border border-line text-charcoal/80 hover:border-ink hover:text-ink transition-colors font-mono tracking-widest2 text-[10px] uppercase rounded-[1px]"
          >
            ストーリー
          </button>
          <button
            type="button"
            onClick={onShare}
            className="inline-flex items-center gap-1.5 px-4 py-2.5 bg-white/70 border border-line text-charcoal/80 hover:border-ink hover:text-ink transition-colors font-mono tracking-widest2 text-[10px] uppercase rounded-[1px]"
          >
            友達にすすめる
          </button>
        </div>
        </div>{/* /text-center mt-2 */}
      </div>
    </section>
  );
}

/* ---------- KartePentagon — 5軸レーダーチャート(現在 vs 目標) ---------- */
function KartePentagon({ values, targetValues, palette = 'gold' }) {
  const size = 240;
  const cx = size / 2;
  const cy = size / 2 + 4;
  const maxR = 82;
  const angleFor = i => (-90 + 72 * i) * Math.PI / 180;

  const accent = palette === 'ivory' ? '#D9BE93' : '#B8945A';
  const targetAccent = '#D9BE93';
  const labelColor = palette === 'ivory' ? '#E7E4DE' : '#3D3833';
  const valueColor = palette === 'ivory' ? '#D9BE93' : '#B8945A';
  const gridColor  = palette === 'ivory' ? 'rgba(217,190,147,0.25)' : '#E7E4DE';
  const outerGrid  = palette === 'ivory' ? 'rgba(217,190,147,0.45)' : '#D6C7B0';

  const vertex = (val, i) => {
    const r = (val / 5) * maxR;
    const a = angleFor(i);
    return [cx + r * Math.cos(a), cy + r * Math.sin(a)];
  };
  const dataPts  = values.map((v,i) => vertex(v,i));
  const dataStr  = dataPts.map(p => p.join(',')).join(' ');
  const targetPts = (targetValues || []).map((v,i) => vertex(v,i));
  const targetStr = targetPts.map(p => p.join(',')).join(' ');
  const gridStr  = [1,2,3,4,5].map(lv => values.map((_,i) => vertex(lv,i).join(',')).join(' '));
  const axisEnd  = (i) => vertex(5, i);
  const labels   = KARTE_AXES.map(x => x.label);
  const labelPos = (i) => {
    const a = angleFor(i);
    const r = maxR + 22;
    return [cx + r * Math.cos(a), cy + r * Math.sin(a)];
  };

  return (
    <svg viewBox={`0 0 ${size} ${size}`} className="w-full h-auto max-w-[260px] mx-auto" aria-hidden>
      {gridStr.map((pts, i) => (
        <polygon key={i} points={pts} fill="none" stroke={i === 4 ? outerGrid : gridColor} strokeWidth={i === 4 ? 0.9 : 0.7} />
      ))}
      {values.map((_, i) => {
        const end = axisEnd(i);
        return <line key={`ax${i}`} x1={cx} y1={cy} x2={end[0]} y2={end[1]} stroke={gridColor} strokeWidth="0.7" />;
      })}

      {/* 目標値(あれば)を点線で薄く描く */}
      {targetValues && (
        <>
          <polygon
            points={targetStr}
            fill={targetAccent}
            fillOpacity={palette === 'ivory' ? 0.10 : 0.08}
            stroke={targetAccent}
            strokeWidth="1.2"
            strokeDasharray="3 3"
            style={{ animation: 'karte-target-fade 1600ms ease-out 400ms both' }}
          />
          {targetPts.map((p, i) => (
            <circle key={`tpt${i}`} cx={p[0]} cy={p[1]} r="2.0" fill={targetAccent} opacity="0.7" />
          ))}
        </>
      )}

      {/* 現在値 */}
      <polygon
        points={dataStr}
        fill={accent} fillOpacity={palette === 'ivory' ? 0.22 : 0.16}
        stroke={accent} strokeWidth="1.4"
      />
      {dataPts.map((p, i) => (
        <circle key={`pt${i}`} cx={p[0]} cy={p[1]} r="2.6" fill={accent} />
      ))}

      {labels.map((lb, i) => {
        const [x,y] = labelPos(i);
        return (
          <g key={`lb${i}`}>
            <text x={x} y={y - 6} textAnchor="middle"
                  style={{ fontFamily:'"Inter", "Noto Sans JP", system-ui, sans-serif', fontSize:'11px', fontWeight: 600, fill: labelColor, letterSpacing:'0.1em' }}>
              {lb}
            </text>
            <text x={x} y={y + 10} textAnchor="middle"
                  style={{ fontFamily:'"Cormorant Garamond", serif', fontSize:'14px', fontWeight: 500, fill: valueColor }}>
              {values[i]}{targetValues && targetValues[i] !== values[i] && (
                <tspan dx="2" style={{ fill: targetAccent, fontSize:'10px' }}>→{targetValues[i]}</tspan>
              )}
            </text>
          </g>
        );
      })}
    </svg>
  );
}

/* ---------- KarteAnimalMark — 18キャラクター画像(line画モチーフ fallback) ---------- */
function KarteAnimalMark({ size = 92, accent = false, code }) {
  const s = size;
  const color = accent ? '#B8945A' : '#3D3833';
  // code が指定されていればキャラクター画像を表示(椎茸占い風の可愛いアバター)
  if (code) {
    return (
      <div
        className={`relative inline-block karte-mark-anim ${accent ? 'karte-mark-accent' : ''}`}
        style={{ width: s, height: s }}
      >
        {accent && <span className="karte-mark-glow" aria-hidden />}
        <img
          src={`images/characters/${code}.png`}
          alt=""
          width={s}
          height={s}
          loading="lazy"
          className="relative w-full h-full object-contain"
          onError={(e) => { e.target.style.display = 'none'; }}
        />
      </div>
    );
  }
  // fallback: 抽象 SVG マーク
  return (
    <div
      className={`relative inline-block karte-mark-anim ${accent ? 'karte-mark-accent' : ''}`}
      style={{ width: s, height: s }}
    >
      {accent && <span className="karte-mark-glow" aria-hidden />}
      <svg viewBox="0 0 100 100" width={s} height={s} aria-hidden className="relative">
        <circle cx="50" cy="50" r="46" fill="none" stroke={accent ? '#D9BE93' : '#E2DDD3'} strokeWidth="0.8" />
        <circle cx="50" cy="50" r="38" fill="none" stroke={accent ? '#D9BE93' : '#E7E4DE'} strokeWidth="0.5" opacity="0.6" />
        <g stroke={color} strokeWidth="0.9" fill="none" strokeLinecap="round">
          <path d="M50 26 L50 74" opacity="0.45" />
          <path d="M26 50 L74 50" opacity="0.45" />
          <path d="M50 28 L57 50 L50 72 L43 50 Z" opacity="0.78" />
          <circle cx="50" cy="50" r="3.2" fill={color} stroke="none" />
        </g>
        <text x="50" y="92" textAnchor="middle"
              style={{ fontFamily:'Montserrat, sans-serif', fontSize:'6.5px', fill: accent ? '#D9BE93' : '#8C7A63', letterSpacing:'0.3em', textTransform:'uppercase' }}>
          Seam · Karte
        </text>
      </svg>
    </div>
  );
}

/* ---------- KarteMiniPentagon — 図鑑用の小型レーダー ---------- */
function KarteMiniPentagon({ values, size = 110 }) {
  const cx = size / 2;
  const cy = size / 2 + 2;
  const maxR = size * 0.36;
  const angleFor = i => (-90 + 72 * i) * Math.PI / 180;
  const vertex = (val, i) => {
    const r = (val / 5) * maxR;
    const a = angleFor(i);
    return [cx + r * Math.cos(a), cy + r * Math.sin(a)];
  };
  const dataPts = values.map((v, i) => vertex(v, i));
  const dataStr = dataPts.map(p => p.join(',')).join(' ');
  const outline = values.map((_, i) => vertex(5, i).join(',')).join(' ');
  const grid3   = values.map((_, i) => vertex(3, i).join(',')).join(' ');
  return (
    <svg viewBox={`0 0 ${size} ${size}`} width={size} height={size} aria-hidden>
      <polygon points={outline} fill="none" stroke="#D6C7B0" strokeWidth="0.7" />
      <polygon points={grid3}   fill="none" stroke="#E7E4DE" strokeWidth="0.5" />
      <polygon points={dataStr} fill="#B8945A" fillOpacity="0.18" stroke="#B8945A" strokeWidth="1.1" />
      {dataPts.map((p, i) => <circle key={i} cx={p[0]} cy={p[1]} r="1.8" fill="#B8945A" />)}
    </svg>
  );
}

/* ---------- KarteCollectionCard — 図鑑の1枚 ---------- */
function KarteCollectionCard({ animal, isMine, onOpen, onPick }) {
  return (
    <div
      className={[
        'group bg-white/80 border rounded-[2px] p-5 sm:p-6 flex flex-col h-full transition-all',
        isMine ? 'border-gold shadow-soft' : 'border-line hover:border-ink hover:shadow-soft',
