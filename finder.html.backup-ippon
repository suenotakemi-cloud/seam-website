              <dd className="mt-1.5 font-serif text-[15px] text-ink leading-relaxed">{animal.strength}</dd>
            </div>
            <div>
              <dt className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55">Hidden concern</dt>
              <dd className="mt-1.5 text-[13px] text-charcoal/85 leading-[1.95]">{animal.hiddenConcern}</dd>
            </div>
          </dl>
          <div className="shrink-0 justify-self-center">
            <KarteMiniPentagon values={animal.radar} size={160} />
          </div>
        </div>

        <div className="mt-7 pt-5 border-t border-line">
          <p className="font-mono tracking-widest2 text-[10px] uppercase text-gold">進化先の4つの道</p>
          <div className="mt-3 grid grid-cols-2 sm:grid-cols-4 gap-3">
            {['A','B','C','D'].map(dir => {
              const id = animal.targets?.[dir];
              const goal = id && KARTE_GOAL_ANIMALS[id];
              if (!goal) return null;
              return (
                <div key={dir} className="text-center border border-line bg-white/70 rounded-[2px] p-3">
                  <p className="font-mono tracking-widest2 text-[9px] uppercase text-gold">{KARTE_DIRECTION_LABEL[dir]}</p>
                  <p className="mt-1.5 font-serif text-[13.5px] text-ink leading-snug">{goal.name}</p>
                </div>
              );
            })}
