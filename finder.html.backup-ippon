/* ---------- pickMustPlusOne — 必須プラスONE処方の選定 ---------- */
function pickMustPlusOne(products, answers, scores) {
  if (!products || products.length === 0) return [];
  const a = answers || {};
  const s = scores || {};
  const t = buildUserTags(a, s);
  const byId = {};
  for (const p of products) byId[p.id] = p;

  const matched = [];
  for (const rule of MUST_PLUS_ONE_RULES) {
    let fired = false;
    try { fired = !!rule.match({ a, t, s }); } catch (e) { fired = false; }
    if (!fired) continue;
    const matchedProducts = (rule.productIds || []).map(id => byId[id]).filter(Boolean);
    if (matchedProducts.length === 0) continue;
    matched.push({ rule, products: matchedProducts });
  }
  return matched;
}

/* ---------- pickDeepProducts — カテゴリ別ケア処方 (ルーティン順) ---------- */
function pickDeepProducts(products, answers, scores, flags, opts = {}) {
  const userTags  = buildUserTags(answers, scores);
  const hardRules = checkHardRules(userTags, answers, scores);
  const maxPerBrand = opts.maxPerBrand || 3;

  // キャラクター由来の商品アフィニティ(18キャラごとの最適商品)
  const originCode = opts.originCode || '';
  const affinityIds = new Set(CHARACTER_PRODUCT_AFFINITY[originCode] || []);
  // 悩み由来の商品アフィニティ(15種類の悩み別最適商品)
  const concernAffinityCount = {}; // 商品IDが何件の悩みにマッチしたか
  for (const c of ((answers || {}).concerns || [])) {
    const ids = CONCERN_PRODUCT_AFFINITY[c] || [];
    for (const id of ids) {
      concernAffinityCount[id] = (concernAffinityCount[id] || 0) + 1;
    }
  }

  // 必須プラスONE商品(MUST_PLUS_ONE_RULES)に登場する商品IDは、ケア処方からは除外
  // (重複表示を避けるため。プラスONEセクションで既に強く打ち出されている)
  const a = answers || {};
  const t = userTags;
  const sscores = scores || {};
  const mustIds = new Set();
  for (const rule of MUST_PLUS_ONE_RULES) {
    let fired = false;
    try { fired = !!rule.match({ a, t, s: sscores }); } catch (e) { fired = false; }
    if (fired) {
      for (const id of (rule.productIds || [])) mustIds.add(id);
    }
  }

  // 仕上げカテゴリ向け追加スコア (Color, Perm, Curl などの条件で 仕上げ商品を強化)
  const finishBoost = (p) => {
    const cat = deepCategoryForProduct(p);
    if (cat !== 'finish') return 0;
    let b = 8; // 仕上げ商品はベースで +8 (ルーティンの最後に1本は必要)
    // パーマ・カール持ちには クリエイティブスタイル 6番 を強く推奨
    if ((t.perm.includes('perm_history') || t.perm.includes('perm_loose') || t.perm.includes('perm_digital')) &&
        p.id === 'milbon-creativestyle-mediumhold-6') b += 20;
    // 巻き髪・スタイル維持には ジェミールフラン
    if ((a.styling?.tools || []).some(x => /curler/i.test(x)) && p.id === 'milbon-jemilefran-spray-sd') b += 18;
    // 毛先パサつき・ツヤ求める方には ニゼル ブライトアップ
    if ((t.goal.includes('goal_moist_gloss') || (a.concerns || []).includes('dryness') || (a.concerns || []).includes('damage')) &&
        p.id === 'milbon-nigelle-brightup-veil') b += 15;
    // カラーしている方には カラーモーション ルミナススプレー
    if ((t.color.includes('color_history') || t.color.includes('color_freq_high') || t.color.includes('gray_color')) &&
        p.id === 'colormotion-luminous-spray') b += 18;
    return b;
  };

  const scored = (products || []).map(p => {
    const base    = scoreSeamProduct(p, answers, scores, flags);
    const deep    = scoreProductDeep(p, userTags, hardRules);
    const penalty = applyPenalties(p, userTags);
    const finish  = finishBoost(p);
    const supp    = isSupplementary(p); // 補助ブランド判定
    // キャラクター別アフィニティ: メインは +45、補助ブランドは +12 (おまけ枠)
    let affinity = 0;
    if (affinityIds.has(p.id)) affinity = supp ? 12 : 45;
    // 悩み別アフィニティ: メインは +25/悩み (max+60)、補助は +8/悩み (max+20)
    const concernHits = concernAffinityCount[p.id] || 0;
    const concernUnit = supp ? 8 : 25;
    const concernCap  = supp ? 20 : 60;
    const concernAffinity = Math.min(concernCap, concernHits * concernUnit);
    // 補助ブランド全体に微小な減点(メインブランドを優先するため)
    const supplementPenalty = supp ? 6 : 0;
    return {
      p,
      s: Math.max(0, base + deep + finish + affinity + concernAffinity - penalty - supplementPenalty),
      deepCat: deepCategoryForProduct(p),
      isAffinity: affinity > 0 || concernAffinity > 0,
      isSupplementary: supp,
      affinityReason: [
        affinity > 0 ? 'character' : null,
        concernAffinity > 0 ? `concern×${concernHits}` : null,
      ].filter(Boolean).join('+'),
    };
  }).filter(x => x.s > 0 && x.deepCat && !mustIds.has(x.p.id))
    .sort((a, b) => b.s - a.s);

  // カテゴリ別バケット
  const blocks = {};
  const catSubUsed = {}; // 各バケット内で seam-master.json category の重複を避ける(legacy)
  const suppCountInBucket = {}; // 各バケット内の補助ブランド本数(おまけ枠制限)
  const brandCountInBucket = {}; // 各バケット内の同ブランド本数(バケット内多様性)
  for (const id of Object.keys(DEEP_CATEGORY_DEFS)) {
    blocks[id] = [];
    catSubUsed[id] = new Set();
    suppCountInBucket[id] = 0;
    brandCountInBucket[id] = {};
  }

  // 同一ブランドが全カテゴリで支配しないようグローバル上限を緩めに設定(各カテゴリ3本×6=18枠中、最大6本まで)
  const globalBrandCap = Math.max(maxPerBrand, 6);
  const brandCount = {};
  for (const item of scored) {
    const bucket = item.deepCat;
    const def = DEEP_CATEGORY_DEFS[bucket];
    if (!def) continue;
    // バケット容量
    if (blocks[bucket].length >= (def.max || 3)) continue;
    // ブランド集中防止 (グローバル: 全カテゴリ合計の上限)
    if ((brandCount[item.p.brand] || 0) >= globalBrandCap) continue;
    // バケット内ブランド集中防止 (各カテゴリ内で同ブランドは最大2本まで)
    if ((brandCountInBucket[bucket][item.p.brand] || 0) >= 2) continue;
    // 補助ブランドの「おまけ枠」: 各バケットに最大1点まで
    //   - finish のみ最大2点(ニゼル/ジェミールフラン両方OK)
    //   - outbath のみ最大2点(Elujuda + HITAなど混在OK)
    if (item.isSupplementary) {
      const suppCap = (bucket === 'finish' || bucket === 'outbath') ? 2 : 1;
      if (suppCountInBucket[bucket] >= suppCap) continue;
    }
    // バケット内では同一商品IDが連続するのを防ぐのみ
    // (シャンプー3本/トリートメント3本などを均等に出すため、カテゴリ重複は許容)
    // ブランド集中防止 (maxPerBrand) で1ブランドが独占しないよう既に制限済み
    blocks[bucket].push(item);
    brandCount[item.p.brand] = (brandCount[item.p.brand] || 0) + 1;
    brandCountInBucket[bucket][item.p.brand] = (brandCountInBucket[bucket][item.p.brand] || 0) + 1;
    catSubUsed[bucket].add(item.p.category);
    if (item.isSupplementary) suppCountInBucket[bucket]++;
  }

  return { blocks, userTags, hardRules };
}

/* ---------- SEAM全164商品マスター（seam-master.json）対応 ---------- */
// FWBUZR7u.xlsx 由来の164商品マスターを使用
function scoreSeamProduct(p, answers, scores, flags) {
  let s = 0;
  // 新schema互換: finishTags が {finish:[],weight,texture:[]} の場合に対応
  const finishArr = Array.isArray(p.finishTags) ? p.finishTags : (p.finishTags?.finish || []);
  const concernArr = p.concernTags || [];
  const functionArr = p.functionTags || [];
  // ── 髪質プロファイル一致(キャラクターごとの差別化) ──
  // 「ターゲットが絞られた商品」を「万能商品」より優先(narrowness bonus)
  const ht = p.hairType || {};
  const tList = ht.thickness || [];
  const dList = ht.density   || [];
  const wList = ht.wave      || [];
  // 髪の太さ
  if (answers.thickness && tList.length > 0) {
    if (tList.includes(answers.thickness)) {
      // base + specialty bonus(候補が少ないほど+α)
      s += 12 + (tList.length === 1 ? 8 : tList.length === 2 ? 4 : 0);
    } else {
      s -= 8;
    }
  }
  // 毛量
  if (answers.density && dList.length > 0) {
    if (dList.includes(answers.density)) {
      s += 10 + (dList.length === 1 ? 6 : dList.length === 2 ? 3 : 0);
    } else {
      s -= 6;
    }
  }
  // くせ
  if (answers.wave && wList.length > 0) {
    if (wList.includes(answers.wave)) {
      s += 8 + (wList.length <= 2 ? 4 : 0);
    } else if (answers.wave !== 'none' && answers.wave !== 'straightened') {
      s -= 4;
    }
  }
  for (const c of (answers.concerns || [])) {
    if (concernMatches(c, concernArr)) {
      // 基本マッチ +20
      s += 20;
      // 順序ボーナス: 製品の主要悩み(先頭ほど)に一致すると +6〜+15
      s += concernPositionBoost(c, concernArr);
    }
  }
  // スカルプマスクのブースト: 頭皮の悩みがある人に scalp-mask を強くマッチ
  const scalpConcerns = (answers.concerns || []).filter(c => ['scalpDry','scalpOily','thinning'].includes(c));
  if (scalpConcerns.length > 0 && functionArr.includes('scalp-mask')) s += 18;
  // 頭皮のべたつき/匂い特化: scalp-odor / buildup / dandruff があれば追加ブースト
  if ((scores.scalpOiliness || 0) >= 3) {
    if (concernArr.includes('scalp-odor')) s += 14;
    if (concernArr.includes('buildup')) s += 10;
    if (concernArr.includes('dandruff')) s += 8;
  }
  if (answers.goalTexture && finishArr.includes(answers.goalTexture)) s += 15;
  if (deriveBleach(answers)) {
    const bo = p.damageTags?.bleachOk;
    if (bo === 'multi-bleach') s += 30;
    else if (bo === 'heavy')   s += 22;
    else if (bo === 'medium')  s += 12;
  }
  const temp = answers.styling?.temp;
  if (temp === 't200' && (p.functionTags || []).includes('heat-protect')) s += 25;
  if (temp === 't180' && (p.functionTags || []).includes('heat-protect')) s += 15;

  // ── 熱保護: 普段使うアイテム種別を優先 ──
  // ミスト / ミルク / オイル のうちユーザーが選んだ種別の商品(熱保護タグ持ち)を強くプッシュ
  const heatProtectChoice = Array.isArray(answers.heatProtect) ? answers.heatProtect : (answers.heatProtect ? [answers.heatProtect] : []);
  const pCat = p.category || '';
  const hasHeatProtectTag = (p.functionTags || []).includes('heat-protect');
  if (heatProtectChoice.includes('mist') && /mist|water/.test(pCat)) {
    s += hasHeatProtectTag ? 22 : 14;
  }
  if (heatProtectChoice.includes('milk') && /milk|cream|emulsion/.test(pCat)) {
    s += hasHeatProtectTag ? 22 : 14;
  }
  if (heatProtectChoice.includes('oil') && /oil|butter/.test(pCat)) {
    s += hasHeatProtectTag ? 22 : 14;
  }
  if ((scores.scalpDryness  || 0) >= 3 && (p.concernTags || []).includes('scalp-dry'))  s += 12;
  if ((scores.scalpOiliness || 0) >= 3 && (p.concernTags || []).includes('scalp-oily')) s += 12;
  if ((scores.aging         || 0) >= 3 && (p.functionTags || []).includes('aging-care')) s += 10;

  // ── 頭皮悩みの優先ルーティング(エッセンス+シャンプー基軸) ──
  // 設計方針:
  //  - 頭皮悩みは「エッセンス + シャンプー」で処方
  //  - トリートメント / アウトバス(オイル・ミルク・ミスト) は "髪質の悩み" で処方
  //    (ダメージ・くせ・パサつき・ツヤ不足等)
  //  - フケ/かゆみは履歴問わずスキャルプ系シャンプー OK
  //  - 男性: シャンプー寄せはそのまま、TR/leave-in は髪質悩みに従う
  //  - 30歳以上: グランケアをエイジングケアとしてプッシュ(SH/エッセンスのみ)
  //  - 優先度: 薄毛 > 白髪/エイジング > 頭皮乾燥/フケ
  const concerns = answers.concerns || [];
  const isThinning  = concerns.includes('thinning') || (scores.volumeLoss || 0) >= 4;
  const isGrayHair  = answers.grayHair === 'yes' || answers.color === 'gray' || (scores.aging || 0) >= 3;
  const isScalpDry  = concerns.includes('scalpDry') || concerns.includes('scalpOily') || (scores.scalpDryness || 0) >= 2;
  const isAge30Plus = ['30s','40s','50plus'].includes(answers.age);
  const isMale      = answers.gender === 'male';
  const hasChemHistory = (answers.color && answers.color !== 'none')
                      || (answers.straighten && answers.straighten !== 'none')
                      || (answers.perm && answers.perm !== 'none');
  const line  = p.line || '';
  const cat   = p.category || '';
  const isEssence  = cat === 'scalp-essence';
  const isShampoo  = cat === 'shampoo' || cat === 'scalp-shampoo' || cat === 'scalp-cleanser';
  const isTreatment= cat === 'treatment' || cat === 'hair-mask' || cat === 'mask';
  const isLeaveIn  = /leave-in|out-?bath|outbath|booster/.test(cat);
  // 頭皮ブーストの対象: シャンプー + エッセンス のみ。
  // TR / leave-in は対象外(髪質悩みベースで素直にスコアリング)
  const isScalpRoutableCat = isShampoo || isEssence;
  const isAdenoOrPrecedia = /アデノバイタル|プレセディア/.test(line);
  const isAgingSpa        = /エイジングスパ/.test(line);
  const isGranCare        = /グランケア|プロマスター/.test(line);
  const isMoistCalm       = /モイストカーム/.test(line);

  // (A) 薄毛/抜け毛 — エッセンス+シャンプー
  if (isThinning && isScalpRoutableCat) {
    if (isEssence && isAdenoOrPrecedia) s += 70;
    if (isEssence && isAgingSpa)        s += 40;
    if (isShampoo && isAdenoOrPrecedia) s += 28;
    if (isShampoo && isAgingSpa)        s += 16;
  }
  // (B) 白髪 — グランケア エッセンス+シャンプー
  else if (isGrayHair && isScalpRoutableCat) {
    if (isEssence && isGranCare) s += 60;
    if (isShampoo && isGranCare) s += 26;
  }
  // (C) 頭皮乾燥/フケ/かゆみ — モイストカーム エッセンス + スカルプ系SH
  else if (isScalpDry && isScalpRoutableCat) {
    if (isEssence && isMoistCalm) s += 80;  // 頭皮乾燥はモイストカーム強プッシュ
    if (isShampoo && isMoistCalm) s += 26;
    // フケ/かゆみは履歴問わずスキャルプ系SHもOK
    if (isShampoo && (cat === 'scalp-shampoo' || cat === 'scalp-cleanser')) s += 18;
    if (isShampoo && (p.functionTags || []).includes('scalp-care')) s += 10;
  }

  // ── 30歳以上のエイジングケア必須プッシュ ──
  // エッセンス: 履歴問わず必ずグランケアをトップに
  // シャンプー: 履歴ナシ女性 or 男性のみ(履歴アリ女性はごわつき防止で除外)
  if (isAge30Plus && isGranCare && isScalpRoutableCat && !isThinning && !isScalpDry) {
    if (isEssence) s += 75;
    if (isShampoo && (!hasChemHistory || isMale)) s += 18;
  }

  // ── ごわつき防止 ──
  // 履歴アリ女性が頭皮ケアブランドのシャンプーに当たるのを軽減
  if (isShampoo && hasChemHistory && !isMale && (isGranCare || isAdenoOrPrecedia || isAgingSpa)) {
    s -= 20;
  }

  // ── タグ準拠の素直なブースト(以前の挙動を保持) ──
  if ((p.concernTags || []).includes('hairloss')) s += isThinning ? 8 : 0;
  if ((p.concernTags || []).includes('graying'))  s += isGrayHair ? 6 : 0;

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // ── セグメントタグ発火(for-fine-hair / for-wave-hair / for-color-damage 等) ──
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  const fn = p.functionTags || [];
  // (1) 細毛用 — thickness:thin
  if (answers.thickness === 'thin' && fn.includes('for-fine-hair')) s += 20;
  // (2) 癖毛用 — wave is anything except none/straightened
  const hasWave = answers.wave && answers.wave !== 'none' && answers.wave !== 'straightened';
  if (hasWave && fn.includes('for-wave-hair')) s += 22;
  // (3) カラーダメージ用 — color !== none
  const hasColor = answers.color && answers.color !== 'none';
  if (hasColor && fn.includes('for-color-damage')) s += 18;
  // (4) ブリーチダメージ用 — bleach系のcolor or deriveBleach
  const hasBleach = /^(bleach_recent|bleach_past|multi_bleach|highlight)$/.test(answers.color || '') || !!deriveBleach(answers);
  if (hasBleach && fn.includes('for-bleach-damage')) s += 25;
  // (5) パーマダメージ用 — perm !== none/past
  const hasPerm = answers.perm && answers.perm !== 'none' && answers.perm !== 'past';
  if (hasPerm && fn.includes('for-perm-damage')) s += 18;
  // (6) 縮毛矯正ダメージ用 — straighten !== none
  const hasStraighten = answers.straighten && answers.straighten !== 'none';
  if (hasStraighten && fn.includes('for-straighten-damage')) s += 22;
  // (7) 熱ダメージ用 — temp >= 180 or daily iron use
  const tools = (answers.styling?.tools || []);
  const dailyHeat = tools.includes('ironDaily') || tools.includes('curlerDaily');
  const hotTemp = answers.styling?.temp === 't180' || answers.styling?.temp === 't200';
  if ((dailyHeat || hotTemp) && fn.includes('for-heat-damage')) s += 22;
  // (8) スカルプ用 — 頭皮悩み(乾燥/オイリー/薄毛/フケ)
  const hasScalpConcern = isScalpDry || isThinning || (answers.concerns || []).some(c => ['scalpDry','scalpOily','thinning','dandruff'].includes(c));
  if (hasScalpConcern && fn.includes('for-scalp')) s += 18;
  // (9) エイジングケア用 — 30歳以上は必ず発火
  if (isAge30Plus && fn.includes('for-aging')) s += 22;

  // ── ブロンドアブソリュ厳格化: 名前通りブリーチ毛にのみ発火 ──
  if (/ブロンドアブソリュ/.test(line) && !hasBleach) s -= 30;

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // ── ブリーチ毛のセグメント別ルーティング ──
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  if (hasBleach) {
    // (1) 必須商品(リピッドブースター/アルタイムリペア)は最強プッシュ
    if (p.mustShowForBleach) s += 60;
    // (2) 白髪+ブリーチ → アルティールが最適(+80で他のブリーチ補修より優先)
    if (isGrayHair && /アルティール/.test(line)) s += 80;
    // (3) 細毛 + ブリーチ → ブロンドアブソリュが最適(+50で他に優先)
    if (answers.thickness === 'thin' && /ブロンドアブソリュ/.test(line)) s += 50;
    // (4) 普通毛/くせ毛広がり + ブリーチ → BYKARTE HS / リペアリティ / インメトリィ
    const isNormalOrWavy = answers.thickness === 'normal' || hasWave;
    if (isNormalOrWavy) {
      if (/リペアリティ/.test(line))   s += 35;
      if (/インメトリィ/.test(line))   s += 30;
      // BYKARTE HS+ や UH+(高ダメージ向け)
      if (p.brand === 'BYKARTE' && /HS\+|UH\+|CH\+/.test(p.name || '')) s += 30;
    }
  }

  // ── アクアヴィアはくせ毛 Top に来ないように軽ペナルティ(ミラジェリィ/インメトリィに譲る) ──
  if (/アクアヴィア/.test(line) && hasWave) s -= 8;

  // ── ブランド優先度調整 ──
  // BYKARTE は優先表示(+20)、Kérastase / Davines は積極的に出さない(-15)
  const brand = p.brand || '';
  if (brand === 'BYKARTE')          s += 20;
  else if (brand === 'Kérastase')   s -= 15;
  else if (brand === 'Davines')     s -= 15;
  if (answers.color && answers.color !== 'none' && (p.functionTags || []).includes('color-lock')) s += 10;
  if ((scores.damage      || 0) >= 3 && (p.concernTags || []).includes('damage'))      s += 10;
  if ((scores.volumeLoss  || 0) >= 3 && (p.concernTags || []).includes('volume-down')) s += 8;
  if ((scores.heatDamage  || 0) >= 3 && (p.concernTags || []).includes('heat-damage')) s += 10;
  // 価格懸念
  if ((answers.concernsItem || []).includes('price') && p.priceTier === 'luxury') s -= 10;
  return s;
}

function pickSeamProducts(products, answers, scores, flags, opts = {}) {
  const maxPerBrand = opts.maxPerBrand || 2;
  const scored = products
    .map(p => ({ p, s: scoreSeamProduct(p, answers, scores, flags) }))
    .filter(x => x.s > 0)
    .sort((a, b) => b.s - a.s);
  // カテゴリごとに最高スコア。同ブランドが上限を超えないよう調整
  const byCategory = {};
  const brandCount = {};
  for (const { p, s } of scored) {
    if (byCategory[p.category]) continue;
    if ((brandCount[p.brand] || 0) >= maxPerBrand) continue;
    byCategory[p.category] = { p, s };
    brandCount[p.brand] = (brandCount[p.brand] || 0) + 1;
  }
  return Object.values(byCategory).sort((a, b) => (a.p.routineStep || 99) - (b.p.routineStep || 99));
}

/* ---------- ヘッドスパメニュー & 推奨ロジック ---------- */
const HEAD_SPA_RECS = [
  {
    id: 'refresh',
    name: 'リフレッシュ ヘッドスパ',
    nameEn: 'Refresh Head Spa',
    duration: '約30分',
    why: '目の疲れや頭の重さを、頭皮の血流ケアでやわらげます。',
    triggers: ['eyeStrain', 'mindFull'],
    intensity: 'light',
  },
  {
    id: 'release',
    name: 'リリース ヘッドスパ',
    nameEn: 'Release Head Spa',
    duration: '約45分',
    why: '肩・首・頭のこりを、深めの指圧でほぐします。',
    triggers: ['neckShoulder', 'bodyHeavy'],
    intensity: 'medium',
  },
  {
    id: 'sleep',
    name: 'スリープ ヘッドスパ',
    nameEn: 'Sleep Head Spa',
    duration: '約50分',
    why: '深い呼吸と温感で、ぐっすり眠るためのスパです。',
    triggers: ['sleepLight', 'mindFull'],
    intensity: 'deep',
  },
  {
    id: 'deep',
    name: 'ディープリラックス ヘッドスパ',
    nameEn: 'Deep Relax Head Spa',
    duration: '約60分',
    why: '頭・肩・呼吸を丁寧にほぐすフルコースです。',
    triggers: ['eyeStrain', 'neckShoulder', 'mindFull', 'sleepLight', 'bodyHeavy'],
    intensity: 'full',
    fullCare: true,
  },
  {
    id: 'scalp-growth',
    name: 'スカルプ ヘッドスパ(頭皮環境ケア)',
    nameEn: 'Scalp Growth Head Spa',
    duration: '約50分',
    why: '頭皮環境を整え、健やかな髪が育つ土台をサポートするスパです。',
    triggers: [],
    forThinning: true,
    intensity: 'medium',
  },
];

const WELLNESS_LABEL = {
  eyeStrain:    '目の疲れ',
  neckShoulder: '肩・首のこり',
  mindFull:     '気持ちが休まらない',
  sleepLight:   '寝つきが悪い',
  bodyHeavy:    '体のだるさ',
  well:         '特に気にならない',
};

function pickHeadSpaRecs(answers) {
  const a = answers || {};
  const w = a.wellness || [];
  const concerns = a.concerns || [];
  const recs = [];

  // ヘッドスパに興味がない場合は提案しない(薄毛も含めて)
  if (a.headSpaInterest === 'no') return null;

  // 薄毛・抜け毛があれば、スカルプ(頭皮環境ケア)を最優先で
  // ※ ただし headSpaInterest が 'yes' か未回答のときのみ
  if (concerns.includes('thinning')) {
    const sp = HEAD_SPA_RECS.find(x => x.id === 'scalp-growth');
    if (sp) recs.push({ ...sp, matchCount: 99 });
  }

  // ヘッドスパに興味あり + ウェルネス未回答 のときは、デフォルトコースを提案
  if (a.headSpaInterest === 'yes' && (w.length === 0 || (w.length === 1 && w.includes('well')))) {
    const refresh = HEAD_SPA_RECS.find(x => x.id === 'refresh');
    if (refresh && !recs.some(r => r.id === refresh.id)) recs.push({ ...refresh, matchCount: 1 });
    return recs;
  }

  // ウェルネス傾向で推奨
  if (w.length === 0 || (w.length === 1 && w.includes('well'))) {
    return recs.length ? recs : null;
  }

  const scored = HEAD_SPA_RECS
    .filter(s => !s.forThinning)
    .map(spa => ({ ...spa, matchCount: spa.triggers.filter(t => w.includes(t)).length }))
    .filter(s => s.matchCount > 0)
    .sort((a, b) => b.matchCount - a.matchCount);

  // 3つ以上の悩みがあるなら、Deep + 個別2つ
  if (w.length >= 3) {
    const deep = HEAD_SPA_RECS.find(s => s.fullCare);
    const others = scored.filter(s => !s.fullCare).slice(0, 2);
    recs.push(...(deep ? [{ ...deep, matchCount: w.length }] : []), ...others);
  } else {
    // 1〜2個 → 該当する専門スパを優先表示(Deep は出さない)
    const individualSpas = scored.filter(s => !s.fullCare).slice(0, 2);
    recs.push(...individualSpas);
  }

  // 重複除去
  const seen = new Set();
  return recs.filter(s => { if (seen.has(s.id)) return false; seen.add(s.id); return true; });
}

function HeadSpaSection({ answers }) {
  const spas = useMemo(() => pickHeadSpaRecs(answers), [answers]);
  if (!spas || spas.length === 0) return null;

  const wellnessSelected = ((answers && answers.wellness) || []).filter(w => w !== 'well');
  const hasThinning = ((answers && answers.concerns) || []).includes('thinning');

  return (
    <section className="mt-12 sm:mt-16 anim-fade-up" style={{ animationDelay:'340ms' }}>
      <p className="font-mono tracking-widest2 text-[11px] uppercase text-gold">— Head Spa</p>
      <h2 className="mt-3 font-serif text-2xl sm:text-3xl text-ink leading-snug">
        おすすめのヘッドスパ
      </h2>
      <p className="mt-2 text-[12.5px] sm:text-[13px] text-charcoal/70 leading-[1.95] max-w-2xl">
        {hasThinning
          ? '頭皮環境を整える頭皮環境ケアのスパからご提案します。'
          : 'いまのあなたの症状に合うヘッドスパをご提案します。'}
      </p>

      {(wellnessSelected.length > 0 || hasThinning) && (
        <div className="mt-5 border-l-2 border-gold pl-4 sm:pl-5 py-1">
          <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-gold">— あなたが気になっていること</p>
          <div className="mt-2 flex flex-wrap gap-1.5">
            {hasThinning && (
              <span className="font-mono tracking-widest2 text-[10px] uppercase text-ink bg-cream px-2 py-1 rounded-[1px]">
                頭皮環境を整えたい
              </span>
            )}
            {wellnessSelected.map((w, i) => (
              <span key={i} className="font-mono tracking-widest2 text-[10px] uppercase text-ink bg-cream px-2 py-1 rounded-[1px]">
                {WELLNESS_LABEL[w] || w}
              </span>
            ))}
          </div>
        </div>
      )}

      <div className="mt-7 grid sm:grid-cols-2 gap-4">
        {spas.map((spa) => (
          <article key={spa.id} className="bg-white border border-line p-5 sm:p-6 rounded-[2px] flex flex-col">
            <header className="flex items-center justify-between pb-3 border-b border-line gap-3">
              <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-gold whitespace-nowrap">
                Head Spa{spa.fullCare ? ' · Full' : ''}
              </span>
              <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55 nums">
                {spa.duration}
              </span>
            </header>
            <p className="mt-3 font-mono tracking-widest2 text-[10px] uppercase text-charcoal/55">{spa.nameEn}</p>
            <h3 className="mt-1 font-serif text-[18px] sm:text-[20px] text-ink leading-snug">{spa.name}</h3>
            <p className="mt-3 text-[13px] leading-[1.95] text-charcoal/85 flex-1">{spa.why}</p>

            <div className="mt-4 flex flex-wrap gap-2 no-print">
              <button
                type="button"
                data-open-resv
                aria-label="ヘッドスパを予約する"
                className="inline-flex items-center justify-center gap-2 px-5 min-h-[44px] bg-ink text-ivory text-[12px] tracking-widest2 uppercase rounded-[2px] hover:bg-charcoal active:scale-[0.97] transition-all"
              >
                予約する
              </button>
              <a
                href="#visit-seam"
                onClick={(e) => { e.preventDefault(); document.getElementById('visit-seam')?.scrollIntoView({ behavior:'smooth', block:'start' }); }}
                aria-label="店舗を見る"
                className="inline-flex items-center justify-center gap-2 px-5 min-h-[44px] border border-line text-charcoal text-[12px] tracking-widest2 uppercase rounded-[2px] hover:border-ink hover:text-ink active:scale-[0.97] transition-all"
              >
                店舗を見る
              </a>
            </div>
          </article>
        ))}
      </div>

      <p className="mt-6 text-[12px] text-charcoal/60 leading-[1.85] max-w-2xl">
        ※ ヘッドスパは美容師による施術です。当日の体調や髪の状態に合わせて、最適なコースをご案内いたします。
      </p>
    </section>
  );
}

/* ---------- pickHomeTools — Home Tools(美容家電)おすすめロジック ---------- */
function pickHomeTools(tools, answers, scores) {
  if (!tools || !tools.length) return [];
  const a = answers || {};
  const s = scores || {};
  const concerns = a.concerns || [];
  const tools_used = (a.styling && a.styling.tools) || [];
  const temp = a.styling && a.styling.temp;
  const usesIron = tools_used.some(t => /^iron|bangs/i.test(t)) || ['t180','t200'].includes(temp);
  const usesCurler = tools_used.some(t => /curler/i.test(t));
  const isBleached = a.bleach && a.bleach !== 'none';
  const length = a.length || '';
  const isLong = ['shoulderDown', 'chestUp', 'long'].includes(length);
  const isShort = ['short', 'bob', 'shoulderUp'].includes(length);
  const isCoarse = a.thickness === 'thick' || (s.frizz || 0) >= 3;
  const hasScalpOdor = (s.scalpOiliness || 0) >= 3 || concerns.includes('scalpOily');
  const hasScalpDry = (s.scalpDryness || 0) >= 3 || concerns.includes('scalpDry');
  const hasThinning = concerns.includes('thinning') || concerns.includes('topFlat') || concerns.includes('volumeDown') || (s.aging || 0) >= 3;

  const scored = tools.map(t => {
    let score = 0;
    const m = t.match || {};
    // ベース重み
    score += m.weight || 0;
    // 全員向けフラグ
    if (m.anyone) score += 4;
    // 関心タグ一致
    for (const c of concerns) {
      if ((m.concerns || []).includes(c)) score += 6;
    }
    // アイロン使用者
    if (usesIron && m.iron) score += 15;
    if (usesCurler && m.curler) score += 15;
    // ブリーチ毛 → 低ダメージプロ仕様優先
    if (isBleached && m.bleached) score += 12;
    if (isBleached && t.subtype === 'professional') score += 6;
    // 長さマッチ(カールアイロン径選択)
    if (length && (m.length || []).includes(length)) score += 10;
    // 剛毛 → パワーストレート
    if (isCoarse && m.coarseHair) score += 12;
    // 頭皮ニオイ/ベタつき → シャワーヘッド
    if (hasScalpOdor && m.scalpOdor) score += 14;
    // 薄毛・抜け毛 → 頭皮系
    if (hasThinning && (t.category === 'tool-headspa' || t.subtype === 'scalp-care' || t.subtype === 'scalp-massage')) score += 12;
    // 頭皮乾燥/オイリー → headspa
    if ((hasScalpOdor || hasScalpDry) && t.category === 'tool-headspa') score += 8;
    return { t, score };
  }).filter(x => x.score > 0).sort((a, b) => b.score - a.score);

  // カテゴリ別 (ドライヤー1 + アイロン1 + α) で多様性確保 - 最大4個
  const picks = [];
  const usedCategories = new Set();
  const maxByCat = { 'tool-dryer': 1, 'tool-iron-straight': 1, 'tool-iron-curl': 1, 'tool-iron-2way': 1, 'tool-iron-brush': 1, 'tool-shower': 1, 'tool-headspa': 1, 'tool-brush': 1 };
  for (const { t, score } of scored) {
    if (picks.length >= 4) break;
    const cat = t.category;
    if (usedCategories.has(cat) && (maxByCat[cat] || 1) <= 1) continue;
    picks.push({ ...t, _score: score });
    usedCategories.add(cat);
  }
  return picks;
}

/* ---------- HomeToolsSection — 美容家電おすすめセクション ---------- */
function HomeToolsSection({ tools, answers, scores }) {
  const picks = useMemo(
    () => pickHomeTools(tools, answers, scores),
    [tools, answers, scores]
  );
  if (!picks || picks.length === 0) return null;

  return (
    <section className="mt-12 sm:mt-16 anim-fade-up" style={{ animationDelay: '320ms' }}>
      <div className="mb-5">
        <p className="font-mono tracking-widest2 text-[11px] uppercase text-gold">— Home Tools</p>
        <h2 className="mt-3 font-serif text-2xl sm:text-3xl text-ink leading-snug">髪の質感を上げる、毎日の道具</h2>
        <p className="mt-3 text-[13px] sm:text-[14px] text-charcoal/70 leading-[1.95] max-w-2xl">
          ヘアケア用品と同じくらい、<span className="text-ink">毎日のドライヤーやアイロン</span>が髪を作ります。
          診断結果から、いまのあなたの髪に最適な美容家電を厳選しました。
        </p>
      </div>
      <div className="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-5">
        {picks.map(t => (
          <article key={t.id} className="bg-white border border-gold/30 rounded-[2px] p-3 sm:p-6 flex flex-col">
            {/* ━━━━ スマホ: 横並びコンパクト / PC: 縦積み従来レイアウト ━━━━ */}
            <div className="flex sm:flex-col gap-3 sm:gap-0">
              <ProductImage p={t} className="w-20 h-20 sm:w-full sm:h-40 shrink-0 sm:mb-4 rounded-[2px]" />
              <div className="min-w-0 flex-1">
                <p className="font-mono tracking-widest2 text-[9px] sm:text-[10px] uppercase text-charcoal/55">
                  {t.brand}
                </p>
                <h4 className="mt-1 sm:mt-1.5 font-serif text-[14px] sm:text-[17px] text-ink leading-snug">{t.name}</h4>
                {t.priceTier === 'luxury' && (
                  <span className="mt-1.5 sm:mt-2 inline-block font-mono tracking-widest2 text-[8.5px] sm:text-[9px] uppercase text-gold bg-cream/60 border border-gold/40 px-1.5 sm:px-2 py-0.5 rounded-[1px]">
                    Premium Tier
                  </span>
                )}
              </div>
            </div>
            <p className="mt-2.5 sm:mt-3 text-[12px] sm:text-[13.5px] leading-[1.75] sm:leading-[1.95] text-charcoal/85">
              {t.featureSummary}
            </p>
            <p className="mt-2.5 sm:mt-3 text-[11.5px] sm:text-[12.5px] leading-[1.8] sm:leading-[1.9] text-charcoal/65 border-l-2 border-gold/30 pl-2.5 sm:pl-3">
              <span className="font-mono tracking-widest2 text-[9px] sm:text-[9.5px] uppercase text-gold mr-1.5">Why</span>
              {t.reasonBase}
            </p>
            {t.featurePoints && t.featurePoints.length > 0 && (
              <div className="mt-3 sm:mt-4 flex flex-wrap gap-1 sm:gap-1.5 mt-auto">
                {/* スマホは 2chip まで, PC は 3chip */}
                {t.featurePoints.slice(0, 3).map((pt, i) => (
                  <span
                    key={i}
                    className={`text-[10.5px] sm:text-[11px] px-1.5 sm:px-2 py-0.5 sm:py-1 border border-line text-charcoal/65 rounded-[1px] bg-cream/40 ${i >= 2 ? 'hidden sm:inline-block' : ''}`}
                  >
                    {pt}
                  </span>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
      <p className="mt-4 sm:mt-5 text-[11.5px] sm:text-[12px] text-charcoal/60 leading-relaxed">
        ※ 美容家電は店頭でも実機をお試しいただけます。お気軽に SEAM スタッフまでお声がけください。
      </p>
    </section>
  );
}

function isRefillImage(src) {
  if (!src) return false;
  const s = src.toLowerCase();
  // 直接的な詰め替え/パウチ表記のみフィルター
  return /refill|pouch|リフィル|レフィル|詰め?替え?|詰替|パウチ|sachet/i.test(s);
}

/* sizeLabels から詰め替え/パウチサイズを除去 (本体サイズのみ表示) */
function filterNonRefillSizes(sizeLabels) {
  if (!sizeLabels || !sizeLabels.length) return [];
  return sizeLabels.filter(label => {
    const s = (label || '').toLowerCase();
    return !/refill|pouch|リフィル|レフィル|詰め?替え?|詰替|パウチ|sachet|パック|pack/i.test(s);
  });
}

function ProductImage({ p, className }) {
  // seam-master.json は `image`、レガシーは `imageUrl` — どちらも許容
  let imgSrc = p.image || p.imageUrl;
  if (isRefillImage(imgSrc)) imgSrc = null; // 詰め替えは出さない
  if (!imgSrc) {
    return (
      <div className={`flex items-center justify-center bg-gradient-to-br from-cream/30 via-white to-cream/40 border border-line ${className || ''}`}>
        <span className="font-serif text-[12px] text-charcoal/30 tracking-wider">{p.brand}</span>
      </div>
    );
  }
  return (
    <div className={`bg-white ${className || ''}`} style={{ overflow: 'hidden' }}>
      <img
        src={imgSrc}
        alt={p.name}
        loading="lazy"
        className="w-full h-full object-contain"
        onError={(e) => { e.target.style.display = 'none'; }}
      />
    </div>
  );
}

function ProductCardLarge({ item }) {
  const { p, roleLabel, _unusedBoost } = item;
  return (
    <article className="bg-white border border-gold/40 rounded-[2px] p-5 sm:p-7 relative overflow-hidden">
      {/* ★ ランクや% は出さず、キュレートの "役割" だけを上品に提示 */}
      <div className="absolute top-0 right-0 bg-ink text-ivory px-3 py-1.5 font-mono tracking-widest2 text-[9.5px] uppercase nums rounded-bl-[2px] z-10">
        — Editor's Pick
      </div>
      <div className="flex flex-col sm:flex-row gap-4 sm:gap-6 mb-4">
        <ProductImage p={p} className="w-full sm:w-36 h-40 sm:h-36 shrink-0 rounded-[2px]" />
        <div className="flex-1 min-w-0">
          <div className="flex items-center gap-2 mb-3 flex-wrap">
            <span className="font-mono tracking-widest2 text-[10px] uppercase text-gold">
              {roleLabel || 'もっとも合いやすい提案'}
            </span>
            {_unusedBoost && (
              <span className="ml-1 font-mono tracking-widest2 text-[9.5px] uppercase text-ink bg-cream/80 border border-gold/30 px-2 py-0.5 rounded-[1px]">
                いま一番おすすめ
              </span>
            )}
          </div>
          <p className="font-mono tracking-widest2 text-[10px] uppercase text-charcoal/55">
            {p.brand}{p.line && p.line !== p.brand && <span> · {p.line}</span>}
          </p>
          <h4 className="mt-1.5 font-serif text-[19px] sm:text-[21px] text-ink leading-snug">{p.name}</h4>
        </div>
      </div>
      <p className="mt-3 text-[13.5px] sm:text-[14px] leading-[1.95] text-charcoal/85">{p.featureSummary || p.cardCopy}</p>
      {(() => {
        const chips = getProductChips(p, 5);
        return chips.length > 0 && (
          <div className="mt-3 flex flex-wrap gap-1.5">
            {chips.map((c, i) => (
              <span key={i} className="text-[11px] px-2.5 py-0.5 bg-cream/60 text-charcoal/80 border border-gold/30 rounded-[1px] whitespace-nowrap" style={{ letterSpacing: '0.02em' }}>{c}</span>
            ))}
          </div>
        );
      })()}
      {p.recommendedFor && (
        <p className="mt-3 text-[12px] text-charcoal/65 leading-relaxed">
          <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/45 mr-1.5">For</span>{p.recommendedFor}
        </p>
      )}
      {p.sizeLabels && p.sizeLabels.length > 0 && (
        <a
          href={p.productPageUrl || (typeof SHOP_URL !== 'undefined' ? SHOP_URL : '#')}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${p.name}を公式サイトで見る (新規タブで開く)`}
          className="mt-5 group block border border-gold/40 bg-white rounded-[2px] overflow-hidden hover:border-gold active:scale-[0.99] transition-all no-print"
        >
          {/* Row 1: ¥ Member Price + Size */}
          <div className="px-4 pt-3 pb-2.5 flex items-center justify-between gap-3 flex-wrap bg-gradient-to-r from-cream/35 via-white to-cream/35">
            <div className="flex items-center gap-2">
              <span className="font-serif text-[18px] text-gold leading-none">¥</span>
              <span className="font-mono tracking-widest2 text-[10px] uppercase text-gold whitespace-nowrap">Member Price</span>
            </div>
            <span className="font-mono tracking-widest2 text-[11px] uppercase text-ink whitespace-nowrap">{p.sizeLabels.join(' / ')}</span>
          </div>
          {/* Row 2: 公式サイトで見る CTA (フルワイド) */}
          <div className="border-t border-gold/15 px-4 py-3 flex items-center justify-between gap-2 min-h-[44px]">
            <span className="font-mono tracking-widest2 text-[11px] uppercase text-ink group-hover:text-gold transition-colors">公式サイトで見る</span>
            <span className="text-gold group-hover:translate-x-1 transition-transform text-[14px] leading-none" aria-hidden>↗</span>
          </div>
          <p className="px-4 pb-2 text-[10.5px] text-charcoal/55 leading-snug">価格は会員登録後にご確認いただけます</p>
        </a>
      )}
    </article>
  );
}

function ProductCardSmall({ item }) {
  const { p, role, roleLabel } = item;
  // 役割ごとに小さくトーンを変える(alternative=gold / different=charcoal)
  const accent = role === 'different'
    ? 'border-charcoal/20'
    : 'border-gold/30';
  const tagColor = role === 'different'
    ? 'text-charcoal/65'
    : 'text-gold';
  return (
    <article className={`bg-white border ${accent} rounded-[2px] p-3.5 sm:p-4 flex flex-col h-full relative`}>
      <p className={`font-mono tracking-widest2 text-[9px] uppercase ${tagColor} leading-tight mb-2 min-h-[2.4em]`}>
        — {roleLabel || ''}
      </p>
      <ProductImage p={p} className="w-full h-28 sm:h-32 mb-2.5 rounded-[1px]" />
      <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55 truncate">{p.brand}</p>
      <h5 className="mt-1 font-serif text-[13.5px] sm:text-[14.5px] text-ink leading-snug line-clamp-2 min-h-[2.6em]">{p.name}</h5>
      {p.sizeLabels && p.sizeLabels.length > 0 && (
        <a
          href={p.productPageUrl || (typeof SHOP_URL !== 'undefined' ? SHOP_URL : '#')}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${p.name}を公式サイトで見る (新規タブで開く)`}
          className="mt-3 group flex items-center justify-between border border-gold/30 px-2.5 py-2 rounded-[2px] min-h-[36px] hover:border-gold active:scale-[0.97] transition-all no-print"
        >
          <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-ink">¥ Member</span>
          <span className="text-gold group-hover:translate-x-0.5 transition-transform" aria-hidden>↗</span>
        </a>
      )}
    </article>
  );
}

/* ──────────────────────────────────────────────────────────────────
   MustPlusOneSection — 必須プラスONE処方
   診断結果の "あなただけのケア処方" の前に強く表示する、悩み別マスト本。
   ────────────────────────────────────────────────────────────────── */
function MustPlusOneSection({ matches }) {
  if (!matches || matches.length === 0) return null;
  return (
    <section className="mt-10 sm:mt-14 anim-fade-up" style={{ animationDelay: '180ms' }}>
      {/* Section header */}
      <div className="flex items-start justify-between flex-wrap gap-3 mb-3">
        <div>
          <p className="font-mono tracking-widest2 text-[11px] uppercase text-gold">— Plus One · Recommend</p>
          <h2 className="mt-3 font-serif text-2xl sm:text-3xl text-ink leading-snug">
            あなたにもっともおすすめしたい、ケアアイテム。
          </h2>
        </div>
        <span className="font-mono tracking-widest2 text-[10px] uppercase text-charcoal/55 pt-1 nums">
          {matches.length} item{matches.length > 1 ? 's' : ''}
        </span>
      </div>
      <p className="mt-2 text-[12.5px] sm:text-[13px] text-charcoal/70 leading-[1.95] max-w-2xl">
        いつものシャンプー・トリートメント・アウトバスにプラスONEするだけで、仕上がりが大きく変わる一本。
      </p>
      <div className="mt-3 inline-flex items-center gap-1.5 font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55">
        <span className="w-1 h-1 rounded-full bg-gold" />
        <span>Available at SEAM</span>
      </div>

      {/* Cards */}
      <div className="mt-7 space-y-5 sm:space-y-6">
        {matches.map(({ rule, products }) => (
          <article
            key={rule.key}
            className="relative bg-white border-y sm:border border-gold/35 sm:rounded-[3px] -mx-5 sm:mx-0 overflow-hidden shadow-[0_2px_24px_-12px_rgba(181,124,90,0.35)] active:scale-[0.998] transition-transform"
          >
            {/* Top accent bar */}
            <div className="h-[3px] bg-gradient-to-r from-gold/70 via-gold to-gold/70" />

            <div className="p-5 sm:p-6">
              {/* Badge */}
              <header className="flex items-center justify-between gap-3 flex-wrap pb-3 border-b border-line">
                <div className="flex items-center gap-2.5">
                  <span className="inline-flex items-center gap-1.5 font-mono tracking-widest2 text-[9.5px] uppercase text-ivory bg-ink px-2.5 py-1 rounded-[1px] whitespace-nowrap">
                    <span className="w-1 h-1 rounded-full bg-gold animate-pulse" />
                    + 1 Recommend
                  </span>
                  <span className="font-mono tracking-widest2 text-[10px] uppercase text-gold whitespace-nowrap">— {rule.badge}</span>
                </div>
                <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/60 whitespace-nowrap">
                  {rule.badgeJp}
                </span>
              </header>

              {/* Headline */}
              <div className="mt-4">
                <h3 className="font-serif text-[18px] sm:text-[21px] text-ink leading-snug">
                  {rule.headline}
                </h3>
                <p className="mt-2 font-serif text-[14px] sm:text-[15px] text-gold leading-snug">
                  {rule.sub}
                </p>
              </div>

              {/* Description */}
              <p className="mt-3 text-[12.5px] sm:text-[13px] leading-[1.95] text-charcoal/80">
                {rule.desc}
              </p>

              {/* Recommend reason badge */}
              <div className="mt-4 inline-flex items-center gap-2 bg-cream/60 border border-gold/30 px-3 py-1.5 rounded-[1px]">
                <span className="font-mono tracking-widest2 text-[9px] uppercase text-gold">Why</span>
                <span className="text-[11.5px] text-ink leading-snug">{rule.must}</span>
              </div>

              {/* Products */}
              <div className={`mt-5 grid gap-3 ${products.length > 1 ? 'sm:grid-cols-2' : ''}`}>
                {products.map(p => (
                  <div key={p.id} className="bg-cream/35 border border-line rounded-[2px] p-4 flex gap-4 items-start">
                    {/* image */}
                    {(() => {
                      const src = (p.image || p.imageUrl);
                      if (!src || (typeof isRefillImage === 'function' && isRefillImage(src))) return null;
                      return (
                        <div className="shrink-0 bg-white border border-line rounded-[1px] w-20 h-24 sm:w-24 sm:h-28 flex items-center justify-center overflow-hidden">
                          <img
                            src={src}
                            alt={p.name}
                            loading="lazy"
                            className="max-w-full max-h-full object-contain"
                            onError={(e) => { e.target.style.display = 'none'; }}
                          />
                        </div>
                      );
                    })()}
                    {/* meta */}
                    <div className="flex-1 min-w-0">
                      <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55 truncate">
                        {p.brand}{p.line && p.line !== p.brand && <span> · {p.line}</span>}
                      </p>
                      <h4 className="mt-1 font-serif text-[14.5px] sm:text-[15.5px] text-ink leading-snug">
                        {p.name}
                      </h4>
                      {p.featureSummary && (
                        <p className="mt-1.5 text-[11.5px] text-charcoal/70 leading-[1.75] line-clamp-2">
                          {p.featureSummary}
                        </p>
                      )}
                      {p.sizeLabels && p.sizeLabels.length > 0 && (
                        <a
                          href={p.productPageUrl || (typeof SHOP_URL !== 'undefined' ? SHOP_URL : '#')}
                          target="_blank"
                          rel="noopener noreferrer"
                          className="mt-2 inline-flex items-center gap-1.5 font-mono tracking-widest2 text-[9.5px] uppercase text-ink hover:text-gold no-print transition-colors"
                        >
                          <span className="text-gold">¥</span>
                          <span>SEAM Member Price</span>
                          <span className="text-gold">↗</span>
                        </a>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  );
}

/* ---------- DeepProductSection — Mode B のタグマッチング商品提案 ---------- */
function DeepProductSection({ deepResult, seamData }) {
  if (!deepResult || !seamData) return null;
  const { blocks, hardRules } = deepResult;
  const totalCount = Object.values(blocks).reduce((acc, arr) => acc + arr.length, 0);
  if (totalCount === 0) return null;

  // ルーティン順: SH → TR → アウトバス → マスク → スカルプ → 仕上げ → サロン
  const orderedBlocks = ['shampoo','treatment','outbath','mask','scalp','finish','salon']
    .map(id => ({ ...(DEEP_CATEGORY_DEFS[id] || BLOCK_DEFS[id] || {}), items: blocks[id] || [] }))
    .filter(b => b.items.length > 0);

  return (
    <section className="mt-12 sm:mt-16 anim-fade-up" style={{ animationDelay:'300ms' }}>
      <div className="flex items-start justify-between flex-wrap gap-3 mb-3">
        <div>
          <p className="font-mono tracking-widest2 text-[11px] uppercase text-gold">— Deep Match</p>
          <p className="mt-3 text-[12.5px] sm:text-[13px] text-charcoal/65 leading-snug">診断から導き出した</p>
          <h2 className="mt-1.5 font-serif text-2xl sm:text-3xl text-ink leading-snug">
            あなただけのケア処方
          </h2>
        </div>
        <span className="font-mono tracking-widest2 text-[10px] uppercase text-charcoal/55 pt-1">
          {totalCount} item{totalCount > 1 ? 's' : ''}
        </span>
      </div>

      {/* さりげない安心感バッジ — 全製品がSEAMで揃う */}
      <div className="mt-3 inline-flex items-center gap-1.5 font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55">
        <span className="w-1 h-1 rounded-full bg-gold" />
        <span>All available at SEAM</span>
      </div>

      {hardRules.length > 0 && (
        <div className="mt-5 border-l-2 border-gold pl-4 sm:pl-5 py-1">
          <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-gold">— なぜこの処方か</p>
          <ul className="mt-2 space-y-1 text-[12.5px] text-charcoal/85 leading-[1.85]">
            {hardRules.map((r, i) => <li key={i}>・{r.message}</li>)}
          </ul>
        </div>
      )}

      <div className="mt-7 space-y-8 sm:space-y-10">
        {orderedBlocks.map(block => (
          <div key={block.id}>
            <header className="flex items-center gap-3 pb-2 border-b border-line">
              <span className="font-mono tracking-widest2 text-[10px] uppercase text-ink nums bg-cream px-2 py-0.5">{block.eyebrow}</span>
              <h3 className="font-serif text-[18px] sm:text-[20px] text-ink leading-snug">{block.title}</h3>
              <span className="h-px flex-1 bg-line" />
              <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/45 nums">{block.items.length} item{block.items.length > 1 ? 's' : ''}</span>
            </header>
            <p className="mt-2 text-[12px] text-charcoal/60 leading-relaxed">{block.desc}</p>

            <div className="mt-4 grid sm:grid-cols-2 gap-3">
              {block.items.map(({ p, s }) => (
                <article key={p.id} className="bg-white border border-line p-5 rounded-[2px] flex flex-col h-full relative">
                  <header className="pb-2.5 border-b border-line">
                    <div className="flex items-center justify-between gap-2 flex-wrap">
                      <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-gold whitespace-nowrap">{(p.category || '').replace(/-/g,' ')}</span>
                      {p.routineStep && (
                        <span className="font-mono tracking-widest2 text-[9px] uppercase text-charcoal/55 nums whitespace-nowrap">Step {String(p.routineStep).padStart(2,'0')}</span>
                      )}
                    </div>
                  </header>
                  {/* ── 商品画像 (詰め替えは弾く) ── */}
                  {(() => {
                    const src = (p.image || p.imageUrl);
                    if (!src || isRefillImage(src)) return null;
                    return (
                      <div className="mt-3 flex justify-center bg-white">
                        <img
                          src={src}
                          alt={p.name}
                          loading="lazy"
                          className="h-32 sm:h-36 w-auto max-w-full object-contain"
                          onError={(e) => { e.target.style.display = 'none'; }}
                        />
                      </div>
                    );
                  })()}
                  <div className="mt-3">
                    <p className="font-mono tracking-widest2 text-[10px] uppercase text-charcoal/55">
                      {p.brand}{p.line && p.line !== p.brand && <span> · {p.line}</span>}
                    </p>
                    <h4 className="mt-1 font-serif text-[16.5px] text-ink leading-snug">{p.name}</h4>
                  </div>
                  <p className="mt-3 text-[12.5px] leading-[1.85] text-charcoal/80 flex-1">{p.featureSummary || p.cardCopy}</p>
                  {(() => {
                    const chips = getProductChips(p, 4);
                    return chips.length > 0 && (
                      <div className="mt-2.5 flex flex-wrap gap-1">
                        {chips.map((c, i) => (
                          <span key={i} className="text-[10.5px] px-2 py-0.5 bg-cream/60 text-charcoal/75 border border-gold/25 rounded-[1px] whitespace-nowrap" style={{ letterSpacing: '0.02em' }}>{c}</span>
                        ))}
                      </div>
                    );
                  })()}
                  {p.recommendedFor && (
                    <p className="mt-2 text-[11.5px] text-charcoal/65 leading-relaxed">
                      <span className="font-mono tracking-widest2 text-[9px] uppercase text-charcoal/45 mr-1.5">For</span>{p.recommendedFor}
                    </p>
                  )}
                  {p.sizeLabels && p.sizeLabels.length > 0 && (
                    <a
                      href={p.productPageUrl || SHOP_URL}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${p.name}を公式サイトで見る (新規タブで開く)`}
                      className="mt-4 group block border border-gold/40 bg-white rounded-[2px] overflow-hidden hover:border-gold active:scale-[0.99] transition-all no-print"
                    >
                      <div className="px-3.5 pt-2.5 pb-2 flex items-center justify-between gap-3 flex-wrap bg-gradient-to-r from-cream/35 via-white to-cream/35">
                        <div className="flex items-center gap-2">
                          <span className="font-serif text-[17px] text-gold leading-none">¥</span>
                          <span className="font-mono tracking-widest2 text-[10px] uppercase text-gold whitespace-nowrap">Member Price</span>
                        </div>
                        <span className="font-mono tracking-widest2 text-[10.5px] uppercase text-ink whitespace-nowrap">{p.sizeLabels.join(' / ')}</span>
                      </div>
                      <div className="border-t border-gold/15 px-3.5 py-2.5 flex items-center justify-between gap-2 min-h-[44px]">
                        <span className="font-mono tracking-widest2 text-[10.5px] uppercase text-ink group-hover:text-gold transition-colors">公式サイトで見る</span>
                        <span className="text-gold group-hover:translate-x-1 transition-transform text-[14px] leading-none" aria-hidden>↗</span>
                      </div>
                    </a>
                  )}
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  );
}

/* ---------- カルテ保存/共有 ---------- */
// PDFファイル名: SEAM_HAIR_FINDER_KARTE_YYYY-MM-DD.pdf
// ブラウザの印刷ダイアログを利用して、iOS/Android/PC全てで「保存・共有」を提供する。
//   - iOS Safari: 印刷プレビュー → 共有シート（AirDrop / ファイル / LINE 等）
//   - Android Chrome: 印刷プレビュー → "PDF として保存" → 共有
//   - PC: 印刷ダイアログから "PDF として保存"
function saveOrShareKarte() {
  const date = new Date().toISOString().slice(0,10);
  const filename = `SEAM_HAIR_FINDER_KARTE_${date}`;
  const originalTitle = document.title;
  document.title = filename;
  setTimeout(() => {
    window.print();
    setTimeout(() => { document.title = originalTitle; }, 800);
  }, 10);
}

// Web Share API が使える端末ではURL共有のオプションも提供（補助的）
function buildChart(scores, answers) {
  const items = answers.items || [];
  const moistureUsage = items.includes('mask') || items.includes('milk') || items.includes('treatment');

  return {
    '水分不足':     clamp(scores.dryness, 5),
    '内部補修不足': clamp(scores.damage + (moistureUsage ? 0 : 1), 5),
    '熱ダメージ':   clamp(scores.heatDamage, 5),
    '毛先履歴':     clamp(scores.bleachHistory * 0.7 + scores.longHairHistory, 5),
    '頭皮環境':     clamp(scores.scalpDryness + scores.scalpOiliness, 5),
    'ボリューム':   clamp(scores.volumeLoss + scores.aging * 0.5, 5),
    'うねり':       clamp(scores.frizz, 5),
    'ツヤ':         clamp(scores.dryness * 0.5 + scores.damage * 0.5 + scores.colorFade * 0.5, 5),
  };
}

/* =========================================================================
   UI Components
   ========================================================================= */

function TopBar({ step, total }) {
  return (
    <header className="absolute top-0 inset-x-0 z-20">
      <div className="mx-auto max-w-3xl px-5 sm:px-8 py-5 flex items-center justify-between">
        <a href="index.html" className="font-display tracking-widest2 text-[13px] sm:text-sm text-ink/90">
          SEAM
        </a>
        {step != null ? (
          <div className="flex items-center gap-3 text-[11px] sm:text-xs tracking-widest2 text-charcoal/70 nums uppercase">
            <span>Hair Finder</span>
            <span className="text-charcoal/30">/</span>
            <span><span className="text-ink">{String(step).padStart(2,'0')}</span> <span className="text-charcoal/40">— {String(total).padStart(2,'0')}</span></span>
          </div>
        ) : (
          <span className="text-[11px] sm:text-xs tracking-widest2 uppercase text-charcoal/60">Hair Finder</span>
        )}
      </div>
    </header>
  );
}

/* ---------- Home ---------- */
