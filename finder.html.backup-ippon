                <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/45 nums">
                  {lastKarte.savedAt ? lastKarte.savedAt.slice(0,10) : ''}
                </span>
              </header>
              <p className="mt-3 text-[12.5px] text-charcoal/70 leading-[1.85]">
