/* ---------- タイプ別ルーティン ---------- */
/* ---------- 髪質チャート ---------- */
function clamp(v, max) { return Math.max(0, Math.min(max, Math.round(v))); }
function levelLabel(v) { return v <= 1 ? 'Keep' : v <= 3 ? 'Care' : 'Intensive Care'; }

/* ---------- Aujua マッチング（タグベース推薦） ---------- */
const CONCERN_TO_TAG = {
  dry:'dry', frizz:'frizz', wave:'wave', rough:'rough', tangle:'tangle',
  noShine:'no-shine', split:'split', damage:'damage',
  colorFade:'color-fade', grayFade:'gray-fade',
  volumeDown:'volume-down', topFlat:'top-flat',
  scalpDry:'scalp-dry', scalpOily:'scalp-oily', thinning:'thinning',
};
// 同じ悩みでも 新schema では別タグ名で表現されるので、複数タグ候補で照合
const CONCERN_TO_TAGS = {
  dry:        ['dry'],
  frizz:      ['frizz', 'spread', 'humidity', 'no-smooth', 'unruly'],
  wave:       ['wave', 'frizz', 'unruly', 'humidity', 'curl-define'],
  rough:      ['no-shine', 'damage', 'dry', 'split'],
  tangle:     ['tangle'],
  noShine:    ['no-shine', 'damage'],
  split:      ['split', 'breakage'],
  damage:     ['damage', 'multi-bleach', 'bleach-damage', 'breakage', 'no-elasticity', 'heat-damage'],
  colorFade:  ['color-fade', 'multi-bleach'],
  grayFade:   ['gray-fade', 'color-fade'],
  volumeDown: ['volume-down', 'no-volume', 'flat', 'thin-hair', 'fine-hair', 'no-firmness'],
  topFlat:    ['top-flat', 'flat', 'no-volume', 'thin-hair', 'fine-hair'],
  scalpDry:   ['scalp-dry', 'scalp-sensitive'],
  scalpOily:  ['scalp-oily', 'buildup', 'scalp-odor', 'dandruff'],
  thinning:   ['thinning', 'hairloss', 'thin-hair', 'fine-hair', 'no-firmness', 'no-volume'],
};
function concernMatches(c, productConcernTags) {
  const tags = CONCERN_TO_TAGS[c] || (CONCERN_TO_TAG[c] ? [CONCERN_TO_TAG[c]] : []);
  for (const t of tags) {
    if (productConcernTags.includes(t)) return true;
  }
  return false;
}
// 並び順スコア: タグが先頭に近いほど "そのラインの主要悩み" として強くマッチング
function concernPositionBoost(c, productConcernTags) {
  const tags = CONCERN_TO_TAGS[c] || (CONCERN_TO_TAG[c] ? [CONCERN_TO_TAG[c]] : []);
  let bestIdx = -1;
  for (const t of tags) {
    const idx = productConcernTags.indexOf(t);
    if (idx !== -1 && (bestIdx === -1 || idx < bestIdx)) bestIdx = idx;
  }
  if (bestIdx === -1) return 0;
  // 先頭(idx=0) → +15, 2番目 → +12, 3番目 → +9, 4番目 → +6, 5番目以降 → +3
  return [15, 12, 9, 6, 3][Math.min(bestIdx, 4)] || 3;
}
const ENV_TO_TAG = { humid:'humid-climate', dry:'dry-climate', sun:'sun-exposure', indoor:'indoor' };

/* ──────────────────────────────────────────
   FUNCTION_TAG_JP — 商品の functionTags を日本語ラベルに変換
   一目で特性が分かるよう、化粧品の効能訴求表現に準拠
   ────────────────────────────────────────── */
