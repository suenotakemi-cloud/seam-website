            <span className="font-mono tracking-widest2 text-[10px] text-charcoal/45 ml-2">{list.length} types</span>
          </p>
        </div>

        {/* ── タイプカードグリッド ── */}
        {onPickAsMine && (
          <div className="mt-8 anim-fade-up bg-cream/60 border-l-2 border-gold p-4 sm:p-5 rounded-[2px]">
            <p className="font-mono tracking-widest2 text-[10px] uppercase text-gold mb-2">— Pick your type</p>
            <p className="text-[13.5px] sm:text-[14px] text-charcoal/85 leading-[1.9]">
              ご自分のタイプがすでにわかっている方は、下のカードから <span className="text-ink">「私はこのタイプ →」</span> を選ぶと、髪の現状と履歴だけを入力する短い診断に進めます。
            </p>
          </div>
        )}
        <div className="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
          {list.map((animal, i) => (
            <div key={animal.id} className="anim-fade-up" style={{ animationDelay: `${Math.min(i * 30, 240)}ms` }}>
              <KarteCollectionCard
                animal={animal}
                isMine={animal.id === myId}
                onOpen={() => setOpen(animal)}
                onPick={onPickAsMine ? () => onPickAsMine(animal) : undefined}
              />
            </div>
          ))}
        </div>

        {/* ── 振り返り/CTA ── */}
        <div className="mt-14 sm:mt-16 anim-fade-up text-center max-w-xl mx-auto">
          <p className="font-serif text-[15px] sm:text-[16px] text-ink leading-[1.95]">
            それぞれの髪に、それぞれの良さがあります。<br />
            あなたの「いま」と「これから」を、見つけるきっかけに。
          </p>
          <div className="mt-7 flex flex-wrap items-center justify-center gap-3">
            {!myKarte && (
              <a href="finder.html" className="inline-flex items-center gap-2 bg-ink text-ivory px-5 py-3 rounded-[1px] hover:bg-charcoal transition-colors font-mono tracking-widest2 text-[10.5px] uppercase">
                自分のタイプを診断
              </a>
            )}
            <button
              type="button"
              onClick={onBackHome}
              className="font-mono tracking-widest2 text-[10.5px] uppercase text-charcoal/65 hover:text-ink transition-colors inline-flex items-center gap-2"
            >
              <span className="inline-block w-5 h-px bg-charcoal/40" />
              ホームへ戻る
            </button>
          </div>
        </div>
      </main>

      <KarteCollectionDetail animal={open} isMine={open?.id === myId} onClose={() => setOpen(null)} />
    </div>
  );
}

// ── 縮毛矯正ユーザー向け動的コピー差し替え
// answers.straighten が 'none'/'past' 以外、または answers.wave === 'straightened' の場合、
// MWA/AWP/SCA(波・くせ系キャラ)のコピーを「ストレートに整えた今のあなた」向けに調整。
function isCurrentlyStraightened(answers) {
  if (!answers) return false;
  const st = answers.straighten;
  const wave = answers.wave;
  const activeStraightening = st && st !== 'none' && st !== 'past';
  return activeStraightening || wave === 'straightened';
}

function adaptOriginForStraightening(origin, answers) {
  if (!origin || !origin.code) return origin;
  if (!isCurrentlyStraightened(answers)) return origin;
  const waveCodes = ['MWA', 'AWP', 'SCA'];
  if (!waveCodes.includes(origin.code)) return origin;

  // 各波系キャラに対する「ストレート派」用のオーバーライド
  const overrides = {
    MWA: {
      personality: '本来は独特な揺らぎを宿す髪。今は薬剤の力でまっすぐに整えていますが、その内側には誰にもまねできない繊細さと表情が眠っています。仕上げ方を自由に選べる、稀有なタイプ。',
      charmHint: '整えるほどに艶を纏う、深い静けさ。',
      dailyMood: 'ストレートが綺麗にキープできた日の、自分への小さな拍手。',
      suitableStyles: ['つややかなストレートロング', '繊細レイヤーミディアム', 'シャープなボブ', '上品なまとめ髪'],
    },
    AWP: {
      personality: 'もとは軽やかなくせを抱える髪。今はまっすぐに整え、ふんわりとした繊細さだけが残るようにケアされています。素材の繊細さは、ストレートでも品となって滲み出ます。',
      charmHint: '春風そのもののような、軽やかな艶。',
      dailyMood: 'ふんわりとしたシルエットが、いちばん上手く決まった朝。',
      suitableStyles: ['ふんわりストレートボブ', '前髪パーマでメリハリ', 'シースルーバング', '繊細なレイヤーミディアム'],
    },
    SCA: {
      personality: '光の角度で表情が変わるアレキサンドライトのような髪。今はストレートに整えることで、本来の艶と流れがより上品に際立つようになっています。',
      charmHint: '光で深みを変える、変化の宝石。',
      dailyMood: '艶やかにまっすぐ流れる髪を、ふと鏡で確認したくなる日。',
      suitableStyles: ['ストレートロング', '上品なシャープボブ', '艶感のあるミディアム', 'なめらかなまとめ髪'],
    },
  };
  const ov = overrides[origin.code];
  return ov ? { ...origin, ...ov } : origin;
}

/* ──────────────────────────────────────────
   VisitSeamSection — Apple新製品ページ風 minimal & exciting
   - 大胆な1行ステートメント
   - 3つの体験ブロック（スクロールトリガーで滑らかにフェードイン）
   - 単一の主役CTA
   ────────────────────────────────────────── */
function useScrollReveal() {
  const ref = useRef(null);
  const [shown, setShown] = useState(false);
  useEffect(() => {
    if (!ref.current || !('IntersectionObserver' in window)) { setShown(true); return; }
    const obs = new IntersectionObserver(
      ([entry]) => { if (entry.isIntersecting) { setShown(true); obs.disconnect(); } },
      { rootMargin: '0px 0px -15% 0px', threshold: 0.08 }
    );
    obs.observe(ref.current);
    return () => obs.disconnect();
  }, []);
  return [ref, shown];
}

function VisitReveal({ children, delay = 0, direction = 'up' }) {
  const [ref, shown] = useScrollReveal();
  const dy = direction === 'up' ? 28 : -16;
  return (
    <div
      ref={ref}
      style={{
        opacity: shown ? 1 : 0,
        transform: shown ? 'translateY(0) scale(1)' : `translateY(${dy}px) scale(0.985)`,
        transition: `opacity 0.9s cubic-bezier(0.16,1,0.3,1) ${delay}ms, transform 1s cubic-bezier(0.16,1,0.3,1) ${delay}ms`,
        willChange: 'opacity, transform',
      }}
    >
      {children}
    </div>
  );
}

function VisitSeamSection({ saveOrShareKarte }) {
  const blocks = [
    {
      num: '01',
      eyebrow: 'Try in Person',
      title: '実際に、手に取れる。',
      body: 'カルテに合うシャンプー、トリートメント、オイル ─ サンプルで肌に乗せて、香りを確かめて、本当に合う一本を選びます。',
      illust: 'サロン店内 / 商品棚と光のイメージ',
    },
    {
      num: '02',
      eyebrow: 'Talk with Stylist',
      title: '美容師が、隣に座る。',
      body: 'カルテをそのまま見せれば、診断結果を踏まえてあなたの髪を直接拝見し、いまベストな処方をご提案します。',
      illust: 'カウンセリング中のシーン / 髪を見る手元',
    },
    {
      num: '03',
      eyebrow: 'Continue with Care',
      title: 'ずっと、続けられる。',
      body: '店頭でメンバー登録後は、オンラインで24時間ご注文・定期配送。来店ごとにカルテが育ち、季節に合わせて処方を微調整します。',
      illust: 'スマホでオンライン購入 / カルテ更新のシーン',
    },
  ];

  return (
    <section
      id="visit-seam"
      className="-mx-5 sm:-mx-8 px-5 sm:px-8 py-24 sm:py-36 mt-12 sm:mt-16 scroll-mt-[96px] overflow-hidden relative"
      style={{
        background: 'linear-gradient(180deg, #FBF8F2 0%, #F4ECDA 100%)',
      }}
    >
      {/* 装飾: ゴールドの淡い光が動く背景 */}
      <div aria-hidden className="absolute inset-0 pointer-events-none visit-glow" style={{
        background: 'radial-gradient(50% 35% at 50% 25%, rgba(184,148,90,0.20), transparent 70%)'
      }} />

      <div className="relative max-w-3xl mx-auto">
        {/* HERO Statement */}
        <VisitReveal>
          <div className="text-center">
            <p className="font-mono tracking-widest3 text-[10.5px] uppercase text-gold mb-4" style={{ letterSpacing: '0.32em' }}>— Visit SEAM</p>
            <h2
              className="font-serif text-ink leading-[1.18]"
              style={{
                fontSize: 'clamp(28px, 5.4vw, 52px)',
                letterSpacing: '-0.018em',
                fontWeight: 600,
                wordBreak: 'keep-all',
                overflowWrap: 'break-word',
              }}
            >
              <span style={{ display: 'inline-block' }}>カルテができたら、</span><br />
              <span className="text-gold" style={{ display: 'inline-block' }}>あとは、店に行くだけ。</span>
            </h2>
            <span aria-hidden className="block w-12 h-px bg-gold/55 mx-auto mt-7" />
            <p className="mt-6 text-[14.5px] sm:text-[16px] leading-[2] text-charcoal/80 max-w-md mx-auto">
              プロが、あなたの髪を直接見ます。<br />
              診断結果を、本当の処方に変える場所。
            </p>
          </div>
        </VisitReveal>

        {/* 3 Feature Blocks */}
        <div className="mt-24 sm:mt-32 space-y-24 sm:space-y-36">
          {blocks.map((b, i) => {
            const reverse = i % 2 === 1;
            const Placeholder = (
              <div
                className="relative w-full"
                style={{
                  aspectRatio: '4/3',
                  background: 'linear-gradient(160deg, #FFFFFF 0%, #F4ECDA 100%)',
                  borderTop: '1px solid rgba(184,148,90,0.25)',
                  borderBottom: '1px solid rgba(184,148,90,0.25)',
                }}
              >
                <span aria-hidden className="absolute top-2 left-2 w-2.5 h-2.5 border-t border-l border-gold/40" />
                <span aria-hidden className="absolute top-2 right-2 w-2.5 h-2.5 border-t border-r border-gold/40" />
                <span aria-hidden className="absolute bottom-2 left-2 w-2.5 h-2.5 border-b border-l border-gold/40" />
                <span aria-hidden className="absolute bottom-2 right-2 w-2.5 h-2.5 border-b border-r border-gold/40" />
                <div className="absolute inset-0 flex flex-col items-center justify-center text-center px-6">
                  <span
                    className="font-serif text-gold opacity-30"
                    style={{ fontSize: 'clamp(72px, 12vw, 128px)', lineHeight: 1, fontStyle: 'italic', letterSpacing: '-0.04em' }}
                  >{b.num}</span>
                  <p className="mt-3 font-mono tracking-widest3 text-[9.5px] uppercase text-gold whitespace-nowrap" style={{ letterSpacing: '0.25em' }}>— Illustration —</p>
                  <p className="mt-2 font-serif italic text-[11.5px] sm:text-[12.5px] text-charcoal/55 leading-[1.7] max-w-[80%]" style={{ wordBreak: 'keep-all', overflowWrap: 'break-word' }}>{b.illust}</p>
                </div>
              </div>
            );
            const TextCol = (
              <div>
                <p className="font-mono tracking-widest3 text-[10px] uppercase text-gold mb-3" style={{ letterSpacing: '0.32em' }}>— {b.eyebrow}</p>
                <h3
                  className="font-serif text-ink leading-[1.2]"
                  style={{
                    fontSize: 'clamp(22px, 4vw, 32px)',
                    letterSpacing: '-0.012em',
                    fontWeight: 600,
                    wordBreak: 'keep-all',
                    overflowWrap: 'break-word',
                  }}
                >
                  {b.title}
                </h3>
                <p className="mt-5 text-[14px] sm:text-[15px] leading-[2] text-charcoal/80" style={{ wordBreak: 'keep-all', overflowWrap: 'break-word' }}>
                  {b.body}
                </p>
              </div>
            );
            return (
              <VisitReveal key={b.num} delay={i * 60}>
                <article className="grid sm:grid-cols-2 gap-8 sm:gap-14 items-center">
                  {reverse ? (
                    <>{TextCol}{Placeholder}</>
                  ) : (
                    <>{Placeholder}{TextCol}</>
                  )}
                </article>
              </VisitReveal>
            );
          })}
        </div>

        {/* Primary CTA */}
        <VisitReveal delay={120}>
          <div className="mt-28 sm:mt-36 text-center">
            <p className="font-mono tracking-widest3 text-[10.5px] uppercase text-gold mb-3" style={{ letterSpacing: '0.32em' }}>— Find a Store</p>
            <h3
              className="font-serif text-ink leading-[1.25] mb-7"
              style={{
                fontSize: 'clamp(22px, 4vw, 32px)',
                letterSpacing: '-0.012em',
                fontWeight: 600,
                wordBreak: 'keep-all',
                overflowWrap: 'break-word',
              }}
            >
              <span style={{ display: 'inline-block' }}>全国{typeof SEAM_STORES !== 'undefined' ? SEAM_STORES.length : 7}拠点で、</span>
              <span style={{ display: 'inline-block' }}>お待ちしています。</span>
            </h3>
            <a
              href="#"
              onClick={(e) => { e.preventDefault(); const el = document.getElementById('visit-seam-stores'); if (el) el.scrollIntoView({behavior:'smooth'}); }}
              className="inline-flex items-center gap-3 px-9 py-4 bg-ink text-ivory hover:bg-charcoal transition-all font-serif text-[15px] sm:text-[16px] rounded-full"
              style={{ boxShadow: '0 8px 24px -6px rgba(40,38,36,0.35)' }}
            >
              <span>近くのSEAMを探す</span>
              <span className="text-[14px]">→</span>
            </a>
          </div>
        </VisitReveal>

        {/* Store list — collapsible/inline */}
        <VisitReveal delay={180}>
          <div id="visit-seam-stores" className="mt-24 sm:mt-32 scroll-mt-[96px]">
            <div className="text-center mb-10">
              <p className="font-mono tracking-widest3 text-[10.5px] uppercase text-gold mb-3" style={{ letterSpacing: '0.32em' }}>— Stores</p>
              <h3 className="font-serif text-[22px] sm:text-[28px] text-ink leading-tight" style={{ letterSpacing: '-0.012em', fontWeight: 600 }}>
                SEAM 認定サロン
              </h3>
            </div>
            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
              {(typeof SEAM_STORES !== 'undefined' ? SEAM_STORES : []).map((s, i) => <StoreCard key={s.id} store={s} index={i} />)}
            </div>
          </div>
        </VisitReveal>
      </div>
    </section>
  );
}

/* ──────────────────────────────────────────
   CounselingSheet — 美容師さんと共有するテキストのみのカルテ
   ────────────────────────────────────────── */
const STRAIGHTEN_LABEL = {
  none: 'していない',
  yearly: '年1回程度',
  biannual: '半年に1回',
  quarterly: '3ヶ月に1回',
  frequent: '2ヶ月に1回以上(年6回以上・頻繁)',
  kaizen: '髪質改善・酸性ストレートを定期的に',
  past: '過去にしていた',
};
const PERM_LABEL = {
  none: 'していない', past: '過去にしていた',
  yearly: '年1回程度', biannual: '半年に1回',
  quarterly: '3ヶ月に1回', frequent: '頻繁(年5回以上)',
};
const COLOR_LABEL = {
  none: 'していない',
  retouch_6w: '根元リタッチを1〜2ヶ月ごと',
  retouch_2m: '根元リタッチを2〜3ヶ月ごと',
  full_3m: '全頭カラーを3ヶ月ごと',
  full_6m: '全頭カラーを半年に1回',
  highlight: 'ハイライト/ローライト',
};
const BLEACH_LABEL = {
  none: 'していない', past: '過去にしていた',
  single: 'シングルカラー', double: 'ダブルカラー以上',
  retouch: 'リタッチでブリーチを継続',
};
const WAVE_LABEL = {
  none: 'ストレート', wave: 'ゆるい波・くせ', curly: 'くせ強め',
  straightened: '縮毛矯正で整えている',
  surface: '表面に出るくせ', humid: '湿気でうねりやすい',
  partial: '部分的なくせ', overall: '全体的にくせあり',
};
const CS_THICKNESS_LABEL = { thin: '細め', normal: '普通', thick: '太め' };
const CS_AMOUNT_LABEL = { few: '少なめ', normal: '普通', many: '多め' };
const CS_LENGTH_LABEL = {
  short: 'ショート', bob: 'ボブ', shoulderUp: '肩上',
  shoulderDown: '肩下', chestUp: '胸上', long: 'ロング',
};
const CS_TEMP_LABEL = { t150: '〜150℃', t180: '180℃', t200: '200℃以上' };
const CS_TOOL_LABEL = {
  iron: 'ストレートアイロン', curler: 'カールアイロン',
  bangs: '前髪アイロン', dryer: 'ドライヤー',
};

function CounselingSheet({ karte, answers, onSaveImage }) {
  const o = karte?.origin;
  if (!o) return null;
  const typeShort = (typeof TYPE_SHORT_NAME !== 'undefined') ? TYPE_SHORT_NAME[o.code] : null;
  const a = answers || {};

  const today = new Date();
  const todayStr = `${today.getFullYear()}.${String(today.getMonth()+1).padStart(2,'0')}.${String(today.getDate()).padStart(2,'0')}`;

  /* === 質問定義から値→ラベルを動的解決するヘルパー === */
  const QL = (typeof QUESTION_LOOKUP !== 'undefined') ? QUESTION_LOOKUP : {};
  const lookupLabel = (qid, value) => {
    if (value === undefined || value === null || value === '') return null;
    const q = QL[qid];
    if (!q || !q.options) return String(value);
    const opt = q.options.find(o => o.v === value);
    if (!opt) return String(value);
    // sub があれば併記(美容師さんに正確に伝わるため)
    return opt.sub ? `${opt.label}（${opt.sub}）` : opt.label;
  };
  const lookupLabelShort = (qid, value) => {
    if (value === undefined || value === null || value === '') return null;
    const q = QL[qid];
    if (!q || !q.options) return String(value);
    const opt = q.options.find(o => o.v === value);
    return opt ? opt.label : String(value);
  };
  const lookupMulti = (qid, values) => {
    if (!Array.isArray(values) || values.length === 0) return null;
    return values.map(v => lookupLabelShort(qid, v) || v).join('・');
  };

  /* === 各セクションのデータ === */
  // 基本情報 (年代・性別・長さ)
  const basicItems = [];
  if (a.age && a.age !== 'noanswer') basicItems.push(['年代', lookupLabelShort('age', a.age)]);
  if (a.gender && a.gender !== 'noanswer') basicItems.push(['性別', lookupLabelShort('gender', a.gender)]);
  if (a.length) basicItems.push(['長さ', lookupLabelShort('length', a.length)]);

  // 髪質
  const traitItems = [];
  if (a.thickness) traitItems.push(['髪の細さ', lookupLabelShort('thickness', a.thickness)]);
  if (a.density) traitItems.push(['髪の量・密度', lookupLabelShort('density', a.density)]);
  if (a.rootVolume) traitItems.push(['根元の立ち上がり', lookupLabel('rootVolume', a.rootVolume)]);
  if (a.wave) traitItems.push(['くせ・うねり', lookupLabelShort('wave', a.wave)]);

  // 頭皮
  const scalpItems = [];
  if (a.scalpType) scalpItems.push(['頭皮の状態', lookupLabel('scalpType', a.scalpType)]);
  if (a.scalpSensitivity) scalpItems.push(['頭皮の敏感さ', lookupLabel('scalpSensitivity', a.scalpSensitivity)]);
  if (a.scalpAllergy) scalpItems.push(['アレルギー・薬剤反応', lookupLabel('scalpAllergy', a.scalpAllergy)]);

  // カラー履歴
  const colorItems = [];
  if (a.color) colorItems.push(['カラー履歴', lookupLabelShort('color', a.color)]);
  if (a.colorFreq) colorItems.push(['カラーの頻度', lookupLabel('colorFreq', a.colorFreq)]);
  if (a.grayHair) colorItems.push(['白髪染め', lookupLabel('grayHair', a.grayHair)]);
  if (a.grayFreq) colorItems.push(['白髪染めの頻度', lookupLabelShort('grayFreq', a.grayFreq)]);
  if (a.bleachLocation) colorItems.push(['ブリーチ残存箇所', lookupLabel('bleachLocation', a.bleachLocation)]);

  // パーマ・矯正履歴
  const permItems = [];
  if (a.straighten) permItems.push(['縮毛矯正', lookupLabelShort('straighten', a.straighten)]);
  if (a.perm) permItems.push(['パーマ', lookupLabelShort('perm', a.perm)]);
  if (a.permType) permItems.push(['パーマの種類', lookupLabel('permType', a.permType)]);
  if (a.permLoose) permItems.push(['パーマの保ち', lookupLabel('permLoose', a.permLoose)]);

  // 熱ツール使用
  const heatItems = [];
  const tools = (a.styling && a.styling.tools) || [];
  if (tools.length) {
    const toolNames = tools.map(t => {
      const q = QL.styling;
      const opt = q && q.toolOptions && q.toolOptions.find(o => o.v === t);
      return opt ? opt.label : t;
    }).join(' / ');
    heatItems.push(['熱ツールの使い方', toolNames]);
  }
  if (a.styling && a.styling.temp) {
    const q = QL.styling;
    const opt = q && q.tempOptions && q.tempOptions.find(o => o.v === a.styling.temp);
    if (opt) heatItems.push(['アイロン温度', opt.detail ? `${opt.label}（${opt.detail}）` : opt.label]);
  }
  if (Array.isArray(a.heatProtect) && a.heatProtect.length) {
    heatItems.push(['熱保護アイテム', lookupMulti('heatProtect', a.heatProtect)]);
  }

  // 過去のヘアトラブル
  const troubleList = (Array.isArray(a.hairTrouble) ? a.hairTrouble : [])
    .filter(v => v !== 'none')
    .map(v => lookupLabel('hairTrouble', v))
    .filter(Boolean);

  // ホームケア・ライフスタイル
  const lifeItems = [];
  if (Array.isArray(a.items) && a.items.length) {
    lifeItems.push(['日常のヘアケア', lookupMulti('items', a.items)]);
  }
  if (Array.isArray(a.lifestyle) && a.lifestyle.length) {
    lifeItems.push(['ライフスタイル', lookupMulti('lifestyle', a.lifestyle)]);
  }
  if (a.environment) lifeItems.push(['過ごす環境', lookupLabel('environment', a.environment)]);
  if (Array.isArray(a.concernsItem) && a.concernsItem.length) {
    const filtered = a.concernsItem.filter(v => v !== 'none');
    if (filtered.length) lifeItems.push(['アイテムで気になる点', filtered.map(v => lookupLabelShort('concernsItem', v)).join('・')]);
  }

  // 悩み
  const concernList = (Array.isArray(a.concerns) ? a.concerns : [])
    .map(c => lookupLabelShort('concerns', c))
    .filter(Boolean);

  // 希望
  const wishItems = [];
  if (a.goalTexture) wishItems.push(['理想の質感', lookupLabelShort('goalTexture', a.goalTexture)]);
  if (a.goal) wishItems.push(['髪の目標', lookupLabelShort('goal', a.goal)]);

  // ヘッドスパ
  const spaItems = [];
  if (a.headSpaInterest) spaItems.push(['ヘッドスパ', lookupLabelShort('headSpaInterest', a.headSpaInterest)]);
  if (Array.isArray(a.wellness) && a.wellness.length) {
    const filtered = a.wellness.filter(v => v !== 'well');
    if (filtered.length) spaItems.push(['気になる症状', filtered.map(v => lookupLabelShort('wellness', v)).join('・')]);
  }

  // 希望(タイプ別目指す姿)
  const idealImpression = karte?.mainGoal?.tagline || karte?.mainGoal?.name || '本来の質感を活かしたい';

  const sectionTitle = (label) => (
    <p className="font-mono tracking-widest3 text-[10px] uppercase text-gold mt-8 mb-3" style={{ letterSpacing: '0.25em' }}>— {label}</p>
  );
  const dl = (items) => (
    <dl className="space-y-2.5">
      {items.map(([k, v], i) => (
        <div key={i} className="grid grid-cols-[110px_1fr] sm:grid-cols-[130px_1fr] gap-3 items-baseline">
          <dt className="font-serif text-[12px] sm:text-[12.5px] text-charcoal/60 leading-[1.65]" style={{ wordBreak: 'keep-all' }}>{k}</dt>
          <dd className="font-serif text-[13.5px] sm:text-[14.5px] text-ink leading-[1.8]" style={{ fontWeight: 500, wordBreak: 'keep-all', overflowWrap: 'break-word' }}>{v || '—'}</dd>
        </div>
      ))}
    </dl>
  );
  const chips = (arr) => (
    <p className="font-serif text-[13.5px] sm:text-[14.5px] text-ink leading-[2]" style={{ fontWeight: 500, wordBreak: 'keep-all', overflowWrap: 'break-word' }}>
      {arr.join('・')}
    </p>
  );

  return (
    <section className="-mx-5 sm:-mx-8 px-5 sm:px-8 py-16 sm:py-20 bg-white mt-12 sm:mt-16 anim-fade-up scroll-mt-[96px]" id="section-memo">
      <div className="flex items-center gap-3 mb-3">
        <span className="font-mono tracking-widest2 text-[11px] uppercase text-gold nums">— Counseling Sheet</span>
        <span className="h-px flex-1 bg-gold/40" />
      </div>
      <h2 className="font-serif text-[28px] sm:text-[40px] leading-[1.2] text-ink" style={{ wordBreak:'keep-all', overflowWrap:'break-word' }}>
        カルテが、<br />
        <span className="text-gold">作成されました。</span>
      </h2>
      <span aria-hidden className="block w-20 h-px bg-gold/55 mt-5" />
      <p className="mt-5 text-[13px] sm:text-[14px] leading-[1.95] text-charcoal/75 max-w-2xl">
        あなたの診断結果と回答を、美容師さんがそのまま受け取れる形にまとめました。<br />
        来店時にこのページを開いて、見せるだけで伝わります。
      </p>

      {/* カルテ本体 (テキストのみ) */}
      <article
        id="counseling-sheet"
        className="relative mt-9 mx-auto max-w-2xl bg-white p-7 sm:p-12"
        style={{
          borderTop: '1px solid rgba(184,148,90,0.4)',
          borderBottom: '1px solid rgba(184,148,90,0.4)',
          boxShadow: '0 1px 2px rgba(26,24,21,0.04), 0 18px 50px -28px rgba(26,24,21,0.18)',
        }}
      >
        {/* corner ornaments */}
        <span aria-hidden className="absolute top-2 left-2 w-3 h-3 border-t border-l border-gold/55" />
        <span aria-hidden className="absolute top-2 right-2 w-3 h-3 border-t border-r border-gold/55" />
        <span aria-hidden className="absolute bottom-2 left-2 w-3 h-3 border-b border-l border-gold/55" />
        <span aria-hidden className="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-gold/55" />

        {/* Header */}
        <div className="flex items-center justify-between pb-4 border-b border-gold/25 text-[10px] font-mono tracking-widest2 uppercase">
          <span className="text-gold">SEAM Hair Karte</span>
          <span className="text-charcoal/55 nums">{todayStr}</span>
        </div>

        {/* 01 タイプ */}
        {sectionTitle('01 · あなたのタイプ')}
        <div>
          <h3 className="font-serif text-[20px] sm:text-[22px] text-ink leading-[1.35]">{o.name}</h3>
          <p className="mt-1 font-mono tracking-widest2 text-[10.5px] uppercase text-charcoal/55 nums">{o.nameEn} <span className="text-gold">· {o.code}</span></p>
          {typeShort && (
            <p className="mt-2 text-[13px] sm:text-[13.5px] text-charcoal/75">— {typeShort.jp}</p>
          )}
        </div>

        {/* 02 基本情報 */}
        {basicItems.length > 0 && (
          <>
            {sectionTitle('02 · 基本情報')}
            {dl(basicItems)}
          </>
        )}

        {/* 03 髪質の特徴 */}
        {traitItems.length > 0 && (
          <>
            {sectionTitle('03 · 髪質の特徴')}
            {dl(traitItems)}
          </>
        )}

        {/* 04 頭皮の状態 */}
        {scalpItems.length > 0 && (
          <>
            {sectionTitle('04 · 頭皮の状態')}
            {dl(scalpItems)}
          </>
        )}

        {/* 05 髪のキャラクター(性格) */}
        {o.personality && (
          <>
            {sectionTitle('05 · 髪のキャラクター')}
            <p className="font-serif text-[13.5px] sm:text-[14.5px] leading-[2] text-charcoal/85" style={{ letterSpacing: '0.02em' }}>
              {o.personality}
            </p>
          </>
        )}

        {/* 06 カラー履歴 */}
        {colorItems.length > 0 && (
          <>
            {sectionTitle('06 · カラー履歴')}
            {dl(colorItems)}
          </>
        )}

        {/* 07 縮毛矯正・パーマ履歴 */}
        {permItems.length > 0 && (
          <>
            {sectionTitle('07 · 縮毛矯正・パーマ履歴')}
            {dl(permItems)}
          </>
        )}

        {/* 08 熱ツールの使い方 */}
        {heatItems.length > 0 && (
          <>
            {sectionTitle('08 · 熱ツールの使い方')}
            {dl(heatItems)}
          </>
        )}

        {/* 09 過去のヘアトラブル */}
        {troubleList.length > 0 && (
          <>
            {sectionTitle('09 · 過去のヘアトラブル')}
            {chips(troubleList)}
          </>
        )}

        {/* 10 ホームケア・ライフスタイル */}
        {lifeItems.length > 0 && (
          <>
            {sectionTitle('10 · ホームケア・ライフスタイル')}
            {dl(lifeItems)}
          </>
        )}

        {/* 11 気になっていること */}
        {concernList.length > 0 && (
          <>
            {sectionTitle('11 · 気になっていること')}
            {chips(concernList)}
          </>
        )}

        {/* 12 これからの希望 */}
        {sectionTitle('12 · これからの希望')}
        {wishItems.length > 0 && dl(wishItems)}
        <p className="mt-3 font-serif text-[13.5px] sm:text-[14.5px] text-ink leading-[1.95]" style={{ fontWeight: 500 }}>
          目指す姿　<span className="text-gold">{idealImpression}</span>
        </p>
        {o.tenderAdvice && (
          <p className="mt-4 text-[12.5px] sm:text-[13px] leading-[1.95] text-charcoal/70" style={{ borderLeft:'2px solid rgba(184,148,90,0.35)', paddingLeft: '12px' }}>
            <span className="font-mono tracking-widest2 text-[9px] uppercase text-gold mr-1.5">Advice</span>
            {(o.tenderAdvice || '').split('\n\n')[0]}
          </p>
        )}

        {/* 13 ヘッドスパのご希望 */}
        {spaItems.length > 0 && (
          <>
            {sectionTitle('13 · ヘッドスパのご希望')}
            {dl(spaItems)}
          </>
        )}

        {/* Footer */}
        <div className="mt-9 pt-5 border-t border-gold/25 text-center">
          <p className="font-serif italic text-[12.5px] sm:text-[13px] text-charcoal/75 leading-[1.85]">
            この髪を、一緒に考えていただけたら嬉しいです。
          </p>
        </div>
      </article>

      {/* 共有可能な案内 + 保存ボタン */}
      <div className="mt-8 text-center">
        <p className="font-mono tracking-widest2 text-[11px] uppercase text-gold mb-1">— For Sharing</p>
        <p className="font-serif text-[14px] sm:text-[15px] text-ink leading-[1.85]">
          このカルテは、<span className="text-gold">美容師さんにも共有できます</span>。
        </p>
        <p className="mt-2 text-[11.5px] sm:text-[12px] text-charcoal/60 leading-[1.9]">
          来店時にこの画面を見せる、画像で保存して LINE で送る、どちらも可能です。
        </p>
      </div>
      <div className="mt-5 no-print flex flex-wrap gap-3 justify-center">
        <button
          type="button"
          onClick={() => onSaveImage && onSaveImage('story')}
          className="inline-flex items-center gap-2 px-6 py-3.5 bg-ink text-ivory hover:bg-charcoal transition-colors font-serif text-[14px] sm:text-[15px] rounded-[2px]"
        >
          カウンセリングシートを保存
          <span className="text-[12px]">↓</span>
        </button>
        <a
          href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(typeof window !== 'undefined' ? window.location.href : '')}`}
          target="_blank"
          rel="noopener noreferrer"
          className="inline-flex items-center gap-2 px-5 py-3.5 bg-white border border-gold/55 text-ink hover:bg-cream/40 transition-colors font-serif text-[13.5px] sm:text-[14px] rounded-[2px]"
        >
          LINEで送る
        </a>
      </div>
      <p className="mt-4 text-center text-[11.5px] text-charcoal/55 leading-relaxed">
        ※ SEAM 以外の美容室でも、ご相談時にお使いいただけます。
      </p>
    </section>
  );
}

/* ──────────────────────────────────────────
   NarrativeJourney — 4章ナラティブ (Ch01-04, 05-06は別セクションへ統合)
   Chapter 01 髪の生まれ / 02 今の状態 / 03 いちばんの悩み /
   04 アドバイス→ヘアケア (05 美容師カード / 06 SEAM体験は別コンポーネント)
   ────────────────────────────────────────── */
function NarrativeJourney({ karte, answers }) {
  const origin = adaptOriginForStraightening(karte.origin, answers);
  if (!origin) return null;
  const radar = karte.radar || [3,3,3,3,3];

  // フォールバック: birthStory等が無いキャラはpersonalityで代用
  const birthStory = origin.birthStory || origin.personality || '';
  const currentMood = origin.currentMood || '';
  const primaryConcern = origin.primaryConcern || (origin.weaknesses && origin.weaknesses[0]?.title) || '';
  const tenderAdvice = origin.tenderAdvice || (origin.lifestyle && origin.lifestyle.join('。')) || '';

  // 履歴チップ作成
  const historyChips = [];
  if (answers?.straighten && answers.straighten !== 'none' && answers.straighten !== 'past') historyChips.push('縮毛矯正');
  if (answers?.bleach && answers.bleach !== 'none') historyChips.push('ブリーチ');
  if (answers?.color && answers.color !== 'none') historyChips.push('カラー');
  if (answers?.perm && answers.perm !== 'none') historyChips.push('パーマ');
  const tools = (answers?.styling && answers.styling.tools) || [];
  if (tools.some(t => /iron|bang/i.test(t))) historyChips.push('日々のアイロン');

  // しいたけ占い風: 改行で段落を分ける小コンポーネント
  const Paragraphs = ({ text }) => {
    if (!text) return null;
    return text.split('\n\n').map((p, i) => (
      <p key={i} className="font-serif text-[14.5px] sm:text-[15.5px] leading-[2.1] text-charcoal/90 mb-4 last:mb-0" style={{ letterSpacing: '0.02em' }}>
        {p.split('\n').map((line, j, arr) => (
          <React.Fragment key={j}>
            {line}{j < arr.length - 1 && <br />}
          </React.Fragment>
        ))}
      </p>
    ));
  };

  // 章タイトルブロック
  const ChapterTitle = ({ num, en, jp, accent }) => (
    <div className="mt-14 sm:mt-20 mb-7 sm:mb-9 text-center">
      <p className="font-mono tracking-widest3 text-[10px] sm:text-[10.5px] uppercase text-gold mb-3">— Chapter {num} · {en}</p>
      <h2 className="font-serif text-[26px] sm:text-[34px] leading-[1.35] text-ink" style={{ letterSpacing: '-0.01em' }}>
        {accent ? jp.split(accent).reduce((acc, part, i) => i === 0 ? [part] : [...acc, <span key={i} className="text-gold">{accent}</span>, part], []) : jp}
      </h2>
      <span aria-hidden className="block w-12 h-px bg-gold/55 mx-auto mt-5" />
    </div>
  );

  // イラスト挿入用プレースホルダー / 動画/画像があればそれをレンダリング
  const IllustSlot = ({ label, ratio = '3/2', videoSrc, imageSrc, posterSrc, badge }) => (
    <div
      className="my-7 mx-auto max-w-md relative overflow-hidden"
      style={{
        aspectRatio: ratio,
        background: (videoSrc || imageSrc) ? '#1A1815' : 'linear-gradient(180deg, #FBF8F2 0%, #F4ECDA 100%)',
        borderTop: '1px solid rgba(184,148,90,0.30)',
        borderBottom: '1px solid rgba(184,148,90,0.30)',
      }}
    >
      {/* corner ornaments */}
      <span aria-hidden className="absolute top-2 left-2 w-2.5 h-2.5 border-t border-l border-gold/60 z-10" />
      <span aria-hidden className="absolute top-2 right-2 w-2.5 h-2.5 border-t border-r border-gold/60 z-10" />
      <span aria-hidden className="absolute bottom-2 left-2 w-2.5 h-2.5 border-b border-l border-gold/60 z-10" />
      <span aria-hidden className="absolute bottom-2 right-2 w-2.5 h-2.5 border-b border-r border-gold/60 z-10" />

      {videoSrc ? (
        <>
          <video
            src={videoSrc}
            poster={posterSrc}
            autoPlay
            loop
            muted
            playsInline
            preload="metadata"
            className="absolute inset-0 w-full h-full object-cover"
            aria-label={label}
          />
          <span className="absolute top-3 left-1/2 -translate-x-1/2 z-10 font-mono tracking-widest3 text-[8.5px] uppercase text-gold bg-black/40 backdrop-blur-sm px-2 py-0.5 rounded-[1px]" style={{ letterSpacing: '0.3em' }}>
            — {badge || 'Origin'} —
          </span>
        </>
      ) : imageSrc ? (
        <>
          <img
            src={imageSrc}
            alt={label}
            loading="lazy"
            className="absolute inset-0 w-full h-full object-cover"
            onError={(e) => { e.target.style.display = 'none'; }}
          />
          <span className="absolute top-3 left-1/2 -translate-x-1/2 z-10 font-mono tracking-widest3 text-[8.5px] uppercase text-gold bg-black/40 backdrop-blur-sm px-2 py-0.5 rounded-[1px]" style={{ letterSpacing: '0.3em' }}>
            — {badge || 'Moment'} —
          </span>
        </>
      ) : (
        <div className="absolute inset-0 flex items-center justify-center text-center px-6" style={{ color: 'rgba(154,116,56,0.75)' }}>
          <div>
            <p className="font-mono tracking-widest3 text-[9px] uppercase text-gold mb-2" style={{ letterSpacing: '0.3em' }}>— Illustration —</p>
            <p className="font-serif italic text-[12.5px] leading-[1.7] text-charcoal/55">{label}</p>
          </div>
        </div>
      )}
    </div>
  );

  return (
    <div className="anim-fade-up">

      {/* ━━━━━ Chapter 01 · 髪の生まれ ━━━━━ */}
      <section id="chapter-birth" className="scroll-mt-[96px]">
        <ChapterTitle num="01" en="Birth" jp="あなたの髪は、こう生まれた" accent="こう生まれた" />
        <IllustSlot
          label="髪が生まれる詩的イメージ / 朝霧の中の宝石・原石"
          ratio="3/4"
          videoSrc="images/finder/chapter01-origin.mp4"
        />
        <article className="max-w-2xl mx-auto bg-white/80 border border-gold/25 rounded-[18px] p-7 sm:p-9">
          <Paragraphs text={birthStory} />
        </article>
      </section>

      {/* ━━━━━ Chapter 02 · 今のあなたの髪 ━━━━━ */}
      <section id="chapter-current" className="scroll-mt-[96px]">
        <ChapterTitle num="02" en="Current" jp="いまの、あなたの髪" accent="あなたの髪" />

        {/* 履歴チップ */}
        {historyChips.length > 0 && (
          <div className="mb-6 flex flex-wrap items-center justify-center gap-2 max-w-md mx-auto">
            <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55">— History</span>
            {historyChips.map((c, i) => (
              <span key={i} className="inline-flex items-center px-3 py-1.5 text-[11.5px] sm:text-[12px] bg-cream/60 border border-gold/35 rounded-full text-charcoal" style={{ fontWeight: 500 }}>{c}</span>
            ))}
          </div>
        )}

        {/* 状態本文 */}
        <article className="max-w-2xl mx-auto bg-white/80 border border-gold/25 rounded-[18px] p-7 sm:p-9">
          {currentMood ? <Paragraphs text={currentMood} /> : (
            <p className="font-serif text-[14.5px] sm:text-[15.5px] leading-[2.05] text-charcoal/85">
              {buildCurrentCondition(radar)}
            </p>
          )}
        </article>
      </section>

      {/* ━━━━━ Chapter 03 · いちばんの、お悩み ━━━━━ */}
      <section id="chapter-concern" className="scroll-mt-[96px]">
        <ChapterTitle num="03" en="One Concern" jp="あなたが、いちばん気にしてること" accent="いちばん気にしてること" />
        <IllustSlot
          label="湿気の朝・鏡を見て小さくため息のシーン / 寄り添うイメージ"
          ratio="3/2"
          imageSrc="images/finder/chapter03-concern.jpg"
          badge="Empathy"
        />
        <article
          className="relative max-w-2xl mx-auto rounded-[2px] p-8 sm:p-12 bg-white"
          style={{
            borderTop: '1px solid rgba(184,148,90,0.35)',
            borderBottom: '1px solid rgba(184,148,90,0.35)',
            boxShadow: '0 1px 2px rgba(26,24,21,0.04), 0 16px 48px -28px rgba(26,24,21,0.16)',
          }}
        >
          {/* corner ornaments */}
          <span aria-hidden className="absolute top-3 left-3 w-3 h-3 border-t border-l border-gold/45" />
          <span aria-hidden className="absolute top-3 right-3 w-3 h-3 border-t border-r border-gold/45" />
          <span aria-hidden className="absolute bottom-3 left-3 w-3 h-3 border-b border-l border-gold/45" />
          <span aria-hidden className="absolute bottom-3 right-3 w-3 h-3 border-b border-r border-gold/45" />
          <Paragraphs text={primaryConcern} />
        </article>
      </section>

      {/* ━━━━━ Chapter 04 · あなたへのアドバイス ━━━━━ */}
      <section id="chapter-advice" className="scroll-mt-[96px]">
        <ChapterTitle num="04" en="Tender Advice" jp="あなたへの、やさしい処方" accent="やさしい処方" />
        <article
          className="relative max-w-2xl mx-auto rounded-[2px] p-8 sm:p-12"
          style={{
            background: 'linear-gradient(180deg, #FBF8F2 0%, #F5EFE3 100%)',
            borderTop: '1px solid rgba(184,148,90,0.35)',
            borderBottom: '1px solid rgba(184,148,90,0.35)',
            boxShadow: '0 1px 2px rgba(26,24,21,0.04), 0 16px 48px -28px rgba(26,24,21,0.16)',
          }}
        >
          {/* corner ornaments */}
          <span aria-hidden className="absolute top-3 left-3 w-3 h-3 border-t border-l border-gold/55" />
          <span aria-hidden className="absolute top-3 right-3 w-3 h-3 border-t border-r border-gold/55" />
          <span aria-hidden className="absolute bottom-3 left-3 w-3 h-3 border-b border-l border-gold/55" />
          <span aria-hidden className="absolute bottom-3 right-3 w-3 h-3 border-b border-r border-gold/55" />
          {/* prescription mark */}
          <span aria-hidden className="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-white text-[9px] font-mono tracking-widest2 uppercase text-gold border border-gold/35 rounded-full" style={{ letterSpacing: '0.2em' }}>
            ℞ Prescription
          </span>
          <Paragraphs text={tenderAdvice} />
        </article>
        <p className="mt-7 text-center font-mono tracking-widest2 text-[10px] uppercase text-charcoal/55">
          ↓ あなたの髪に合う3つのヘアケア
        </p>
      </section>

    </div>
  );
}

/* ---------- 画像保存・シェア ---------- */
async function saveKarteCardAsImage(filename, mode) {
  if (typeof html2canvas !== 'function') {
    alert('保存の準備が整っていません。すこし時間を置いてもう一度お試しください。');
    return;
  }

  // mode: 'square' (1080x1080) / 'story' (1080x1920) / undefined (旧 Act 04 のみ)
  if (mode === 'square' || mode === 'story') {
    return saveCustomCanvas(filename, mode);
  }

  // 旧: Act 04 シェアカードのみ
  const node = document.getElementById('karte-share-card');
  if (!node) return;
  try {
    const canvas = await html2canvas(node, {
      backgroundColor: '#1A1815',
      scale: 2,
      useCORS: true,
      logging: false,
    });
    const link = document.createElement('a');
    link.download = filename || 'seam-karte.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
  } catch (e) {
    console.warn('Karte image save failed', e);
    alert('画像の保存に失敗しました。もう一度お試しください。');
  }
}

async function saveCustomCanvas(filename, mode) {
  // localStorage 経由でカルテ情報を取得
  let karte = null;
  try {
    const raw = localStorage.getItem('seam_karte_last');
    if (raw) karte = JSON.parse(raw);
  } catch (e) {}
  if (!karte) {
    alert('カルテ情報の読み込みに失敗しました。');
    return;
  }

  const isSquare = mode === 'square';
  const W = 1080;
  const H = isSquare ? 1080 : 1920;
  const canvas = document.createElement('canvas');
  canvas.width = W; canvas.height = H;
  const ctx = canvas.getContext('2d');

  // ── キャラクター画像を事前ロード(失敗してもフォールバックで継続)
  const animalDataPre = (typeof KARTE_ORIGIN_ANIMALS !== 'undefined') ? KARTE_ORIGIN_ANIMALS[karte.originId] : null;
  const charCode = (animalDataPre && animalDataPre.code) || karte.originCode || '';
  let charImg = null;
  if (charCode) {
    try {
      charImg = await new Promise((resolve) => {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = () => resolve(img);
        img.onerror = () => resolve(null);
        img.src = `images/characters/${charCode}.png`;
        // 念のため5秒タイムアウト
        setTimeout(() => resolve(null), 5000);
      });
    } catch (e) { charImg = null; }
  }

  // 背景(オフホワイト + 上下に薄いグラデーション)
  const bgGrad = ctx.createLinearGradient(0, 0, 0, H);
  bgGrad.addColorStop(0, '#F4F0E8');
  bgGrad.addColorStop(0.5, '#FAF8F4');
  bgGrad.addColorStop(1, '#F2EEE6');
  ctx.fillStyle = bgGrad;
  ctx.fillRect(0, 0, W, H);

  // ゴールドの細線(上下)
  ctx.fillStyle = '#B8945A';
  ctx.fillRect(0, 0, W, 4);
  ctx.fillRect(0, H - 4, W, 4);

  // フォント設定
  const fontMono = "'Montserrat', 'Helvetica Neue', Arial, sans-serif";
  const fontSerif = "'Cormorant Garamond', 'Noto Serif JP', serif";
  const fontJP = "'Noto Serif JP', 'Cormorant Garamond', serif";

  const cx = W / 2;
  let y = isSquare ? 90 : 180;

  // SEAM ロゴ
  ctx.fillStyle = '#3D3833';
  ctx.font = `400 28px ${fontMono}`;
  ctx.textAlign = 'center';
  ctx.fillText('SEAM', cx, y);

  // — Your Hair Type
  y += 50;
  ctx.fillStyle = '#B8945A';
  ctx.font = `500 18px ${fontMono}`;
  ctx.fillText('— YOUR HAIR TYPE', cx, y);

  // ペンタゴンの中心位置(やや小さめに)
  y += isSquare ? 50 : 80;
  const pentagonR = isSquare ? 110 : 130;
  const pentagonCY = y + pentagonR;
  drawCanvasPentagon(ctx, cx, pentagonCY, pentagonR, karte.radar || [3,3,3,3,3]);

  // ── キャラクターイラスト ──
  y = pentagonCY + pentagonR + (isSquare ? 20 : 40);
  const charSize = isSquare ? 300 : 480;
  if (charImg) {
    // 元画像のアスペクト比を保持して中央配置
    const ar = charImg.width / charImg.height;
    let dw = charSize, dh = charSize;
    if (ar >= 1) { dh = charSize / ar; } else { dw = charSize * ar; }
    const dx = cx - dw / 2;
    const dy = y;

    // 柔らかい影
    ctx.save();
    ctx.shadowColor = 'rgba(60,52,44,0.18)';
    ctx.shadowBlur = isSquare ? 18 : 28;
    ctx.shadowOffsetY = 6;
    ctx.drawImage(charImg, dx, dy, dw, dh);
    ctx.restore();

    y = dy + dh + (isSquare ? 18 : 36);
  } else {
    // フォールバック: なくても見苦しくない
    y += isSquare ? 20 : 30;
  }

  // 動物英語名 · コード
  ctx.fillStyle = '#8C7A63';
  ctx.font = `400 ${isSquare ? 20 : 22}px ${fontMono}`;
  // 英語名は KARTE_ORIGIN_ANIMALS から取得
  const animalData = (typeof KARTE_ORIGIN_ANIMALS !== 'undefined') ? KARTE_ORIGIN_ANIMALS[karte.originId] : null;
  const enLabel = animalData ? `${animalData.nameEn} · ${animalData.code}` : (karte.originCode || '');
  ctx.fillText(enLabel, cx, y);

  // 動物日本語名(大)
  y += isSquare ? 50 : 80;
  ctx.fillStyle = '#1A1815';
  ctx.font = `400 ${isSquare ? 52 : 72}px ${fontJP}`;
  ctx.fillText(karte.originName || '—', cx, y);

  // 目指す姿
  if (karte.mainGoalName) {
    y += isSquare ? 50 : 90;
    ctx.fillStyle = '#8C7A63';
    ctx.font = `400 18px ${fontMono}`;
    ctx.fillText('目指す姿', cx, y);
    y += 40;
    ctx.fillStyle = '#3D3833';
    ctx.font = `400 ${isSquare ? 36 : 44}px ${fontJP}`;
    ctx.fillText(karte.mainGoalName, cx, y);
  }

  // ストーリー縦長の場合は、追加で日付とハッシュタグ
  if (!isSquare) {
    y = H - 240;
    ctx.fillStyle = '#B8945A';
    ctx.font = `500 18px ${fontMono}`;
    ctx.fillText('— SEAM HAIR FINDER', cx, y);
    y += 40;
    ctx.fillStyle = '#8C7A63';
    ctx.font = `400 16px ${fontMono}`;
    ctx.fillText(new Date().toISOString().slice(0,10), cx, y);
    y += 40;
    ctx.fillStyle = '#3D3833';
    ctx.font = `400 20px ${fontMono}`;
    ctx.fillText('#SEAM髪診断', cx, y);
    y += 36;
    ctx.fillStyle = '#8C7A63';
    ctx.font = `400 14px ${fontMono}`;
    ctx.fillText('seam.site', cx, y);
  } else {
    // 正方形の場合は下部に日付
    y = H - 100;
    ctx.fillStyle = '#B8945A';
    ctx.font = `500 14px ${fontMono}`;
    ctx.fillText('— SEAM HAIR FINDER · #SEAM髪診断', cx, y);
    y += 30;
    ctx.fillStyle = '#8C7A63';
    ctx.font = `400 12px ${fontMono}`;
    ctx.fillText(`${new Date().toISOString().slice(0,10)} · seam.site`, cx, y);
  }

  // ダウンロード
  const link = document.createElement('a');
  link.download = filename || `seam-${mode}.png`;
  link.href = canvas.toDataURL('image/png');
  link.click();
}

function buildOgImageDataURL(originId, direction) {
  const origin = KARTE_ORIGIN_ANIMALS[originId];
  if (!origin) return null;
  const direction_ = direction || 'B';
  const mainGoalId = origin.targets?.[direction_];
  const mainGoal = KARTE_GOAL_ANIMALS[mainGoalId];

  const W = 1200, H = 630;
  const canvas = document.createElement('canvas');
  canvas.width = W; canvas.height = H;
  const ctx = canvas.getContext('2d');

  // 黒ベース背景 + 上下ゴールド
  ctx.fillStyle = '#0F0E0D';
  ctx.fillRect(0, 0, W, H);
  ctx.fillStyle = '#B8945A';
  ctx.fillRect(0, 0, W, 3);
  ctx.fillRect(0, H - 3, W, 3);

  // 微かなラジアルグラデーション
  const grad = ctx.createRadialGradient(W/2, H/2, 50, W/2, H/2, 600);
  grad.addColorStop(0, 'rgba(217,190,147,0.10)');
  grad.addColorStop(1, 'rgba(217,190,147,0)');
  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, W, H);

  ctx.textAlign = 'center';
  const fontMono = "'Montserrat', 'Helvetica Neue', Arial, sans-serif";
  const fontSerif = "'Cormorant Garamond', 'Noto Serif JP', serif";
  const fontJP = "'Noto Serif JP', 'Cormorant Garamond', serif";

  // ペンタゴン(左側)
  const pentagonCX = 320;
  const pentagonCY = H / 2;
  drawCanvasPentagonDark(ctx, pentagonCX, pentagonCY, 170, origin.radar || [3,3,3,3,3]);

  // 右側テキスト
  const textCX = 820;
  let y = 130;

  // SEAM ロゴ + バッジ
  ctx.fillStyle = '#B8945A';
  ctx.font = `500 18px ${fontMono}`;
  ctx.fillText('— SEAM HAIR FINDER', textCX, y);

  // タイプコード(大)
  y += 100;
  ctx.fillStyle = '#FFFFFF';
  ctx.font = `400 110px ${fontSerif}`;
  ctx.fillText(origin.code || '—', textCX, y);

  // 英語名
  y += 50;
  ctx.fillStyle = '#D9BE93';
  ctx.font = `400 22px ${fontMono}`;
  ctx.fillText(origin.nameEn || '', textCX, y);

  // 日本語名
  y += 60;
  ctx.fillStyle = '#FFFFFF';
  ctx.font = `400 44px ${fontJP}`;
  ctx.fillText(origin.name || '', textCX, y);

  // レア度 + 目指す姿
  y += 50;
  ctx.fillStyle = '#D9BE93';
  ctx.font = `400 18px ${fontMono}`;
  const subtitle = origin.nameEn || origin.code || '';
  ctx.fillText(subtitle, textCX, y);
  if (mainGoal) {
    y += 35;
    ctx.fillStyle = 'rgba(255,255,255,0.65)';
    ctx.font = `400 18px ${fontJP}`;
    ctx.fillText(`目指す姿 → ${mainGoal.name}`, textCX, y);
  }

  // 下部 URL
  ctx.fillStyle = 'rgba(201,169,110,0.7)';
  ctx.font = `400 14px ${fontMono}`;
  ctx.fillText('seam.site · #SEAM髪診断', textCX, H - 50);

  return canvas.toDataURL('image/png');
}

function drawCanvasPentagonDark(ctx, cx, cy, radius, values) {
  const angleFor = (i) => (-Math.PI / 2) + (i * 2 * Math.PI / 5);
  for (let lv = 1; lv <= 5; lv++) {
    const r = (lv / 5) * radius;
    ctx.beginPath();
    for (let i = 0; i < 5; i++) {
      const a = angleFor(i);
      const x = cx + r * Math.cos(a);
      const y = cy + r * Math.sin(a);
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.strokeStyle = lv === 5 ? 'rgba(217,190,147,0.45)' : 'rgba(217,190,147,0.18)';
    ctx.lineWidth = lv === 5 ? 1.4 : 0.9;
    ctx.stroke();
  }
  ctx.strokeStyle = 'rgba(217,190,147,0.18)';
  ctx.lineWidth = 0.9;
  for (let i = 0; i < 5; i++) {
    const a = angleFor(i);
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + radius * Math.cos(a), cy + radius * Math.sin(a));
    ctx.stroke();
  }
  ctx.beginPath();
  for (let i = 0; i < 5; i++) {
    const v = values[i] || 3;
    const r = (v / 5) * radius;
    const a = angleFor(i);
    const x = cx + r * Math.cos(a);
    const y = cy + r * Math.sin(a);
    if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
  }
  ctx.closePath();
  ctx.fillStyle = 'rgba(184,148,90,0.28)';
  ctx.fill();
  ctx.strokeStyle = '#B8945A';
  ctx.lineWidth = 2;
  ctx.stroke();
  ctx.fillStyle = '#B8945A';
  for (let i = 0; i < 5; i++) {
    const v = values[i] || 3;
    const r = (v / 5) * radius;
    const a = angleFor(i);
    const x = cx + r * Math.cos(a);
    const y = cy + r * Math.sin(a);
    ctx.beginPath();
    ctx.arc(x, y, 5, 0, Math.PI * 2);
    ctx.fill();
  }
}

function drawCanvasPentagon(ctx, cx, cy, radius, values) {
  const angleFor = (i) => (-Math.PI / 2) + (i * 2 * Math.PI / 5);
  const labels = ['透明感', '艶', 'まとまり', '華やぎ', '頭皮'];

  // グリッド
  for (let lv = 1; lv <= 5; lv++) {
    const r = (lv / 5) * radius;
    ctx.beginPath();
    for (let i = 0; i < 5; i++) {
      const a = angleFor(i);
      const x = cx + r * Math.cos(a);
      const y = cy + r * Math.sin(a);
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.strokeStyle = lv === 5 ? '#D6C7B0' : '#E7E4DE';
    ctx.lineWidth = lv === 5 ? 1.4 : 1.0;
    ctx.stroke();
  }

  // 軸線
  ctx.strokeStyle = '#E7E4DE';
  ctx.lineWidth = 1;
  for (let i = 0; i < 5; i++) {
    const a = angleFor(i);
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + radius * Math.cos(a), cy + radius * Math.sin(a));
    ctx.stroke();
  }

  // データ
  ctx.beginPath();
  for (let i = 0; i < 5; i++) {
    const v = values[i] || 3;
    const r = (v / 5) * radius;
    const a = angleFor(i);
    const x = cx + r * Math.cos(a);
    const y = cy + r * Math.sin(a);
    if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
  }
  ctx.closePath();
  ctx.fillStyle = 'rgba(184,148,90,0.16)';
  ctx.fill();
  ctx.strokeStyle = '#B8945A';
  ctx.lineWidth = 2;
  ctx.stroke();

  // 頂点ドット
  ctx.fillStyle = '#B8945A';
  for (let i = 0; i < 5; i++) {
    const v = values[i] || 3;
    const r = (v / 5) * radius;
    const a = angleFor(i);
    const x = cx + r * Math.cos(a);
    const y = cy + r * Math.sin(a);
    ctx.beginPath();
    ctx.arc(x, y, 5, 0, Math.PI * 2);
    ctx.fill();
  }

  // ラベル
  ctx.fillStyle = '#3D3833';
  ctx.font = "500 14px 'Montserrat', sans-serif";
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  for (let i = 0; i < 5; i++) {
    const a = angleFor(i);
    const lr = radius + 30;
    const x = cx + lr * Math.cos(a);
    const y = cy + lr * Math.sin(a);
    ctx.fillText(labels[i], x, y - 8);
    ctx.fillStyle = '#B8945A';
    ctx.font = "400 18px 'Cormorant Garamond', serif";
    ctx.fillText(String(values[i] || 3), x, y + 10);
    ctx.fillStyle = '#3D3833';
    ctx.font = "500 14px 'Montserrat', sans-serif";
  }
}

/* ---------- 美容師さんに見せるメモ ---------- */
function shareKarteLink(origin) {
  // ?type=ASR&dir=B 形式の共有URL
  let url = window.location.origin + window.location.pathname;
  if (origin && origin.code) {
    let dir = '';
    try {
      const raw = localStorage.getItem('seam_karte_last');
      if (raw) {
        const parsed = JSON.parse(raw);
        const mainGoalId = parsed?.mainGoalId;
        if (mainGoalId && typeof KARTE_GOAL_ANIMALS !== 'undefined') {
          dir = KARTE_GOAL_ANIMALS[mainGoalId]?.direction || '';
        }
      }
    } catch (e) {}
    const params = new URLSearchParams();
    params.set('type', origin.code);
    if (dir) params.set('dir', dir);
    url = url + '?' + params.toString();
  }
  const text = `わたしは「${origin?.name || '—'}」タイプでした。 #SEAM髪診断`;
  if (navigator.share) {
    navigator.share({ title: 'SEAM 髪診断', text, url }).catch(() => {});
  } else if (navigator.clipboard) {
    navigator.clipboard.writeText(`${text}\n${url}`).then(
      () => alert('リンクをコピーしました。友達に送ってみてください。'),
      () => alert('コピーに失敗しました。')
    );
  } else {
    alert('お使いの環境ではシェアできません。URLを直接コピーしてください。');
  }
}

/* ---------- Result ---------- */
function Result({ answers, onRestart, onCollection, onDeepUpgrade }) {
  const { scores, flags } = useMemo(() => computeScores(answers), [answers]);
  const typeId = useMemo(() => determineType(scores, answers), [scores, answers]);
  // 旧 TYPE_DEFS / buildDescription / buildCarePoints の参照は撤去済み (Phase B 監査)
  const chart = useMemo(() => buildChart(scores, answers), [scores, answers]);
  // 共有URLでアクセス時、ページタイトルと OG メタを動的更新
  useEffect(() => {
    if (!answers._isShared) return;
    const origin = KARTE_ORIGIN_ANIMALS[answers._sharedOriginId];
    if (!origin) return;
    const title = `${origin.name} (${origin.code}) — あなたの髪タイプは? | SEAM 髪診断`;
    const desc  = `「${origin.name}」タイプ。${origin.strength || ''}あなたの髪タイプも診断してみませんか?`;
    document.title = title;

    // 動的 OG / Twitter Card
    const setMeta = (selector, attr, content) => {
      let el = document.head.querySelector(selector);
      if (!el) {
        el = document.createElement('meta');
        if (attr === 'property') el.setAttribute('property', selector.match(/property="([^"]+)"/)?.[1] || '');
        else el.setAttribute('name', selector.match(/name="([^"]+)"/)?.[1] || '');
        document.head.appendChild(el);
      }
      el.setAttribute('content', content);
    };
    setMeta('meta[property="og:title"]', 'property', title);
    setMeta('meta[property="og:description"]', 'property', desc);
    setMeta('meta[name="twitter:title"]', 'name', title);
    setMeta('meta[name="twitter:description"]', 'name', desc);

    // 動的 OG 画像生成(クライアントサイド)
    try {
      const dataURL = buildOgImageDataURL(answers._sharedOriginId, answers._sharedDirection);
      if (dataURL) {
        setMeta('meta[property="og:image"]', 'property', dataURL);
        setMeta('meta[name="twitter:image"]', 'name', dataURL);
      }
    } catch (e) { console.warn('Dynamic OG generation failed', e); }
  }, [answers._isShared, answers._sharedOriginId]);

  const karte = useMemo(() => {
    // 共有URLから来た場合は、サンプル回答ではなく指定された originId/dir で組み立て直す
    if (answers._isShared && answers._sharedOriginId) {
      const origin = KARTE_ORIGIN_ANIMALS[answers._sharedOriginId];
      const direction = answers._sharedDirection || 'B';
      const radar = origin?.radar || [3,3,3,3,3];
      const mainGoalId = origin?.targets?.[direction];
      const mainGoal = KARTE_GOAL_ANIMALS[mainGoalId];
      const targetRadar = deriveTargetRadar(radar, direction);
      const subDirs = ['A','B','C','D'].filter(d => d !== direction);
      const subGoals = subDirs.map(d => ({ dir:d, id: origin?.targets?.[d], goal: KARTE_GOAL_ANIMALS[origin?.targets?.[d]] }));
      const states = [KARTE_POETIC_STATES.find(s => s.id === 'calm')];
      const stateText = states.map(s => s.text).join('、');
      return {
        radar, targetRadar,
        originId: answers._sharedOriginId, origin,
        direction,
        mainGoalId, mainGoal,
        subGoals,
        stateText, states,
        adviceKey:'calm', adviceText: KARTE_ADVICE.calm,
      };
    }
    return resolveKarteAnimal(answers, scores);
  }, [answers, scores]);
  // isDeepMode: Mode B (詳しいカルテ) の項目が回答されているかで判定
  const isDeepMode = useMemo(() => {
    const a = answers || {};
    return !!(a.age || a.rootVolume || a.scalpType || a.colorFreq || a.grayHair ||
              a.bleachLocation || a.permType || a.heatProtect || a.scalpAllergy || a.hairTrouble);
  }, [answers]);

  // 結果が出たら localStorage に保存(次回 "前回のつづきから" 用)
  useEffect(() => {
    if (!karte) return;
    try {
      const payload = {
        version: 1,
        savedAt: new Date().toISOString(),
        originId:   karte.origin?.id || karte.originId,
        originName: karte.origin?.name,
        originCode: karte.origin?.code,
        mainGoalId: karte.mainGoalId,
        mainGoalName: karte.mainGoal?.name,
        radar:      karte.radar,
        typeId:     typeId,
        answersSnapshot: answers,
      };
      localStorage.setItem('seam_karte_last', JSON.stringify(payload));
    } catch (e) {}
  }, [karte, typeId, answers]);
  // 旧 ROUTINE_BY_TYPE / PRODUCTS の参照は撤去済み (Phase B 監査)

  // SEAM 全商品マスター: data/products/seam-master.json を非同期取得 → 診断回答でスコアリング
  // cache-bust付きで強制最新化
  const [seamData, setSeamData] = useState(null);
  useEffect(() => {
    fetch('data/products/seam-master.json?v=' + Date.now(), { cache: 'no-store' })
      .then(r => r.ok ? r.json() : null)
      .then(d => setSeamData(d))
      .catch(() => setSeamData(null));
  }, []);
  // Home Tools(美容家電) data 取得
  const [toolsData, setToolsData] = useState(null);
  useEffect(() => {
    fetch('data/products/seam-tools.json?v=' + Date.now(), { cache: 'no-store' })
      .then(r => r.ok ? r.json() : null)
      .then(d => setToolsData(d))
      .catch(() => setToolsData(null));
  }, []);
  const seamPicks = useMemo(() => {
    if (!seamData) return [];
    return pickSeamProducts(seamData.products, answers, scores, flags, { maxPerBrand: 2 });
  }, [seamData, answers, scores, flags]);
  const deepResult = useMemo(() => {
    if (!seamData || !isDeepMode) return null;
    const originCode = karte?.origin?.code || '';
    return pickDeepProducts(seamData.products, answers, scores, flags, {
      maxPerBlock: 4, maxPerBrand: 3, originCode,
    });
  }, [seamData, answers, scores, flags, isDeepMode, karte]);
  const mustPlusOne = useMemo(() => {
    if (!seamData) return [];
    return pickMustPlusOne(seamData.products, answers, scores);
  }, [seamData, answers, scores]);

  useEffect(() => { window.scrollTo({ top: 0, behavior: 'instant' }); }, []);

  return (
    <div className="min-h-[100svh] bg-finder">
      <div className="no-print"><TopBar /></div>
      <main className="relative z-10 mx-auto max-w-3xl px-5 sm:px-8 pt-28 pb-[calc(90px+env(safe-area-inset-bottom,0px))] sm:pb-28">
        <div className="anim-fade-up">
          {/* Karte-style meta header */}
          <div className="flex items-center justify-between border-y border-line py-2.5 mb-3 print-page-header">
            <div className="flex items-center gap-3">
              <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-gold">Karte</span>
              <span className="h-px w-6 bg-line" />
              <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/60">SEAM Hair Finder</span>
            </div>
            <div className="flex items-center gap-3">
              <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/50 nums">
                {new Date().toISOString().slice(0,10)}
              </span>
              <button
                onClick={saveOrShareKarte}
                className="no-print inline-flex items-center gap-1.5 font-mono tracking-widest2 text-[10px] uppercase text-ink bg-ivory border border-ink px-3 py-1.5 rounded-[1px] hover:bg-ink hover:text-ivory transition-colors"
              >
                <svg viewBox="0 0 16 16" className="w-3 h-3" fill="none" aria-hidden>
                  <path d="M8 2 L 8 11 M4 7 L 8 11 L 12 7 M2.5 13.5 L 13.5 13.5" stroke="currentColor" strokeWidth="1.2" strokeLinecap="round" strokeLinejoin="round" />
                </svg>
                <span className="hidden sm:inline">美容師さんに見せるメモを保存</span>
                <span className="sm:hidden">メモを保存</span>
              </button>
            </div>
          </div>
        </div>

        <ResultHero
          karte={karte}
          onSaveImage={(mode) => saveKarteCardAsImage(`SEAM-${karte?.origin?.code || 'karte'}-${mode}.png`, mode)}
          onShare={() => shareKarteLink(karte?.origin)}
        />

        {/* ━━━━━ NEW: 6-Chapter Narrative (しいたけ占い風寄り添い) ━━━━━ */}
        {karte?.origin && (
          <NarrativeJourney karte={karte} answers={answers} />
        )}

        {/* ChapterBottomNav は撤去 — スマホ最小幅 320px で破綻リスクと
            Mobile 3-Button CTA との重なり問題を解消するため削除 (2026-05) */}

        {/* 旧 Chapter 02 と KarteAnimalSection は NarrativeJourney に統合済み */}

        {/* ⓐ SEAM Select Shop ブロック → 削除 (重複整理)
            "世界中のヘアケアを、あなたに合わせて選ぶ" は SEAM QUALITY PROMISE と重複していたため、
            Visit SEAM セクションの冒頭(Why SEAM)に統合済み */}

        <section className="mt-12 sm:mt-16 anim-fade-up" style={{ animationDelay: '160ms' }}>
          <p className="font-mono tracking-widest2 text-[11px] uppercase text-gold">— Care Priority</p>
          <h2 className="mt-3 font-serif text-2xl sm:text-3xl text-ink">ケアの優先度</h2>
          <p className="mt-2 text-[13px] sm:text-[13.5px] text-charcoal/70 leading-[1.9]">
            いまの髪の状態を、Keep(維持) / Care(ケア) / Intensive Care(集中ケア)の3段階で表示しています。
          </p>
          <div className="mt-7 bg-white/70 border border-line p-6 sm:p-8 rounded-[2px]">
            <HairChart chart={chart} />
          </div>
        </section>

        {/* Heat × history warnings */}
        {(flags.heatColorWarning || flags.heatBleachWarning) && (
          <section className="mt-12 sm:mt-16 anim-fade-up" style={{ animationDelay: '200ms' }}>
            <p className="font-mono tracking-widest2 text-[11px] uppercase text-gold">— Alert</p>
            <h2 className="mt-3 font-serif text-2xl sm:text-3xl text-ink">熱と髪の履歴について</h2>
            <p className="mt-2 text-[12.5px] text-charcoal/65 leading-relaxed">
              いつもの温度と、これまでの履歴の組み合わせから、いくつか注意点があります。
            </p>
            <div className="mt-6 space-y-4">
              {flags.heatColorWarning && (
                <article className="border-l-2 border-gold bg-white/70 rounded-sm p-5 sm:p-6">
                  <header className="flex items-center gap-3">
                    <span className="font-mono tracking-widest2 text-[10px] uppercase text-gold px-2 py-0.5 border border-gold/40 rounded-sm">Caution · 180°C+</span>
                    <span className="font-serif text-[15px] text-ink">カラーの褪色に注意</span>
                  </header>
                  <p className="mt-3 text-[13px] leading-[1.95] text-charcoal/85">
                    180°C以上のアイロン・コテは、ヘアカラーの色素を熱で壊し、褪色を早めます。
                    特に <span className="text-ink font-medium">アッシュ・マット・グレー・ベージュなどの寒色系・くすみ系</span> はオレンジ味が出やすく、退色のスピードが目に見えて速くなります。
                  </p>
                  <ul className="mt-3 text-[12.5px] leading-[1.95] text-charcoal/75 space-y-1.5">
                    <li>· カラー直後の数日は、できれば 160°C 以下で使用する。</li>
                    <li>· 同じ箇所を何度もスルーせず、1〜2回で形を決める。</li>
                    <li>· アイロン前にヒートプロテクト系のミストを必ず併用する。</li>
                  </ul>
                </article>
              )}
              {flags.heatBleachWarning && (
                <article
                  className="border-l-2 border-gold text-ink rounded-sm p-5 sm:p-6"
                  style={{ background: 'linear-gradient(155deg, #FBF7EF 0%, #F5EDDD 60%, #EEE2CB 100%)' }}
                >
                  <header className="flex items-center gap-3">
                    <span className="font-mono tracking-widest2 text-[10px] uppercase text-ink bg-white/70 border border-gold/40 px-2 py-0.5 rounded-sm">Warning · 200°C+</span>
                    <span className="font-serif text-[15px] text-ink">サロン施術前は、必ず美容師へ申告を</span>
                  </header>
                  <p className="mt-3 text-[13px] leading-[1.95] text-charcoal/85">
                    高温アイロンの使用履歴がある髪は、見た目以上に <span className="text-gold">熱ダメージが内部に蓄積</span> している場合があります。
                    ブリーチや縮毛矯正などの薬剤施術時に、切れ毛・縮れ・ビビり毛として一気に表面化する可能性があるため、施術前に必ず美容師へお伝えください。
                  </p>
                  <ul className="mt-3 text-[12.5px] leading-[1.95] text-charcoal/75 space-y-1.5">
                    <li>· 普段の温度を 180°C 以下に下げる検討を。</li>
                    <li>· 必ずヒートプロテクトを使い、髪が完全に乾いた状態で当てる。</li>
                    <li>· 同じ箇所への連続スルーは避け、短時間で通す。</li>
                    <li>· 気になる症状がある場合は、自宅ケアより先にサロンでご相談ください。</li>
                  </ul>
                </article>
              )}
            </div>
          </section>
        )}

        {/* 旧 Chapter 03 banner は NarrativeJourney の Chapter 04 Tender Advice に統合済み */}

{/* "あなたに必要なケア" Care Points セクションは情報重複により削除済み */}

        {/* ━━━━━ +1 MUST · プラスワン必須処方(常時表示) ━━━━━ */}
        {mustPlusOne && mustPlusOne.length > 0 && (
          <MustPlusOneSection matches={mustPlusOne} />
        )}

        {/* Deep Match — Mode B 完了時のみ表示 */}
        {isDeepMode && deepResult && (
          <DeepProductSection deepResult={deepResult} seamData={seamData} />
        )}

        {/* ProductShowcase (旧 "3つの選択") は DeepProductSection (あなただけのケア処方) と
            カテゴリ重複 + 役割重複のため削除済み (Phase 1 監査での重複削減) */}

        {/* Home Tools — 美容家電(ドライヤー/アイロン/ヘッドスパ) */}
        {toolsData && toolsData.tools && (
          <HomeToolsSection
            tools={toolsData.tools}
            answers={answers}
            scores={scores}
          />
        )}

        <HeadSpaSection answers={answers} />

        {/* ━━━━━ カルテが作成されました — テキストのみのカウンセリングシート ━━━━━ */}
        {karte?.origin && (
          <CounselingSheet
            karte={karte}
            answers={answers}
            onSaveImage={(mode) => saveKarteCardAsImage(`SEAM-karte-${karte?.origin?.code || ''}-${mode}.png`, mode)}
          />
        )}

        {/* StylistMemoSection は Hair ID Card に統合済み (重複削減) */}

        {/* ━━━━━ VISIT SEAM — Apple-style minimal & exciting ━━━━━ */}
        <VisitSeamSection saveOrShareKarte={saveOrShareKarte} />


        {/* ⓕ 最終 CTA — 締めくくり (圧倒的 breathing) — index signature pattern */}
        <section className="mt-20 sm:mt-28 anim-fade-up no-print text-center">
          {/* Eyebrow with bilateral hairline (centered) */}
          <div className="flex items-center justify-center gap-3 mb-4">
            <span className="h-px flex-1 bg-gold/40 max-w-[40px]" />
            <span className="font-mono tracking-widest2 text-[10.5px] text-gold uppercase">Begin</span>
            <span className="h-px flex-1 bg-gold/40 max-w-[40px]" />
          </div>

          <h2 className="font-serif text-[26px] sm:text-[32px] text-ink leading-[1.3]">
            SEAM、はじめましょう。
          </h2>

          {/* Gold underline below H2 (index signature) */}
          <span aria-hidden className="block w-16 h-px bg-gold/60 mx-auto mt-5" />

          {/* 締めコピー (詩的) */}
          <p className="mt-7 font-serif text-[15px] sm:text-[16px] text-ink/85 leading-[1.9]">
            髪のカルテを、サロンへ持って。
          </p>

          {/* Ring-framed Main CTA */}
          <div className="mt-6 flex justify-center">
            <div className="relative inline-block">
              <span aria-hidden className="absolute -inset-1.5 sm:-inset-2 rounded-full border border-mainBrown/35 pointer-events-none" />
              <button
                className="relative inline-flex items-center justify-center gap-3 px-7 py-4 sm:py-5 text-white font-serif text-[14px] sm:text-[15px] rounded-full transition-colors shadow-card"
                style={{background:'#B57C5A', letterSpacing:'0.02em'}}
                onMouseEnter={(e)=>{e.currentTarget.style.background='#9F6A4B'}}
                onMouseLeave={(e)=>{e.currentTarget.style.background='#B57C5A'}}
              >
                <span>近くのSEAMを探す</span>
                <span className="inline-flex items-center justify-center w-9 h-9 sm:w-10 sm:h-10 rounded-full ml-1" style={{background:'#ffffff', color:'#B57C5A'}}>→</span>
              </button>
            </div>
          </div>

          {/* 信頼ライン (鍵アイコン) */}
          <div className="mt-4 sm:mt-5 flex items-center justify-center gap-2 text-[11.5px] sm:text-[12px] text-charcoal/65">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.6"><rect x="5" y="11" width="14" height="10" rx="1"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
            <span>カルテ持参で更に丁寧 / 全国7店舗 / 当日予約OK</span>
          </div>

          {/* Secondary outline CTA */}
          <div className="mt-5 flex justify-center">
            <a
              href={SHOP_URL}
              target="_blank"
              rel="noopener noreferrer"
              className="inline-flex items-center gap-2 px-5 py-3 border border-ink/25 text-ink text-[12.5px] font-serif rounded-full hover:border-ink hover:bg-white/60 transition-colors"
            >
              <span>メンバーはオンラインへ</span><span className="text-gold">↗</span>
            </a>
          </div>
        </section>

        <section className="mt-10 sm:mt-14 text-center no-print">
          <button
            onClick={onRestart}
            className="inline-flex items-center gap-3 font-mono text-[10.5px] tracking-widest2 uppercase text-charcoal/70 hover:text-ink"
          >
            <span className="inline-block w-6 h-px bg-charcoal/40" />
            <span>もう一度診断する</span>
            <span className="inline-block w-6 h-px bg-charcoal/40" />
          </button>
        </section>

        <section className="mt-12 text-center">
          <p className="font-serif text-charcoal/70 text-[14px] leading-relaxed">
            髪は、履歴で変わる。<br />
            <span className="font-serif text-ink text-[18px] sm:text-[20px] block mt-3">ぜんぶ、<span className="text-gold">SEAMにあります。</span></span>
            <span className="text-charcoal/55 text-[12.5px] block mt-2">あなたの診断結果のすべての商品は、SEAM 認定サロンと会員制オンラインストアで取り扱っています。</span>
          </p>
        </section>
      </main>
      <footer className="py-8 text-center text-[11px] tracking-widest2 uppercase text-charcoal/40">
        SEAM · Salon Selection Store
      </footer>

      {/* Mobile sticky bottom CTA — 結果ページ専用 (Apple HIG準拠 min-h 56px) */}
      <div className="sm:hidden no-print fixed bottom-0 inset-x-0 z-30 border-t border-line bg-ivory/95 backdrop-blur-md" style={{paddingBottom:'env(safe-area-inset-bottom, 0)'}}>
        <div className="grid grid-cols-[1.5fr_1fr_1fr] h-[68px]">
          {/* 主役: 髪のカルテを保存 */}
          <button
            type="button"
            onClick={() => saveKarteCardAsImage(`SEAM-${karte?.origin?.code || 'karte'}-square.png`, 'square')}
            aria-label="髪のカルテを画像で保存"
            className="flex flex-col items-center justify-center gap-1 text-white relative active:opacity-90 transition-opacity"
            style={{background:'#B57C5A', minHeight:'56px'}}
          >
            <span className="absolute -top-2 left-1/2 -translate-x-1/2 font-mono tracking-widest2 text-[8.5px] uppercase text-ink nums bg-goldLight px-2 py-0.5 rounded-[1px] whitespace-nowrap">Save Karte</span>
            <svg viewBox="0 0 16 16" className="w-5 h-5" fill="none" aria-hidden>
              <path d="M3 5 H13 V13 H3 Z M5 2 H11 V5 M6.5 8 H9.5 M6.5 10.5 H9.5" stroke="currentColor" strokeWidth="1.3" strokeLinecap="round" strokeLinejoin="round" />
            </svg>
            <span className="font-serif text-[12.5px] text-white leading-none">髪のカルテを保存</span>
          </button>
          {/* 予約 */}
          <button
            type="button"
            data-open-resv
            aria-label="サロンを予約する"
            className="flex flex-col items-center justify-center gap-1 bg-cream text-ink active:bg-cream/80 border-l border-line transition-colors"
            style={{minHeight:'56px'}}
          >
            <svg viewBox="0 0 16 16" className="w-5 h-5" fill="none" aria-hidden>
              <rect x="2.5" y="3" width="11" height="11" rx="0.5" stroke="currentColor" strokeWidth="1.3"/>
              <path d="M5 1.5 L 5 4 M11 1.5 L 11 4 M2.5 7 L 13.5 7" stroke="currentColor" strokeWidth="1.3" strokeLinecap="round"/>
            </svg>
            <span className="font-serif text-[11.5px] leading-none">サロン予約</span>
          </button>
          {/* シェア */}
          <button
            type="button"
            onClick={() => shareKarteLink(karte?.origin)}
            aria-label="診断結果をシェアする"
            className="flex flex-col items-center justify-center gap-1 bg-cream text-ink active:bg-cream/80 border-l border-line transition-colors"
            style={{minHeight:'56px'}}
          >
            <svg viewBox="0 0 16 16" className="w-5 h-5" fill="none" aria-hidden>
              <circle cx="4" cy="8" r="2" stroke="currentColor" strokeWidth="1.3" />
              <circle cx="12" cy="3.5" r="2" stroke="currentColor" strokeWidth="1.3" />
              <circle cx="12" cy="12.5" r="2" stroke="currentColor" strokeWidth="1.3" />
              <path d="M5.7 7 L 10.3 4.4 M 5.7 9 L 10.3 11.6" stroke="currentColor" strokeWidth="1.3" />
            </svg>
            <span className="font-serif text-[11.5px] leading-none">シェア</span>
          </button>
        </div>
      </div>
    </div>
  );
}

/* ---------- App ---------- */
function loadLastKarte() {
  try {
    const raw = localStorage.getItem('seam_karte_last');
    if (!raw) return null;
    const parsed = JSON.parse(raw);
    if (!parsed || !parsed.answersSnapshot) return null;
    return parsed;
  } catch (e) { return null; }
}

function clearLastKarte() {
  try { localStorage.removeItem('seam_karte_last'); } catch (e) {}
}

/* URL ?type=ASR&dir=B からサンプル回答を生成 */
function buildSampleAnswersForType(typeCode, dirCode) {
  let originId = null;
  for (const id in KARTE_ORIGIN_ANIMALS) {
    if (KARTE_ORIGIN_ANIMALS[id].code === typeCode) { originId = id; break; }
  }
  if (!originId) return null;
  return {
    concerns: ['noShine'],
    length: 'shoulderUp',
    thickness: 'normal', density: 'normal', wave: 'none',
    color: 'none', bleach: 'none', straighten: 'none', perm: 'none',
    styling: { tools: ['rare'], temp: 't140' },
    lifestyle: ['desk'],
    environment: 'indoor',
    items: ['shampoo'],
    concernsItem: ['none'],
    goalTexture: 'glossy', goal: 'ends',
    headSpaInterest: 'no',
    _isShared: true,
    _sharedOriginId: originId,
    _sharedDirection: ['A','B','C','D'].includes(dirCode) ? dirCode : 'B',
  };
}

function RevealLoader() {
  const lines = [
    'お聞かせいただき、ありがとうございました。',
    'あなたの髪に、そっと耳をすませています。',
    'もう少しだけ、お時間をください。',
  ];
  return (
    <div className="min-h-[100svh] bg-finder relative flex items-center justify-center px-6">
      <div className="text-center max-w-md">
        <div className="inline-block karte-mark-accent" style={{ width: 96, height: 96 }}>
          <span className="karte-mark-glow" aria-hidden />
          <svg viewBox="0 0 100 100" width="96" height="96" aria-hidden className="relative">
            <circle cx="50" cy="50" r="46" fill="none" stroke="#D9BE93" strokeWidth="0.8" />
            <circle cx="50" cy="50" r="38" fill="none" stroke="#E7E4DE" strokeWidth="0.5" />
            <g stroke="#B8945A" strokeWidth="0.9" fill="none" strokeLinecap="round">
              <path d="M50 28 L57 50 L50 72 L43 50 Z" opacity="0.78" />
              <circle cx="50" cy="50" r="3.2" fill="#B8945A" stroke="none" />
            </g>
          </svg>
        </div>
        <p className="mt-7 font-mono tracking-widest2 text-[10px] uppercase text-gold">— Reading your hair</p>
        <h2 className="mt-3 font-serif text-[20px] sm:text-[22px] text-ink leading-[1.85]">
          あなたの髪に、耳をすませています
        </h2>
        <div className="mt-6 space-y-2 text-[12.5px] leading-[1.95] text-charcoal/70">
          {lines.map((l,i) => (
            <p key={i} className="anim-fade-up" style={{ animationDelay: (i*350)+'ms' }}>{l}</p>
          ))}
        </div>
        <div className="mt-9 inline-flex gap-1.5">
          <span className="w-1.5 h-1.5 bg-gold/80 rounded-full" style={{ animation:'karte-glow 1500ms ease-in-out infinite', animationDelay:'0ms' }} />
          <span className="w-1.5 h-1.5 bg-gold/80 rounded-full" style={{ animation:'karte-glow 1500ms ease-in-out infinite', animationDelay:'300ms' }} />
          <span className="w-1.5 h-1.5 bg-gold/80 rounded-full" style={{ animation:'karte-glow 1500ms ease-in-out infinite', animationDelay:'600ms' }} />
        </div>
      </div>
    </div>
  );
}

function App() {
  // URL から共有リンクを検出
  const sharedInit = useMemo(() => {
    if (typeof window === 'undefined') return null;
    const params = new URLSearchParams(window.location.search);
    const type = (params.get('type') || '').toUpperCase();
    const dir  = (params.get('dir')  || '').toUpperCase();
    if (!type) return null;
    const sample = buildSampleAnswersForType(type, dir);
    return sample;
  }, []);

  const [view, setView] = useState(sharedInit ? 'result' : 'home');
  const [answers, setAnswers] = useState(sharedInit || {});
  const [lastKarte, setLastKarte] = useState(() => loadLastKarte());
  const [reservationOpen, setReservationOpen] = useState(false);

  // 予約モーダルの開閉(イベント委譲で全てのトリガーに対応)
  useEffect(() => {
    const handler = (e) => {
      const trigger = e.target.closest('[data-open-resv]');
      if (trigger) { e.preventDefault(); setReservationOpen(true); }
    };
    document.addEventListener('click', handler);
    const esc = (e) => { if (e.key === 'Escape') setReservationOpen(false); };
    document.addEventListener('keydown', esc);
    return () => {
      document.removeEventListener('click', handler);
      document.removeEventListener('keydown', esc);
    };
  }, []);

  const start     = () => { setAnswers({}); setView('quiz'); };
  const startDeep = () => { setAnswers({}); setView('quizDeep'); };
  const resume = () => {
    if (!lastKarte) return;
    setAnswers(lastKarte.answersSnapshot || {});
    setView('result');
  };
  const complete = () => {
    setView('reveal');
    setTimeout(() => setView('result'), 2200);
  };
  const backHome = () => {
    setView('home');
    setLastKarte(loadLastKarte());
  };
  const restart = () => {
    setAnswers({});
    setView('home');
    setLastKarte(loadLastKarte());
  };
  const clearAndRestart = () => {
    clearLastKarte();
    setLastKarte(null);
    setAnswers({});
    setView('home');
  };
  // 既存ユーザーは前回のキャラから「履歴更新」モードへ。
  // 初めての方は picker mode で 18 体から選択 → 履歴入力サブフロー。
  const [pickerMode, setPickerMode] = useState(false);
  const openCollection = () => {
    setLastKarte(loadLastKarte());
    setPickerMode(false);
    setView('collection');
  };
  const openCharacterPicker = () => {
    setLastKarte(loadLastKarte());
    setPickerMode(true);
    setView('collection');
  };
  // キャラを picker で選んだ → 履歴中心の短いカルテへジャンプ
  const pickAsMine = (animal) => {
    setAnswers({ _knownOriginId: animal.id });
    setPickerMode(false);
    setView('quizDeep');
  };
  // Mode A 結果ページから Mode B へ。回答は引き継ぐ。
  const upgradeToDeep = () => { setView('quizDeep'); };

  const reservationEl = <ReservationModal open={reservationOpen} onClose={() => setReservationOpen(false)} />;

  if (view === 'home')       return <>{reservationEl}<Home onStart={start} onStartDeep={startDeep} lastKarte={lastKarte} onResume={resume} onClearLast={clearAndRestart} onCollection={openCharacterPicker} onLibrary={openCollection} /></>;
  if (view === 'quiz')       return <>{reservationEl}<Quiz answers={answers} setAnswers={setAnswers} onComplete={complete} onBackHome={backHome} /></>;
  if (view === 'quizDeep')   return <>{reservationEl}<QuizDeep answers={answers} setAnswers={setAnswers} onComplete={complete} onBackHome={backHome} /></>;
  if (view === 'reveal')     return <RevealLoader />;
  if (view === 'result')     return <>{reservationEl}<Result answers={answers} onRestart={restart} onCollection={openCollection} onDeepUpgrade={upgradeToDeep} /></>;
  if (view === 'collection') return <>{reservationEl}<Collection onBackHome={backHome} myKarte={lastKarte} onPickAsMine={pickerMode ? pickAsMine : undefined} /></>;
  return null;
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
  </script>
</body>
</html>
