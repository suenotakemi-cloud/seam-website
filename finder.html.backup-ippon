      >
        <header className="flex items-start justify-between gap-3 pb-3 border-b border-line">
          <div className="min-w-0">
            <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55">{animal.nameEn}</p>
            <p className="mt-0.5 font-mono tracking-widest2 text-[9.5px] uppercase text-gold">{animal.code}</p>
