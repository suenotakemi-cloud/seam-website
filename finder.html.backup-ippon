          </p>
        </div>

        <section className="mt-16 sm:mt-24 anim-fade-up" style={{ animationDelay: '240ms' }}>
          <div className="hairline-center">
            <span className="font-mono tracking-widest2 text-[10px] uppercase">Concept</span>
          </div>
          <div className="mt-10 sm:mt-12 grid sm:grid-cols-2 gap-10 sm:gap-16">
            <div>
              <h2 className="font-serif text-2xl sm:text-3xl text-ink leading-snug">髪は、履歴で変わる。</h2>
              <div className="mt-5 text-[13px] sm:text-[13.5px] leading-[2] text-charcoal/85">
                <p>今の髪は、今だけでできていない。</p>
                <p className="mt-3">ブリーチした日。縮毛矯正をかけた日。毎朝アイロンを通す習慣。伸ばしてきた毛先に残る、過去のダメージ。</p>
                <p className="mt-3">SEAM Hair Finder は、あなたの髪の履歴から、今必要なヘアケアを見つけます。</p>
              </div>
            </div>
            <div>
              <p className="font-mono tracking-widest2 text-[10px] uppercase text-gold">— How it works</p>
              <ol className="mt-4 border-t border-line">
                {[
                  ['01','髪の悩みと、なりたい質感を選ぶ'],
                  ['02','ブリーチ・カラー・縮毛矯正・パーマの履歴を答える'],
                  ['03','アイロン・コテの使用頻度と温度を答える'],
                  ['04','美容師の視点から、必要なケアルーティンを処方'],
                ].map(([n,t]) => (
                  <li key={n} className="border-b border-line py-3 flex items-baseline gap-4">
                    <span className="font-mono text-[10.5px] tracking-widest2 text-gold nums shrink-0">{n}</span>
                    <span className="text-[13px] sm:text-[13.5px] leading-[1.85] text-charcoal/85">{t}</span>
                  </li>
                ))}
              </ol>
            </div>
          </div>
        </section>
      </main>
      <footer className="relative z-10 py-8 text-center font-mono text-[10px] tracking-widest2 uppercase text-charcoal/40">
        SEAM · Salon Selection Store
      </footer>
    </div>
  );
}

/* ---------- ProgressBar ---------- */
function ProgressBar({ current, total }) {
  const pct = Math.max(0, Math.min(100, (current / total) * 100));
  return (
    <div className="w-full">
      <div className="h-px w-full bg-line/70 overflow-hidden">
        <div className="h-full bg-gold transition-all duration-500 ease-out" style={{ width: `${pct}%` }} aria-hidden />
      </div>
    </div>
  );
}

/* ---------- QuestionCard router ---------- */
function QuestionCard({ question, value, onChange }) {
  const { type } = question;
  if (type === 'chip-multi')      return <ChipMulti q={question} value={value} onChange={onChange} />;
  if (type === 'card-single')     return <CardSingle q={question} value={value} onChange={onChange} />;
  if (type === 'card-multi')      return <CardMulti q={question} value={value} onChange={onChange} />;
  if (type === 'slider')          return <SliderChoice q={question} value={value} onChange={onChange} />;
  if (type === 'check-multi')     return <CheckMulti q={question} value={value} onChange={onChange} />;
  if (type === 'carousel-single') return <CarouselSingle q={question} value={value} onChange={onChange} />;
  if (type === 'heat-tools')      return <HeatTools q={question} value={value || {}} onChange={onChange} />;
  if (type === 'card-history')    return <CardHistory q={question} value={value} onChange={onChange} />;
  return null;
}

/* ---- Chip multi (max N) — editorial square chips ---- */
function ChipMulti({ q, value = [], onChange }) {
  const max = q.max || 99;
  const toggle = (v) => {
    if (value.includes(v)) return onChange(value.filter(x => x !== v));
    if (value.length >= max) return;
    onChange([...value, v]);
  };
  return (
    <div>
      <div className="mt-1 flex items-baseline justify-between">
        <p className="font-mono tracking-widest2 text-[10.5px] uppercase text-charcoal/55">最大 {max} つまで</p>
        <p className="font-mono tracking-widest2 text-[10.5px] uppercase text-ink nums">
          <span className="text-ink">{String(value.length).padStart(2,'0')}</span>
          <span className="text-charcoal/35"> / {String(max).padStart(2,'0')}</span>
        </p>
      </div>
      <div className="mt-5 flex flex-wrap gap-1.5">
        {q.options.map(o => {
          const active = value.includes(o.v);
          const disabled = !active && value.length >= max;
          return (
            <button
              key={o.v}
              type="button"
              disabled={disabled}
              onClick={() => toggle(o.v)}
              className={[
                'group inline-flex items-center gap-2 px-3.5 py-2 text-[12.5px] sm:text-[13px] border transition-all rounded-[2px]',
                active
                  ? 'bg-ink text-ivory border-ink'
                  : 'bg-white/70 text-charcoal border-line hover:border-ink hover:text-ink',
                disabled ? 'opacity-35 cursor-not-allowed' : '',
              ].join(' ')}
            >
              <span
                className={[
                  'w-3 h-3 border inline-flex items-center justify-center rounded-[1px]',
                  active ? 'border-ivory bg-ivory' : 'border-line group-hover:border-ink',
                ].join(' ')}
                aria-hidden
              >
                {active && (
                  <svg viewBox="0 0 12 12" className="w-2.5 h-2.5">
                    <path d="M2 6.5 L 5 9 L 10 3" stroke="#1A1815" strokeWidth="1.5" fill="none" strokeLinecap="round" strokeLinejoin="round" />
                  </svg>
                )}
              </span>
              {o.label}
            </button>
          );
        })}
      </div>
    </div>
  );
}

/* ---- Card single — editorial list ---- */
function CardSingle({ q, value, onChange }) {
  return (
    <div className="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-1.5">
      {q.options.map((o, i) => {
        const active = value === o.v;
        return (
          <button
            key={o.v}
            type="button"
            onClick={() => onChange(o.v)}
            className={[
              'group text-left px-4 sm:px-5 py-3.5 border transition-all flex items-center gap-4 rounded-[2px]',
              active
                ? 'bg-ink text-ivory border-ink'
                : 'bg-white/70 text-charcoal border-line hover:border-ink',
            ].join(' ')}
          >
            <span className={['font-mono tracking-widest2 text-[10.5px] nums shrink-0',
              active ? 'text-goldLight' : 'text-charcoal/35'].join(' ')}>
              {String(i+1).padStart(2,'0')}
            </span>
            <span className="flex-1 min-w-0">
              <span className={['block font-serif text-[15.5px] sm:text-[16.5px] leading-snug',
                active ? 'text-ivory' : 'text-ink'].join(' ')}>{o.label}</span>
              {o.sub && (
                <span className={['block mt-0.5 text-[11px] tracking-wider',
                  active ? 'text-ivory/70' : 'text-charcoal/55'].join(' ')}>{o.sub}</span>
              )}
            </span>
            <span
              className={[
                'w-4 h-4 border inline-flex items-center justify-center shrink-0',
                active ? 'border-ivory bg-ivory rounded-[1px]' : 'border-line group-hover:border-ink rounded-[1px]',
              ].join(' ')}
              aria-hidden
            >
              {active && (
                <svg viewBox="0 0 12 12" className="w-2.5 h-2.5">
                  <path d="M2 6.5 L 5 9 L 10 3" stroke="#1A1815" strokeWidth="1.5" fill="none" strokeLinecap="round" strokeLinejoin="round" />
                </svg>
              )}
            </span>
          </button>
        );
      })}
    </div>
  );
}

/* ---- Card history (Yes/No → detail) ---- */
function CardHistory({ q, value, onChange }) {
  // value: undefined | 'none' | <detail value>
  const [yesIntent, setYesIntent] = useState(() => value && value !== 'none');
  const noneOpt = q.options.find(o => o.v === 'none');
  const detailOptions = q.options.filter(o => o.v !== 'none');

  const showDetails = yesIntent || (value && value !== 'none');
  const noActive    = value === 'none';
  const yesActive   = showDetails;

  const handleYes = () => {
    setYesIntent(true);
    if (value === 'none') onChange(undefined);
  };
  const handleNo = () => {
    setYesIntent(false);
    onChange('none');
  };

  return (
    <div className="mt-5">
      {/* Yes / No */}
      <div className="grid grid-cols-2 gap-1.5">
        <button
          type="button"
          onClick={handleYes}
          className={[
            'group px-4 sm:px-5 py-4 border transition-all flex items-center justify-between gap-3 rounded-[2px] text-left',
            yesActive ? 'bg-ink text-ivory border-ink' : 'bg-white/70 text-charcoal border-line hover:border-ink',
          ].join(' ')}
        >
          <span>
            <span className={['block font-mono tracking-widest2 text-[9.5px] uppercase mb-1',
              yesActive ? 'text-goldLight' : 'text-charcoal/45'].join(' ')}>Yes</span>
            <span className={['block font-serif text-[15.5px] sm:text-[16.5px]',
              yesActive ? 'text-ivory' : 'text-ink'].join(' ')}>履歴がある</span>
          </span>
          <span
            className={[
              'w-4 h-4 border inline-flex items-center justify-center shrink-0 rounded-[1px]',
              yesActive ? 'border-ivory bg-ivory' : 'border-line group-hover:border-ink',
            ].join(' ')}
            aria-hidden
          >
            {yesActive && (
              <svg viewBox="0 0 12 12" className="w-2.5 h-2.5">
                <path d="M2 6.5 L 5 9 L 10 3" stroke="#1A1815" strokeWidth="1.5" fill="none" strokeLinecap="round" strokeLinejoin="round" />
              </svg>
            )}
          </span>
        </button>

        <button
          type="button"
          onClick={handleNo}
          className={[
            'group px-4 sm:px-5 py-4 border transition-all flex items-center justify-between gap-3 rounded-[2px] text-left',
            noActive ? 'bg-ink text-ivory border-ink' : 'bg-white/70 text-charcoal border-line hover:border-ink',
          ].join(' ')}
        >
          <span>
            <span className={['block font-mono tracking-widest2 text-[9.5px] uppercase mb-1',
              noActive ? 'text-goldLight' : 'text-charcoal/45'].join(' ')}>No</span>
            <span className={['block font-serif text-[15.5px] sm:text-[16.5px]',
              noActive ? 'text-ivory' : 'text-ink'].join(' ')}>{(noneOpt && noneOpt.label) || 'していない'}</span>
          </span>
          <span
            className={[
              'w-4 h-4 border inline-flex items-center justify-center shrink-0 rounded-[1px]',
              noActive ? 'border-ivory bg-ivory' : 'border-line group-hover:border-ink',
            ].join(' ')}
            aria-hidden
          >
            {noActive && (
              <svg viewBox="0 0 12 12" className="w-2.5 h-2.5">
                <path d="M2 6.5 L 5 9 L 10 3" stroke="#1A1815" strokeWidth="1.5" fill="none" strokeLinecap="round" strokeLinejoin="round" />
              </svg>
            )}
          </span>
        </button>
      </div>

      {/* Detail options (only when Yes) */}
      {showDetails && (
        <div className="mt-6 anim-fade-up">
          <div className="flex items-center gap-3 mb-3">
            <span className="font-mono tracking-widest2 text-[10px] uppercase text-gold">— Detail</span>
            <span className="h-px flex-1 bg-line" />
          </div>
          {q.yesPrompt && (
            <p className="text-[12.5px] text-charcoal/70 mb-3 leading-relaxed">{q.yesPrompt}</p>
          )}
          <div className="grid grid-cols-1 sm:grid-cols-2 gap-1.5">
            {detailOptions.map((o, i) => {
              const active = value === o.v;
              return (
                <button
                  key={o.v}
                  type="button"
                  onClick={() => onChange(o.v)}
                  className={[
                    'group text-left px-4 sm:px-5 py-3.5 border transition-all flex items-center gap-4 rounded-[2px]',
                    active
                      ? 'bg-ink text-ivory border-ink'
                      : 'bg-white/70 text-charcoal border-line hover:border-ink',
                  ].join(' ')}
                >
                  <span className={['font-mono tracking-widest2 text-[10.5px] nums shrink-0',
                    active ? 'text-goldLight' : 'text-charcoal/35'].join(' ')}>
                    {String(i+1).padStart(2,'0')}
                  </span>
                  <span className={['flex-1 min-w-0 font-serif text-[15px] sm:text-[16px] leading-snug',
                    active ? 'text-ivory' : 'text-ink'].join(' ')}>
                    {o.label}
                  </span>
                  <span
                    className={[
                      'w-4 h-4 border inline-flex items-center justify-center shrink-0 rounded-[1px]',
                      active ? 'border-ivory bg-ivory' : 'border-line group-hover:border-ink',
                    ].join(' ')}
                    aria-hidden
                  >
                    {active && (
                      <svg viewBox="0 0 12 12" className="w-2.5 h-2.5">
                        <path d="M2 6.5 L 5 9 L 10 3" stroke="#1A1815" strokeWidth="1.5" fill="none" strokeLinecap="round" strokeLinejoin="round" />
                      </svg>
                    )}
                  </span>
                </button>
              );
            })}
          </div>
        </div>
      )}
    </div>
  );
}

/* ---- Card multi (with exclusive option) — editorial tiles ---- */
function CardMulti({ q, value = [], onChange }) {
  const toggle = (o) => {
    if (o.exclusive) {
      return onChange(value.includes(o.v) ? [] : [o.v]);
    }
    const next = value.includes(o.v)
      ? value.filter(x => x !== o.v)
      : [...value.filter(x => !q.options.find(p => p.v === x)?.exclusive), o.v];
    onChange(next);
  };
  return (
    <div className="mt-5 grid grid-cols-2 sm:grid-cols-3 gap-1.5">
      {q.options.map((o, i) => {
        const active = value.includes(o.v);
        return (
          <button
            key={o.v}
            type="button"
            onClick={() => toggle(o)}
            className={[
              'group text-left px-3.5 py-3.5 border transition-all flex flex-col gap-2.5 rounded-[2px]',
              active
                ? 'bg-ink text-ivory border-ink'
                : 'bg-white/70 text-charcoal border-line hover:border-ink',
            ].join(' ')}
          >
            <div className="flex items-center justify-between">
              <span className={['font-mono tracking-widest2 text-[9.5px] nums',
                active ? 'text-goldLight' : 'text-charcoal/40'].join(' ')}>
                {String(i+1).padStart(2,'0')}
              </span>
              <span
                className={[
                  'w-[14px] h-[14px] border inline-flex items-center justify-center rounded-[1px]',
                  active ? 'border-ivory bg-ivory' : 'border-line group-hover:border-ink',
                ].join(' ')}
                aria-hidden
              >
                {active && (
                  <svg viewBox="0 0 12 12" className="w-2.5 h-2.5">
                    <path d="M2 6.5 L 5 9 L 10 3" stroke="#1A1815" strokeWidth="1.5" fill="none" strokeLinecap="round" strokeLinejoin="round" />
                  </svg>
                )}
              </span>
            </div>
            <span className={['font-serif text-[13.5px] sm:text-[14.5px] leading-snug',
              active ? 'text-ivory' : 'text-ink'].join(' ')}>{o.label}</span>
          </button>
        );
      })}
    </div>
  );
}

/* ---- Slider (3-step) — editorial dial ---- */
function SliderChoice({ q, value, onChange }) {
  const idx = q.options.findIndex(o => o.v === value);
  const display = q.options[idx >= 0 ? idx : 1];
  return (
    <div className="mt-8">
      <div className="text-center mb-9">
        <p className="font-mono tracking-widest2 text-[10px] uppercase text-charcoal/50">— Now selecting —</p>
        <p className="mt-3 font-serif text-[40px] sm:text-[52px] leading-none text-ink tracking-tight">
          {value ? display.label : '—'}
        </p>
      </div>
      <input
        type="range"
        min={0}
        max={q.options.length - 1}
        step={1}
        value={idx < 0 ? 1 : idx}
        onChange={(e) => onChange(q.options[Number(e.target.value)].v)}
        className="seam-slider"
      />
      <div className="mt-4 grid grid-cols-3 gap-2 text-[11px] tracking-widest2 uppercase text-charcoal/55">
        {q.options.map((o, i) => (
          <button
            key={o.v}
            type="button"
            onClick={() => onChange(o.v)}
            className={[
              'border-t pt-2 transition-colors text-center',
              i === 0 ? 'text-left' : i === q.options.length - 1 ? 'text-right' : 'text-center',
              value === o.v ? 'text-ink border-ink' : 'border-line hover:text-ink/80',
            ].join(' ')}
          >
            {o.label}
          </button>
        ))}
      </div>
    </div>
  );
}

/* ---- Heat tools (frequency + temperature with inline warnings) ---- */
function HeatTools({ q, value, onChange }) {
  const tools = value.tools || [];
  const temp  = value.temp;

  const toggleTool = (o) => {
    if (o.exclusive) {
      const next = tools.includes(o.v) ? [] : [o.v];
      onChange({ ...value, tools: next });
      return;
    }
    const next = tools.includes(o.v)
      ? tools.filter(x => x !== o.v)
      : [...tools.filter(x => !q.toolOptions.find(p => p.v === x)?.exclusive), o.v];
    onChange({ ...value, tools: next });
  };

  const setTemp = (v) => onChange({ ...value, temp: v });

  return (
    <div className="mt-6 space-y-8">
      {/* Section 1 — frequency */}
      <div>
        <div className="flex items-baseline justify-between mb-3">
          <p className="font-mono tracking-widest2 text-[10.5px] uppercase text-ink/80">— 01 — Frequency</p>
          <p className="text-[10.5px] tracking-wider text-charcoal/55">複数選択可</p>
        </div>
        <ul className="border-t border-line">
          {q.toolOptions.map((o, i) => {
            const active = tools.includes(o.v);
            return (
              <li key={o.v} className="border-b border-line">
                <button
                  type="button"
                  onClick={() => toggleTool(o)}
                  className="w-full flex items-center gap-4 py-3.5 text-left group"
                >
                  <span className="font-mono text-[10.5px] tracking-widest2 text-charcoal/45 nums w-6">{String(i+1).padStart(2,'0')}</span>
                  <span
                    className={[
                      'w-[18px] h-[18px] rounded-[3px] border inline-flex items-center justify-center shrink-0 transition-colors',
                      active ? 'bg-ink border-ink' : 'bg-white border-line group-hover:border-ink',
                    ].join(' ')}
                    aria-hidden
                  >
                    {active && (
                      <svg viewBox="0 0 14 14" className="w-3 h-3" fill="none">
                        <path d="M2.5 7.5 L 6 11 L 12 3" stroke="#FAF8F4" strokeWidth="1.6" strokeLinecap="round" strokeLinejoin="round" />
                      </svg>
                    )}
                  </span>
                  <span className={['font-serif text-[15px] sm:text-[16px] flex-1', active ? 'text-ink' : 'text-charcoal group-hover:text-ink'].join(' ')}>
                    {o.label}
                  </span>
                </button>
              </li>
            );
          })}
        </ul>
      </div>

      {/* Section 2 — temperature (「ほとんど使わない」を選んだ場合はスキップ) */}
      {!tools.includes('rare') && (
      <div>
        <div className="flex items-baseline justify-between mb-3">
          <p className="font-mono tracking-widest2 text-[10.5px] uppercase text-ink/80">— 02 — Iron Temperature</p>
          <p className="text-[10.5px] tracking-wider text-charcoal/55">いつも使う温度を1つ</p>
        </div>
        <p className="font-serif text-[15px] sm:text-[16px] text-ink leading-snug mt-2">普段、ヘアアイロンは何℃くらいで使用していますか？</p>
        <p className="text-[12px] text-charcoal/70 leading-[1.85] mt-1.5 mb-5">熱ダメージやカラー褪色の可能性をふまえて、必要なケアを診断します。</p>
        <div className="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {q.tempOptions.map(o => {
            const active = temp === o.v;
            const isWarn180 = o.v === 't180';
            const isWarn200 = o.v === 't200';
            return (
              <button
                key={o.v}
                type="button"
                onClick={() => setTemp(o.v)}
                className={[
                  'group text-left px-4 py-3.5 border transition-all flex items-start gap-3 rounded-sm',
                  active
                    ? 'bg-ink text-ivory border-ink'
                    : 'bg-white text-charcoal border-line hover:border-ink',
                ].join(' ')}
              >
                <span
                  className={[
                    'mt-0.5 w-[18px] h-[18px] rounded-full border inline-flex items-center justify-center shrink-0',
                    active ? 'border-ivory bg-ivory' : 'border-line group-hover:border-ink',
                  ].join(' ')}
                >
                  {active && <span className="w-2 h-2 rounded-full bg-ink" />}
                </span>
                <span className="flex-1">
                  <span className="flex items-center gap-2">
                    <span className={['font-serif text-[16px] nums', active ? 'text-ivory' : 'text-ink'].join(' ')}>{o.label}</span>
                    {isWarn180 && (
                      <span className={['font-mono tracking-widest2 text-[9.5px] uppercase px-1.5 py-0.5 rounded-sm border',
                        active ? 'text-goldLight border-goldLight/60' : 'text-gold border-gold/40'].join(' ')}>Caution</span>
                    )}
                    {isWarn200 && (
                      <span className={['font-mono tracking-widest2 text-[9.5px] uppercase px-1.5 py-0.5 rounded-sm',
                        active ? 'text-ink bg-goldLight' : 'text-ivory bg-gold'].join(' ')}>Warning</span>
                    )}
                  </span>
                  <span className={['block mt-1 text-[11.5px] leading-snug', active ? 'text-ivory/75' : 'text-charcoal/60'].join(' ')}>
                    {o.detail}
                  </span>
                </span>
              </button>
            );
          })}
        </div>

        {/* Live warning callout */}
        {temp === 't180' && (
          <p className="mt-4 text-[12px] leading-[1.85] text-charcoal/80 pl-3 border-l border-gold">
            <span className="font-mono tracking-widest2 text-[10px] uppercase text-gold mr-2">Note</span>
            180°C以上では、ヘアカラーが熱で褪色しやすくなります。<br />特にアッシュ・マット・グレーなどの寒色系は、ワンランク下の温度で短時間スルーがおすすめです。
          </p>
        )}
        {temp === 't200' && (
          <div className="mt-4 text-[12.5px] leading-[1.9] text-ink/90 pl-4 border-l-[2px] border-gold bg-cream/60 py-3.5 pr-3.5 rounded-sm">
            <p className="flex items-center gap-2 mb-1.5">
              <span className="font-mono tracking-widest2 text-[10px] uppercase text-ink bg-goldLight px-1.5 py-0.5 rounded-sm">Warning</span>
              <span className="font-serif text-[13.5px] text-ink">サロン施術前は、必ず美容師へ申告を</span>
            </p>
            <p>
              高温アイロンの使用履歴がある髪は、見た目以上に熱ダメージが蓄積している場合があります。
              ブリーチ・縮毛矯正などの薬剤施術時に、切れ毛・縮れ・ビビり毛につながる可能性があるため、施術前に必ず美容師へお伝えください。
            </p>
          </div>
        )}
      </div>
      )}
      {/* 「ほとんど使わない」を選んだ人への一言 */}
      {tools.includes('rare') && (
        <div className="text-[12.5px] leading-[1.85] text-charcoal/75 pl-3 border-l border-gold">
          <p>アイロン熱の心配はほとんどありません。次へお進みください。</p>
        </div>
      )}
    </div>
  );
}

/* ---- Check multi — editorial line list ---- */
function CheckMulti({ q, value = [], onChange }) {
  const toggle = (o) => {
    if (o.exclusive) return onChange(value.includes(o.v) ? [] : [o.v]);
    const next = value.includes(o.v)
      ? value.filter(x => x !== o.v)
      : [...value.filter(x => !q.options.find(p => p.v === x)?.exclusive), o.v];
    onChange(next);
  };
  return (
    <ul className="mt-5 border-t border-line">
      {q.options.map((o, i) => {
        const active = value.includes(o.v);
        return (
          <li key={o.v} className="border-b border-line">
            <button
              type="button"
              onClick={() => toggle(o)}
              className="group w-full flex items-center gap-4 py-3.5 text-left"
            >
              <span className="font-mono tracking-widest2 text-[10.5px] text-charcoal/40 nums w-6">{String(i+1).padStart(2,'0')}</span>
              <span
                className={[
                  'w-[18px] h-[18px] border inline-flex items-center justify-center shrink-0 rounded-[1px] transition-colors',
                  active ? 'bg-ink border-ink' : 'bg-white border-line group-hover:border-ink',
                ].join(' ')}
                aria-hidden
              >
                {active && (
                  <svg viewBox="0 0 14 14" className="w-3 h-3" fill="none">
                    <path d="M2.5 7.5 L 6 11 L 12 3" stroke="#FAF8F4" strokeWidth="1.6" strokeLinecap="round" strokeLinejoin="round" />
                  </svg>
                )}
              </span>
              <span className={['font-serif text-[14.5px] sm:text-[15.5px] flex-1',
                active ? 'text-ink' : 'text-charcoal group-hover:text-ink'].join(' ')}>{o.label}</span>
            </button>
          </li>
        );
      })}
    </ul>
  );
}

/* ---- Texture visual SVG for carousel ---- */
function TextureVisual({ visual, active }) {
  const stroke = active ? '#FAF8F4' : '#1A1815';
  const accent = active ? '#D9BE93' : '#C9A089';
  const fillBody = active ? '#3D3833' : '#F4F0E8';
  const common = { fill: 'none', stroke, strokeWidth: 1.2, strokeLinecap: 'round' };
  let body = null;
  if (visual === 'moist') {
    body = (
      <g>
        <path d="M30 30 Q 50 10 70 30 L 70 90 Q 50 100 30 90 Z" fill={fillBody} stroke={stroke} />
        <path {...common} d="M40 40 C 45 55 45 70 40 88" />
        <path {...common} d="M50 38 C 55 56 55 72 50 90" />
        <path {...common} d="M60 40 C 55 55 55 70 60 88" />
      </g>
    );
  } else if (visual === 'glossy') {
    body = (
      <g>
        <path d="M30 30 Q 50 10 70 30 L 70 90 Q 50 100 30 90 Z" fill={fillBody} stroke={stroke} />
        <path d="M44 36 Q 50 35 56 36 L 54 86 Q 50 88 46 86 Z" fill={accent} opacity="0.55" />
        <path {...common} d="M40 40 L 40 88" />
        <path {...common} d="M60 40 L 60 88" />
      </g>
    );
  } else if (visual === 'firm') {
    body = (
      <g>
        <path d="M30 30 Q 50 18 70 30 L 70 90 Q 50 96 30 90 Z" fill={fillBody} stroke={stroke} />
        <path {...common} d="M38 36 L 38 90" />
        <path {...common} d="M46 34 L 46 92" />
        <path {...common} d="M54 34 L 54 92" />
        <path {...common} d="M62 36 L 62 90" />
      </g>
    );
  } else if (visual === 'smooth') {
    body = (
      <g>
        <path d="M28 30 Q 50 14 72 30 L 70 92 Q 50 96 30 92 Z" fill={fillBody} stroke={stroke} />
        <path {...common} d="M36 38 L 36 90" />
        <path {...common} d="M44 36 L 44 92" />
        <path {...common} d="M52 36 L 52 92" />
        <path {...common} d="M60 36 L 60 92" />
        <path {...common} d="M68 38 L 68 90" />
      </g>
    );
  } else if (visual === 'airy') {
    body = (
      <g>
        <path d="M22 36 Q 50 4 78 36 L 76 88 Q 50 100 24 88 Z" fill={fillBody} stroke={stroke} />
        <path {...common} d="M34 44 Q 30 60 36 80" />
        <path {...common} d="M48 42 Q 44 62 50 84" />
        <path {...common} d="M62 44 Q 66 62 60 80" />
      </g>
    );
  } else {
    body = (
      <g>
        <path d="M30 32 Q 50 16 70 32 L 70 90 Q 50 96 30 90 Z" fill={fillBody} stroke={stroke} />
        <path {...common} d="M40 38 Q 36 58 42 86" />
        <path {...common} d="M50 36 Q 52 58 48 88" />
        <path {...common} d="M60 38 Q 64 58 58 86" />
      </g>
    );
  }
  return (
    <svg viewBox="0 0 100 110" width="100%" height="100%" aria-hidden>
      {body}
    </svg>
  );
}

function CarouselSingle({ q, value, onChange }) {
  return (
    <div className="mt-5 -mx-5 sm:-mx-8">
      <div className="snap-x-row no-scrollbar flex gap-3 px-5 sm:px-8 overflow-x-auto pb-4">
        {q.options.map((o, i) => {
          const active = value === o.v;
          return (
            <button
              key={o.v}
              type="button"
              onClick={() => onChange(o.v)}
              className={[
                'shrink-0 w-[58%] sm:w-[42%] aspect-[4/5] border transition-all p-5 flex flex-col items-stretch justify-between rounded-[2px]',
                active
                  ? 'bg-ink text-ivory border-ink'
                  : 'bg-white/80 text-charcoal border-line hover:border-ink',
              ].join(' ')}
            >
              <div className="flex items-baseline justify-between">
                <span className={['font-mono tracking-widest2 text-[9.5px] uppercase',
                  active ? 'text-goldLight' : 'text-charcoal/50'].join(' ')}>
                  Texture
                </span>
                <span className={['font-mono tracking-widest2 text-[9.5px] nums',
                  active ? 'text-goldLight' : 'text-charcoal/40'].join(' ')}>
                  / {String(i+1).padStart(2,'0')}
                </span>
              </div>
              <div className="w-[55%] mx-auto flex-1 flex items-center justify-center my-2">
                <TextureVisual visual={o.visual} active={active} />
              </div>
              <span className={['font-serif text-[14.5px] sm:text-[15.5px] leading-tight text-center',
                active ? 'text-ivory' : 'text-ink'].join(' ')}>
                {o.label}
              </span>
            </button>
          );
        })}
      </div>
      <p className="px-5 sm:px-8 font-mono tracking-widest2 text-[10px] uppercase text-charcoal/45 mt-1">— Swipe —</p>
    </div>
  );
}

/* ---------- 章立て ---------- */
const QUIZ_CHAPTERS = [
  { id:'now',     index:1, title:'髪の悩みと特徴',     subTitle:'まず、いまの悩みと髪のタイプを伺います。',         startIdx:0,  endIdx:4  },
  { id:'history', index:2, title:'髪の履歴',           subTitle:'これまでの施術と、アイロンの使い方を伺います。',   startIdx:5,  endIdx:9  },
  { id:'daily',   index:3, title:'いまの生活',         subTitle:'普段の習慣と、まわりの環境を伺います。',           startIdx:10, endIdx:13 },
  { id:'goal',    index:4, title:'目指したい仕上がり', subTitle:'これから目指したい髪を伺います。',                 startIdx:14, endIdx:15 },
  { id:'salon',   index:5, title:'サロンでの相談',     subTitle:'ヘッドスパなど、サロンでのご提案について伺います。', startIdx:16, endIdx:17 },
];
function getChapterFor(idx) {
  return QUIZ_CHAPTERS.find(c => idx >= c.startIdx && idx <= c.endIdx) || QUIZ_CHAPTERS[0];
}
function isChapterStart(idx) {
  return QUIZ_CHAPTERS.some(c => c.startIdx === idx);
}

/* ---------- Quiz ---------- */
function isAnswered(q, val) {
  if (val == null) return false;
  if (q.type === 'heat-tools') {
    const tools = (val && val.tools) || [];
    const temp  = val && val.temp;
    // 「ほとんど使わない」を選んだ場合は温度設定不要
    if (tools.includes('rare')) return true;
    return tools.length > 0 && !!temp;
  }
  if (Array.isArray(val)) return val.length > 0;
  return true;
}

function buildModeASequence(answers) {
  return Q
    .map((q, i) => ({ q, originalIdx: i }))
    .filter(({ q }) => {
      if (typeof q.when !== 'function') return true;
      try { return !!q.when(answers); } catch (e) { return true; }
    });
}

function Quiz({ answers, setAnswers, onComplete, onBackHome }) {
  const sequence = useMemo(() => buildModeASequence(answers), [answers]);
  const total = sequence.length;
  const [idx, setIdx] = useState(0);
  const safeIdx = Math.min(idx, total - 1);
  const entry = sequence[safeIdx];
  const q = entry?.q;
  const value = q ? answers[q.id] : null;
  const valid = q ? isAnswered(q, value) : false;
  const chapter = entry ? getChapterFor(entry.originalIdx) : QUIZ_CHAPTERS[0];

  // この設問が章の最初に表示されるかを、現在のシーケンスから判定
  const showChapterIntro = useMemo(() => {
    if (!entry) return false;
    const firstInChapter = sequence.find(e => getChapterFor(e.originalIdx)?.id === chapter.id);
    return firstInChapter && firstInChapter.q.id === entry.q.id;
  }, [entry, sequence, chapter]);

  const setValue = (v) => setAnswers(prev => ({ ...prev, [q.id]: v }));

  const next = () => {
    if (!valid) return;
    if (safeIdx >= total - 1) onComplete();
    else setIdx(safeIdx + 1);
  };
  const back = () => {
    if (safeIdx === 0) onBackHome();
    else setIdx(safeIdx - 1);
  };

  useEffect(() => { window.scrollTo({ top: 0, behavior: 'instant' }); }, [safeIdx]);

  if (!q) return null;

  return (
    <div className="min-h-[100svh] bg-finder relative pb-32 sm:pb-36">
      <TopBar step={safeIdx + 1} total={total} />
      <div className="pt-[78px]">
        <ProgressBar current={safeIdx + 1} total={total} />
      </div>

      <main className="mx-auto max-w-2xl px-5 sm:px-8 pt-8 sm:pt-14 relative z-10">
        <div key={q.id} className="anim-quiz">
          {/* Chapter marker */}
          <div className="flex items-center gap-3 mb-6 sm:mb-8">
            <span className={`font-mono tracking-widest2 text-[9.5px] uppercase text-gold nums inline-block ${showChapterIntro ? 'milestone-pulse' : ''} px-2 py-0.5`}>
              Chapter {String(chapter.index).padStart(2,'0')}
            </span>
            <span className="h-px w-6 bg-gold/40" />
            <span className="font-serif text-[13px] sm:text-[14px] text-charcoal">
              {chapter.title}
            </span>
          </div>

          {showChapterIntro && (
            <div className="anim-quiz mb-7 sm:mb-9 border-l-2 border-gold pl-4 sm:pl-5" style={{ animationDelay:'120ms' }}>
              <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55">
                ━ {chapter.id === 'now' ? 'はじめに' : `Chapter ${String(chapter.index).padStart(2,'0')}`} ━
              </p>
              <p className="mt-2 text-[13.5px] sm:text-[15px] text-ink leading-[1.85]">
                {chapter.subTitle}
              </p>
            </div>
          )}

          {/* Editorial Q header */}
          <div className="flex items-start gap-5 sm:gap-7">
            <div className="shrink-0 -mt-1">
              <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55 mb-1">Question</p>
              <p className="font-serif text-[44px] sm:text-[58px] leading-none text-ink nums tracking-tight">
                {String(safeIdx + 1).padStart(2,'0')}
              </p>
              <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/40 mt-1 nums">
                / {String(total).padStart(2,'0')}
              </p>
            </div>
            <div className="flex-1 min-w-0 pt-1">
              <p className="font-mono tracking-widest2 text-[10.5px] uppercase text-gold mb-2">— {q.eyebrow}</p>
              <h2 className="font-serif text-[22px] sm:text-[28px] leading-[1.4] text-ink">
                {q.title}
              </h2>
            </div>
          </div>
          <div className="mt-5 h-px bg-line" />
          {q.note && <p className="mt-4 text-[12.5px] sm:text-[13px] text-charcoal/70 leading-[1.85]">{q.note}</p>}

          <QuestionCard question={q} value={value} onChange={setValue} />
        </div>
      </main>

      <nav className="fixed bottom-0 inset-x-0 bg-gradient-to-t from-ivory via-ivory/95 to-ivory/0 pt-6 pb-5 sm:pb-7 z-20">
        <div className="mx-auto max-w-2xl px-5 sm:px-8 flex items-center justify-between gap-4">
          <button
            onClick={back}
            className="font-mono tracking-widest2 text-[10.5px] sm:text-[11px] uppercase text-charcoal/65 hover:text-ink transition-colors inline-flex items-center gap-2"
          >
            <span className="inline-block w-5 h-px bg-charcoal/40" />
            {safeIdx === 0 ? 'Home' : 'Back'}
          </button>
          <button
            onClick={next}
            disabled={!valid}
            className={[
              'inline-flex items-center justify-center gap-3 px-6 sm:px-9 py-3.5 sm:py-4 rounded-[2px] font-mono text-[10.5px] sm:text-[11px] tracking-widest2 uppercase transition-all',
              valid
                ? 'bg-ink text-ivory hover:bg-charcoal'
                : 'bg-mist text-charcoal/40 cursor-not-allowed',
            ].join(' ')}
          >
            <span className={valid ? 'text-goldLight' : 'text-charcoal/40'}>
              {safeIdx >= total - 1 ? 'Submit' : 'Next'}
            </span>
            <span className="font-serif normal-case tracking-normal text-[13px] sm:text-[14px]">
              {safeIdx >= total - 1 ? '診断結果を見る' : '次へ'}
            </span>
            <span className={['inline-block w-4 h-px transition-all', valid ? 'bg-ivory' : 'bg-charcoal/30'].join(' ')} />
          </button>
        </div>
      </nav>
    </div>
  );
}

/* ---------- QuizDeep — Mode B 詳しいカルテ ---------- */
function QuizDeep({ answers, setAnswers, onComplete, onBackHome }) {
  // 動的シーケンス: 回答に応じて条件分岐をスキップ
  const sequence = useMemo(() => buildModeBSequence(answers), [answers]);
  const total = sequence.length;
  const [idx, setIdx] = useState(0);
  const safeIdx = Math.min(idx, total - 1);
  const entry = sequence[safeIdx];
  const q = entry ? QUESTION_LOOKUP[entry.id] : null;
  const value = q ? answers[q.id] : null;
  const valid = q ? isAnswered(q, value) : false;

  const stepInfo = MODE_B_STEPS.find(s => s.index === (entry?.step || 1)) || MODE_B_STEPS[0];

  // この設問が、その step の最初に表示される設問かどうか
  const isStepStart = useMemo(() => {
    if (!entry) return false;
    const firstOfStep = sequence.find(e => e.step === entry.step);
    return firstOfStep && firstOfStep.id === entry.id;
  }, [entry, sequence]);

  const setValue = (v) => setAnswers(prev => ({ ...prev, [q.id]: v }));

  const next = () => {
    if (!valid) return;
    if (safeIdx >= total - 1) onComplete();
    else setIdx(safeIdx + 1);
  };
  const back = () => {
    if (safeIdx === 0) onBackHome();
    else setIdx(safeIdx - 1);
  };

  useEffect(() => { window.scrollTo({ top: 0, behavior: 'instant' }); }, [safeIdx]);

  if (!q) return null;

  return (
    <div className="min-h-[100svh] bg-finder relative pb-32 sm:pb-36">
      <TopBar step={safeIdx + 1} total={total} />
      <div className="pt-[78px]">
        <ProgressBar current={safeIdx + 1} total={total} />
      </div>

      <main className="mx-auto max-w-2xl px-5 sm:px-8 pt-8 sm:pt-14 relative z-10">
        <div key={q.id} className="anim-fade-up">
          {/* STEP marker */}
          <div className="flex items-center gap-3 mb-6 sm:mb-8">
            <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-gold nums">
              STEP {String(stepInfo.index).padStart(2,'0')}
            </span>
            <span className="h-px w-6 bg-gold/40" />
            <span className="font-serif text-[13px] sm:text-[14px] text-charcoal">
              {stepInfo.title}
            </span>
            <span className="ml-auto font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/45">
              詳しいカルテ
            </span>
          </div>

          {isStepStart && (
            <div className="anim-fade-up mb-7 sm:mb-9 border-l-2 border-gold pl-4 sm:pl-5">
              <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55">
                ━ STEP {String(stepInfo.index).padStart(2,'0')} ━
              </p>
              <p className="mt-2 font-serif text-[15px] sm:text-[17px] text-ink leading-[1.85]">
                {stepInfo.desc}
              </p>
            </div>
          )}

          {/* Editorial Q header */}
          <div className="flex items-start gap-5 sm:gap-7">
            <div className="shrink-0 -mt-1">
              <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55 mb-1">Question</p>
              <p className="font-serif text-[44px] sm:text-[58px] leading-none text-ink nums tracking-tight">
                {String(safeIdx + 1).padStart(2,'0')}
              </p>
              <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/40 mt-1 nums">
                / {String(total).padStart(2,'0')}
              </p>
            </div>
            <div className="flex-1 min-w-0 pt-1">
              <p className="font-mono tracking-widest2 text-[10.5px] uppercase text-gold mb-2">— {q.eyebrow}</p>
              <h2 className="font-serif text-[22px] sm:text-[28px] leading-[1.4] text-ink">
                {q.title}
              </h2>
            </div>
          </div>
          <div className="mt-5 h-px bg-line" />
          {q.note && <p className="mt-4 text-[12.5px] sm:text-[13px] text-charcoal/70 leading-[1.85]">{q.note}</p>}

          <QuestionCard question={q} value={value} onChange={setValue} />
        </div>
      </main>

      <nav className="fixed bottom-0 inset-x-0 bg-gradient-to-t from-ivory via-ivory/95 to-ivory/0 pt-6 pb-5 sm:pb-7 z-20">
        <div className="mx-auto max-w-2xl px-5 sm:px-8 flex items-center justify-between gap-4">
          <button
            onClick={back}
            className="font-mono tracking-widest2 text-[10.5px] sm:text-[11px] uppercase text-charcoal/65 hover:text-ink transition-colors inline-flex items-center gap-2"
          >
            <span className="inline-block w-5 h-px bg-charcoal/40" />
            {safeIdx === 0 ? 'Home' : 'Back'}
          </button>
          <button
            onClick={next}
            disabled={!valid}
            className={[
              'inline-flex items-center justify-center gap-3 px-6 sm:px-9 py-3.5 sm:py-4 rounded-[2px] font-mono text-[10.5px] sm:text-[11px] tracking-widest2 uppercase transition-all',
              valid
                ? 'bg-ink text-ivory hover:bg-charcoal'
                : 'bg-mist text-charcoal/40 cursor-not-allowed',
            ].join(' ')}
          >
            <span className={valid ? 'text-goldLight' : 'text-charcoal/40'}>
              {safeIdx >= total - 1 ? 'Submit' : 'Next'}
            </span>
            <span className="font-serif normal-case tracking-normal text-[13px] sm:text-[14px]">
              {safeIdx >= total - 1 ? '詳しい結果を見る' : '次へ'}
            </span>
            <span className={['inline-block w-4 h-px transition-all', valid ? 'bg-ivory' : 'bg-charcoal/30'].join(' ')} />
          </button>
        </div>
      </nav>
    </div>
  );
}

/* ---------- HairChart ---------- */
function HairChart({ chart }) {
  const entries = Object.entries(chart);
  return (
    <div className="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-5">
      {entries.map(([label, v]) => {
        const pct = (v / 5) * 100;
        const level = levelLabel(v);
        const tone = level === 'Keep' ? 'text-charcoal/70' : level === 'Care' ? 'text-roseAccent' : 'text-gold';
        const barColor = level === 'Intensive Care' ? '#B8945A' : level === 'Care' ? '#C9A089' : '#3D3833';
        return (
          <div key={label}>
            <div className="flex items-baseline justify-between">
              <span className="font-serif text-[14.5px] text-ink">{label}</span>
              <span className={`font-mono tracking-widest2 text-[10.5px] uppercase ${tone}`}>{level}</span>
            </div>
            <div className="mt-2 h-px bg-line/80 relative">
              <div
                className="absolute left-0 anim-bar"
                style={{
                  width: `${Math.max(4, pct)}%`,
                  background: barColor,
                  height: '2px',
                  top: '-0.5px',
                }}
              />
            </div>
            <div className="mt-1.5 flex justify-between text-[10px] tracking-widest2 uppercase text-charcoal/35 nums">
              <span>0</span><span>1</span><span>2</span><span>3</span><span>4</span><span>5</span>
            </div>
          </div>
        );
      })}
    </div>
  );
}

/* ---------- StoreCard — editorial card with image ---------- */
function StoreCard({ store, index }) {
  return (
    <article className="bg-white border border-line rounded-[12px] overflow-hidden shadow-soft flex flex-col">
      {/* Store photo */}
      {store.image && (
        <div className="aspect-[4/3] bg-cover bg-center overflow-hidden">
          <div
            className="w-full h-full bg-cover bg-center"
            style={{ backgroundImage: `url(${store.image})` }}
            aria-label={store.name}
          />
        </div>
      )}

      <div className="px-5 py-4 sm:py-5 flex-1 flex flex-col">
        <header className="flex items-start justify-between gap-3">
          <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-gold">
            {store.area}
          </span>
          <span className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/40 nums">
            {String(index + 1).padStart(2, '0')}
          </span>
        </header>

        <h3 className="mt-1 font-serif text-[16px] sm:text-[18px] text-ink leading-snug">{store.name}</h3>

        <dl className="mt-3 text-[11.5px] leading-[1.7] text-charcoal/75 space-y-1 flex-1">
          <div className="flex gap-2">
            <dt className="text-charcoal/50 shrink-0">所在地</dt>
            <dd>{store.address}</dd>
          </div>
          <div className="flex gap-2">
            <dt className="text-charcoal/50 shrink-0">アクセス</dt>
            <dd>{store.station}</dd>
          </div>
        </dl>

        {store.features && store.features.length > 0 && (
          <div className="mt-3 pt-3 border-t border-line/60 flex flex-wrap gap-1">
            {store.features.map(f => (
              <span key={f} className="font-mono tracking-widest2 text-[8.5px] uppercase px-2 py-0.5 bg-cream/50 text-charcoal/65 rounded-full">
                {f}
              </span>
            ))}
          </div>
        )}
      </div>
    </article>
  );
}

const KARTE_AXES = [
  { key:'lightness',  label:'透明感' },
  { key:'luster',     label:'艶' },
  { key:'smoothness', label:'まとまり' },
  { key:'volume',     label:'華やぎ' },
