const Q_DEEP_BY_ID = Object.fromEntries(Q_DEEP_NEW.map(q => [q.id, q]));
const Q_BY_ID      = Object.fromEntries(Q.map(q => [q.id, q]));
const QUESTION_LOOKUP = { ...Q_BY_ID, ...Q_DEEP_BY_ID };

const MODE_B_ORDER = [
  // STEP 1 — もともとの個性
  { step:1, id:'age' },
  { step:1, id:'gender' },
  { step:1, id:'length' },
  { step:1, id:'thickness' },
  { step:1, id:'density' },
  { step:1, id:'rootVolume' },
  { step:1, id:'wave' },
  { step:1, id:'scalpType' },
  { step:1, id:'scalpSensitivity' },

  // STEP 2 — 髪の履歴
  { step:2, id:'color' },
  { step:2, id:'colorFreq',       when:(a) => a.color && a.color !== 'none' },
  // カラーをしている人にだけ「白髪染め」を聞く(していない場合はスキップ)
  { step:2, id:'grayHair',        when:(a) => a.color && a.color !== 'none' },
  { step:2, id:'grayFreq',        when:(a) => a.grayHair === 'yes' },
  { step:2, id:'bleachLocation',  when:(a) => /^(multi_bleach|bleach_recent|bleach_past|highlight)$/.test(a.color || '') },
  { step:2, id:'straighten' },
  { step:2, id:'perm' },
  { step:2, id:'permType',        when:(a) => a.perm && a.perm !== 'none' },
  { step:2, id:'permLoose',       when:(a) => a.perm && a.perm !== 'none' && a.perm !== 'past' },
  { step:2, id:'styling' },
  { step:2, id:'heatProtect' },
  // 美容師さんに必ず申告したい項目
  { step:2, id:'scalpAllergy' },
  { step:2, id:'hairTrouble' },

  // STEP 3 — いまと理想
  { step:3, id:'concerns' },
  { step:3, id:'concernsItem' },
  { step:3, id:'goalTexture' },
  { step:3, id:'goal' },
  { step:3, id:'headSpaInterest' },
  { step:3, id:'wellness', when:(a) => a.headSpaInterest === 'yes' },
];

const MODE_B_STEPS = [
  { index:1, title:'もともとの髪',      desc:'生まれ持った髪の特徴と、頭皮の状態を伺います。' },
  { index:2, title:'髪の履歴',          desc:'これまでの施術と、毎日のアイロンの使い方を伺います。' },
  { index:3, title:'いまの悩みと目標',  desc:'いま気になることと、目指したい仕上がりを伺います。' },
];

// キャラ既知ショートカット: 性格・髪質判定に使う質問はスキップ(履歴・現状中心の短いカルテに)
// age/gender はキャラ判定ではなく属性なのでキャラ既知時もスキップしない(SH/TR/エッセンスの処方に効くため必要)
const CHARACTER_DISCOVERY_IDS = new Set(['thickness','density','rootVolume','wave','scalpType','scalpSensitivity']);
function buildModeBSequence(answers) {
  const isKnown = !!(answers && answers._knownOriginId);
  return MODE_B_ORDER.filter(entry => {
    // キャラ既知ならキャラ判定系をスキップ
    if (isKnown && CHARACTER_DISCOVERY_IDS.has(entry.id)) return false;
    if (typeof entry.when !== 'function') return true;
    try { return !!entry.when(answers); } catch (e) { return true; }
  });
}


/* ---------- bleach 派生 (color質問から導出) ---------- */
function deriveBleach(answers){
  if (!answers) return null;
  if (answers.bleach && answers.bleach !== 'none') return answers.bleach;
  const c = answers.color;
  if (c === 'multi_bleach')  return 'multi';
  if (c === 'bleach_recent') return 'within3m';
  if (c === 'bleach_past')   return 'within1y';
  if (c === 'highlight')     return 'highlight';
  return null;
}

/* ---------- スコアリング ---------- */
const EMPTY_SCORES = {
  dryness: 0, damage: 0, bleachHistory: 0, colorFade: 0,
  frizz: 0, curl: 0, heatDamage: 0, scalpDryness: 0,
  scalpOiliness: 0, volumeLoss: 0, aging: 0,
  longHairHistory: 0, smoothness: 0,
};

const LONG_LENGTHS = new Set(['shoulderDown', 'chestUp', 'long']);

function addScore(target, add) {
  if (!add) return;
  for (const k in add) target[k] = (target[k] || 0) + add[k];
}

function computeScores(answers) {
  const s = { ...EMPTY_SCORES };
  const allQuestions = [...Q, ...(typeof Q_DEEP_NEW !== 'undefined' ? Q_DEEP_NEW : [])];

  for (const q of allQuestions) {
    const a = answers[q.id];
    if (a == null) continue;

    // 通常のスコア加算
    if (q.type === 'heat-tools') {
      const tools = (a && a.tools) || [];
      const temp  = a && a.temp;
      for (const v of tools) {
        const opt = q.toolOptions.find(o => o.v === v);
        if (opt) addScore(s, opt.score);
      }
      if (temp) {
        const opt = q.tempOptions.find(o => o.v === temp);
        if (opt) addScore(s, opt.score);
      }
    } else if (Array.isArray(a)) {
      for (const v of a) {
        const opt = q.options.find(o => o.v === v);
        if (opt) addScore(s, opt.score);
      }
    } else {
      const opt = q.options.find(o => o.v === a);
      if (opt) addScore(s, opt.score);
    }
  }

  const length     = answers.length;
  const bleach     = answers.bleach || (
    answers.color === 'multi_bleach' ? 'multi'   :
    answers.color === 'bleach_recent' ? 'within3m' :
    answers.color === 'bleach_past'   ? 'within1y' :
    answers.color === 'highlight'     ? 'highlight' :
    'none'
  );
  const color      = answers.color;
  const straighten = answers.straighten;
  const stylingAns = answers.styling || {};
  const tools      = stylingAns.tools || [];
  const temp       = stylingAns.temp;
  const items      = answers.items || [];

  // ロング × ブリーチ／カラー残り
  if (LONG_LENGTHS.has(length)) {
    if (bleach && bleach !== 'none') { s.longHairHistory += 2; s.damage += 1; }
    if (color && !['none', 'over1y'].includes(color)) { s.longHairHistory += 1; }
  }
  if (bleach === 'over1y' && LONG_LENGTHS.has(length)) {
    s.longHairHistory += 2; s.damage += 1;
  }

  // 縮毛矯正が3ヶ月以上前 → 根元うねり対策強化
  if (['within6m', 'within1y', 'over1y'].includes(straighten)) {
    s.frizz += 2; s.heatDamage += 1;
  }

  // 毎日アイロン／コテ → 熱ダメージ強化
  const dailyHeat = tools.includes('ironDaily') || tools.includes('curlerDaily');
  if (dailyHeat) { s.heatDamage += 2; s.dryness += 1; }

  // 高温 × 履歴の警告フラグ
  const hot180  = temp === 't180' || temp === 't200';
  const hot200  = temp === 't200';
  const hasColor      = color && color !== 'none';
  const hasBleach     = bleach && bleach !== 'none';
  const hasStraighten = straighten && straighten !== 'none';
  const usesHeat      = tools.length > 0 && !tools.includes('rare');

  const heatColorWarning  = hot180 && hasColor && usesHeat;
  const heatBleachWarning = hot200 && (hasBleach || hasStraighten) && usesHeat;

  // 高温×ブリーチ／縮毛の場合は damage を追加加算
  if (heatBleachWarning) { s.damage += 2; s.heatDamage += 1; }

  const onlyOil     = items.includes('oil') && !items.includes('milk') && !items.includes('mask');
  const maskMissing = !items.includes('mask') && s.damage >= 5;

  return { scores: s, flags: { onlyOil, maskMissing, heatColorWarning, heatBleachWarning, temp, dailyHeat } };
}

