// 詰め替え・パウチ画像を弾くフィルタ（一覧表示で「本体ボトル」だけを見せる）
function isRefillImage(src) {
  if (!src) return false;
  const s = src.toLowerCase();
  return /refill|pouch|リフィル|レフィル|詰め替え|詰替|パウチ|sachet/i.test(s);
}

