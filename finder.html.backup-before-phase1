  <meta http-equiv="Expires" content="0">
  <title>SEAM Hair Finder | 髪の履歴から、今必要なヘアケアを見つける。</title>
  <meta name="description" content="ブリーチ、カラー、縮毛矯正、パーマ、毎日のアイロン。あなたの髪に残る“履歴”まで見て、今必要なヘアケアルーティンを提案します。サロン専売品セレクトショップ SEAM の本格診断。">

  <!-- ─── PWA / Mobile App / WebView optimization ─── -->
  <meta name="theme-color" content="#FAF8F4" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#1A1815" media="(prefers-color-scheme: dark)">
  <meta name="color-scheme" content="light">
  <meta name="format-detection" content="telephone=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="SEAM Finder">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="application-name" content="SEAM Finder">
  <link rel="apple-touch-icon" href="images/favicon.svg">
  <link rel="icon" href="images/favicon.svg" type="image/svg+xml">
  <link rel="manifest" href="manifest.json">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Noto+Serif+JP:wght@300;400;500;600&family=Noto+Sans+JP:wght@300;400;500;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            ivory:      '#FAF8F4',
            cream:      '#F4F0E8',
            sand:       '#ECE5D8',
            bisque:     '#D6C7B0',
            mocha:      '#8C7A63',
            ink:        '#1A1815',
            charcoal:   '#3D3833',
            mist:       '#E7E4DE',
            line:       '#E2DDD3',
            roseBeige:  '#E0C4B5',
            roseAccent: '#C9A089',
            gold:       '#B8945A',
            goldLight:  '#D9BE93',
            // ★ G-2: 設計仕様書に基づく追加トークン (Yuanagi 主体 + Atelier 骨格)
            baseBG:        '#FAF7F2',  // 画面の基本背景
            softSection:   '#F6F1EA',  // 章を区切るやわらかい面
            deepSection:   '#EEE7DD',  // やや濃い面 (商品ゾーン等)
            warmFill:      '#E9D8C8',  // 温かい塗り (Card 内アクセント)
            highlightFill: '#F2E6D9',  // ハイライト塗り (chip 等)
            mainBrown:     '#B57C5A',  // メインアクセント (Atelier ブラウン)
            rose:          '#D7A39A',  // ローズアクセント (注意/補助)
            sage:          '#7E8C7A',  // セージアクセント (環境/季節)
          },
          fontFamily: {
            // ★ Sans を基本軸に整理。和文は Noto Sans JP 主体
            sans:    ['"Noto Sans JP"', '"Inter"', 'system-ui', 'sans-serif'],
            // ★ Serif は和文 Noto Serif JP 一本に。Latin は控えめに Cormorant fallback
            serif:   ['"Noto Serif JP"', '"Cormorant Garamond"', 'serif'],
            // ★ Display は Hero 専用 (英字キャラ名や大型ヒーロー用)
            display: ['"Cormorant Garamond"', '"Noto Serif JP"', 'serif'],
            // ★ Mono は Inter で抑えめ (Montserrat より落ち着いた印象)
            mono:    ['"Inter"', '"Noto Sans JP"', 'sans-serif'],
          },
          letterSpacing: {
            // ★ 0.25em → 0.14em にトーンダウン (騒がしさを減らす)
            widest2: '0.14em',
            widest3: '0.22em', // 必要な場面用に残置
          },
          boxShadow: {
            'soft':  '0 1px 2px rgba(26,24,21,0.04), 0 8px 24px -16px rgba(26,24,21,0.08)',
            'card':  '0 2px 4px rgba(26,24,21,0.03), 0 24px 60px -30px rgba(26,24,21,0.12)',
            'inner-soft': 'inset 0 0 0 1px rgba(184,148,90,0.18)',
          },
        },
      },
    }
  </script>

  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone@7.24.7/babel.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

  <style>
    :root { color-scheme: light; }
    html {
      background: #FAF8F4;
      -webkit-text-size-adjust: 100%;
      text-size-adjust: 100%;
    }
    body {
      background: #FAF8F4;
      font-family: 'Noto Sans JP', 'Inter', system-ui, sans-serif;
      color: #1F1D1A;
      font-weight: 400;
      letter-spacing: 0.005em;
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      font-feature-settings: "palt"; /* 和文プロポーショナル — 行間が美しくなる */
      overscroll-behavior-y: none;
      /* Sticky底部CTAバー (64px) + iPhone safe-area-inset-bottom 分を予約 */
      padding-bottom: calc(64px + env(safe-area-inset-bottom, 0px));
    }
    @media (min-width: 640px) { body { padding-bottom: 0; } }

    /* iOS tap highlight */
    a, button { -webkit-tap-highlight-color: rgba(184,148,90,0.12); }

    /* ═══════════════════════════════════════════════════════════════
       App-Fit Container — finderの全画面を「アプリ画面」サイズに固定
       ═══════════════════════════════════════════════════════════════
       全画面（Home / Quiz / Result / Collection / QuizDeep）が、
       モバイルアプリのフレーム内に収まるように max-width を制限。
       スマホでは全画面、デスクトップではセンタリングしてアプリ枠表示。
       ─────────────────────────────────────────────────────────────── */
    :root {
      --app-max-width: 480px;
      --app-frame-color: #EFE6D8;
    }
    #root {
      max-width: var(--app-max-width);
      margin: 0 auto;
      min-height: 100vh;
      min-height: 100svh;
      background: #FAF8F4;
      position: relative;
      overflow-x: hidden;
    }
    /* デスクトップ: アプリ外側のフレーム色を表示 */
    @media (min-width: 720px) {
      html, body {
        background: var(--app-frame-color);
      }
      #root {
        box-shadow: 0 0 80px rgba(26,24,21,0.06), 0 0 1px rgba(184,148,90,0.2);
      }
    }
    /* Fixed要素も app-max-width 内に収まるように center 配置 */
    .fixed.inset-x-0 {
      max-width: var(--app-max-width);
      left: 50% !important;
      right: auto !important;
      transform: translateX(-50%);
      width: 100%;
    }
    /* Modal等 fixed.inset-0 (full-screen overlay) も同様に */
    .fixed.inset-0 {
      max-width: var(--app-max-width);
      left: 50% !important;
      right: auto !important;
      transform: translateX(-50%);
      width: 100%;
    }
    /* 1画面ローダー(z-9100)等の超高 z-index も同様 */
    @media (min-width: 720px) {
      /* スクリーンの中央に枠 */
      body::before {
        content: '';
        position: fixed;
        top: 0; bottom: 0;
        left: 50%; transform: translateX(-50%);
        width: var(--app-max-width);
        pointer-events: none;
        border-left: 1px solid rgba(184,148,90,0.12);
        border-right: 1px solid rgba(184,148,90,0.12);
        z-index: 1;
      }
    }

    /* ─── 黒CTA全廃: bg-ink text-ivory → SEAM warm brown #B57C5A ─── */
    /* nav 等の構造要素は除外。CTA系のアンカー/ボタンのみ対象。 */
    a.bg-ink.text-ivory,
    button.bg-ink.text-ivory,
    a.bg-ink:not(.bg-ink\/60):not(.bg-ink\/80),
    button.bg-ink:not(.bg-ink\/60):not(.bg-ink\/80) {
      background-color: #B57C5A !important;
      color: #ffffff !important;
    }
    a.bg-ink.text-ivory:hover,
    button.bg-ink.text-ivory:hover,
    a.bg-ink:not(.bg-ink\/60):not(.bg-ink\/80):hover,
    button.bg-ink:not(.bg-ink\/60):not(.bg-ink\/80):hover {
      background-color: #9F6A4B !important;
    }
    a.bg-ink.text-ivory:active,
    button.bg-ink.text-ivory:active {
      background-color: #9F6A4B !important;
    }
    /* CTA内ピル/丸 — 黒→白 反転 */
    .bg-ink .bg-ivory.text-ink,
    .bg-ink .bg-ivory {
      background-color: #ffffff !important;
      color: #B57C5A !important;
    }
    /* hover:bg-charcoal も同調 */
    .hover\:bg-charcoal:hover { background-color: #9F6A4B !important; }
    .active\:bg-charcoal:active { background-color: #9F6A4B !important; }
    /* バッジ/ラベルなど小さい bg-ink は黒のまま許容（章バッジ等） */
    /* ─────────────────────────────────────────────
       ★ タイポグラフィの統一: Serif は H1〜H2 主役だけ
       小さい見出し/カード見出しは sans (Noto Sans JP) に
       ───────────────────────────────────────────── */
    .font-serif { letter-spacing: 0.005em; font-weight: 400; }
    .font-display { letter-spacing: 0.01em; }
    /* mono ラベルは weight 控えめ + tracking 抑え */
    .font-mono { font-weight: 400; letter-spacing: 0.04em; }
    .font-mono.tracking-widest2 { letter-spacing: 0.14em; }
    /* ★ 小サイズ Serif は読みづらいので sans へ自動降格 */
    h4.font-serif, h5.font-serif, h6.font-serif,
    .font-serif.text-\[12px\], .font-serif.text-\[12\.5px\],
    .font-serif.text-\[13px\], .font-serif.text-\[13\.5px\],
    .font-serif.text-\[14px\], .font-serif.text-\[14\.5px\],
    .font-serif.text-\[15px\], .font-serif.text-\[15\.5px\] {
      font-family: 'Noto Sans JP', 'Inter', system-ui, sans-serif !important;
      font-weight: 500;
      letter-spacing: 0.01em;
    }

    .bg-finder {
      background:
        radial-gradient(40% 28% at 88% -6%, rgba(184,148,90,0.08) 0%, rgba(184,148,90,0) 70%),
        radial-gradient(36% 26% at -6% 102%, rgba(60,55,48,0.05) 0%, rgba(60,55,48,0) 70%),
        linear-gradient(180deg, #FAF8F4 0%, #F2EEE6 100%);
    }

    /* Editorial graph paper overlay — extremely subtle */
    .bg-finder::before {
      content: "";
      position: fixed; inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(to right, rgba(60,55,48,0.025) 1px, transparent 1px);
      background-size: 96px 96px;
      mask-image: linear-gradient(180deg, rgba(0,0,0,0.6), rgba(0,0,0,0.1));
      -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,0.6), rgba(0,0,0,0.1));
      z-index: 0;
    }

    .hairline { background: linear-gradient(90deg, transparent, #B8945A 50%, transparent); height: 1px; }

    /* Game-style Profile Cards — タロット/ガチャ風 */
    .game-card {
      transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease;
      will-change: transform;
    }
    .game-card:hover {
      transform: translateY(-4px) scale(1.005);
    }
    .game-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(120% 80% at 0% 0%, rgba(255,255,255,0.5), transparent 60%);
      pointer-events: none;
      border-radius: inherit;
      z-index: 1;
    }
    .game-card > * { position: relative; z-index: 2; }
    @media (prefers-reduced-motion: reduce) {
      .game-card, .game-card:hover { transition: none; transform: none; }
    }

    /* Quiz question transitions */
    @keyframes seamQuizIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .anim-quiz { animation: seamQuizIn 420ms cubic-bezier(0.22, 0.61, 0.36, 1) both; }

    @keyframes seamMilestonePulse {
      0%   { transform: scale(1); opacity: 0.6; }
      50%  { transform: scale(1.4); opacity: 0; }
      100% { transform: scale(1.4); opacity: 0; }
    }
    .milestone-pulse {
      position: relative;
    }
    .milestone-pulse::after {
      content: '';
      position: absolute; inset: 0;
      border-radius: 9999px;
      border: 1px solid #B8945A;
      animation: seamMilestonePulse 1400ms ease-out;
      pointer-events: none;
    }

    @keyframes seamProgressFill {
      from { width: 0%; }
    }
    .progress-anim { animation: seamProgressFill 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both; }

    /* Karte animal reveal */
    @keyframes karte-mark-in {
      0%   { opacity: 0; transform: scale(0.86); filter: blur(2px); }
      60%  { opacity: 0.9; filter: blur(0); }
      100% { opacity: 1; transform: scale(1); }
    }
    @keyframes karte-glow {
      0%, 100% { opacity: 0.18; }
      50%      { opacity: 0.35; }
    }
    @keyframes karte-evolve-ring {
      0%   { transform: scale(0.6); opacity: 0; }
      40%  { opacity: 0.55; }
      100% { transform: scale(2.0); opacity: 0; }
    }
    .karte-mark-anim { animation: karte-mark-in 1100ms cubic-bezier(0.22, 0.61, 0.36, 1) both; }
    @keyframes karte-target-fade {
      0%   { opacity: 0; }
      100% { opacity: 1; }
    }
    @keyframes karte-evo-origin-out {
      0%   { opacity: 1; transform: scale(1) translateX(0); }
      100% { opacity: 0.35; transform: scale(0.7) translateX(-12px); }
    }
    @keyframes karte-evo-goal-in {
      0%   { opacity: 0; transform: scale(0.85) translateX(12px); filter: blur(2px); }
      60%  { opacity: 0.95; filter: blur(0); }
      100% { opacity: 1; transform: scale(1) translateX(0); }
    }
    @keyframes karte-evo-arrow {
      0%   { opacity: 0; transform: scaleX(0); transform-origin: left center; }
      50%  { opacity: 0.7; transform: scaleX(1); }
      100% { opacity: 0.45; }
    }
    .karte-evo-origin { animation: karte-evo-origin-out 1600ms cubic-bezier(0.22, 0.61, 0.36, 1) 800ms both; }
    .karte-evo-goal   { animation: karte-evo-goal-in   1800ms cubic-bezier(0.22, 0.61, 0.36, 1) 1100ms both; }
    .karte-evo-arrow  { animation: karte-evo-arrow     1400ms ease-out 600ms both; }
    .karte-mark-accent { position: relative; }
    .karte-mark-accent::before,
    .karte-mark-accent::after {
      content: ''; position: absolute; inset: 0;
      border-radius: 9999px; border: 1px solid #B8945A;
      pointer-events: none;
    }
    .karte-mark-accent::before { animation: karte-evolve-ring 2400ms ease-out 200ms infinite; }
    .karte-mark-accent::after  { animation: karte-evolve-ring 2400ms ease-out 1300ms infinite; }
    .karte-mark-glow {
      position: absolute; inset: -16%;
      background: radial-gradient(circle, rgba(217,190,147,0.30) 0%, rgba(217,190,147,0) 65%);
      border-radius: 9999px; pointer-events: none;
      animation: karte-glow 4200ms ease-in-out infinite;
    }

    /* Editorial divider with center mark */
    .hairline-center {
      display: flex; align-items: center; gap: 12px;
      color: #B8945A;
    }
    .hairline-center::before, .hairline-center::after {
      content: ""; flex: 1; height: 1px; background: #E2DDD3;
    }

    .seam-slider {
      -webkit-appearance: none;
      appearance: none;
      width: 100%;
      height: 2px;
      background: #E2DDD3;
      outline: none;
      border-radius: 2px;
    }
    .seam-slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 22px; height: 22px;
      background: #1A1815;
      border: 3px solid #FAF8F4;
      border-radius: 50%;
      box-shadow: 0 0 0 1px #1A1815, 0 4px 12px rgba(26,24,21,0.15);
      cursor: pointer;
    }
    .seam-slider::-moz-range-thumb {
      width: 22px; height: 22px;
      background: #1A1815;
      border: 3px solid #FAF8F4;
      border-radius: 50%;
      box-shadow: 0 0 0 1px #1A1815, 0 4px 12px rgba(26,24,21,0.15);
      cursor: pointer;
    }

    .snap-x-row { scroll-snap-type: x mandatory; scroll-padding: 16px; }
    .snap-x-row > * { scroll-snap-align: center; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    @keyframes seamFadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .anim-fade-up { animation: seamFadeUp 0.45s cubic-bezier(.2,.7,.2,1) both; }

    @keyframes seamBarGrow {
      from { width: 0; }
    }
    .anim-bar { animation: seamBarGrow 0.9s cubic-bezier(.2,.7,.2,1) both; }

    /* ===== VISIT SEAM — Apple-style ambient glow ===== */
    @keyframes visitGlow {
      0%, 100% { opacity: 0.55; transform: translate3d(0,0,0) scale(1); }
      50%      { opacity: 1;    transform: translate3d(0,-10px,0) scale(1.05); }
    }
    .visit-glow { animation: visitGlow 8s ease-in-out infinite; }

    @keyframes visitNumDrift {
      0%, 100% { transform: translateY(0); }
      50%      { transform: translateY(-6px); }
    }

    .nums { font-variant-numeric: tabular-nums; }

    /* ===== Print karte ===== */
    @media print {
      @page { size: A4; margin: 14mm 14mm; }

      html, body { background: #ffffff !important; color: #1A1815 !important; }
      .bg-finder { background: #ffffff !important; }
      .bg-finder::before { display: none !important; }

      .no-print, .no-print * { display: none !important; }

      /* Reset shadows + animations */
      * {
        box-shadow: none !important;
        text-shadow: none !important;
        animation: none !important;
        transition: none !important;
        backdrop-filter: none !important;
      }

      /* Dark CTA block becomes white framed for print */
      .print-frame { background: #ffffff !important; color: #1A1815 !important; border: 1px solid #1A1815 !important; }
      .print-frame * { color: #1A1815 !important; }

      /* Tone down translucent backgrounds */
      .bg-white\/70, .bg-white\/80 { background: #ffffff !important; }
      .bg-cream { background: #F4F0E8 !important; }

      /* Karte print header (hidden on screen) */
      .print-only { display: block !important; }

      /* Keep colors readable */
      .text-ivory { color: #1A1815 !important; }
      .text-goldLight { color: #B8945A !important; }

      /* Forced black on important text */
      h1, h2, h3, h4 { color: #1A1815 !important; }

      /* Avoid breaks inside sections */
      section, article { break-inside: avoid; page-break-inside: avoid; }

      /* Print page header line */
      .print-page-header {
        border-bottom: 1px solid #1A1815;
        padding-bottom: 6mm;
        margin-bottom: 8mm;
      }

      /* Compact bar charts */
      .anim-bar { width: var(--print-width, 100%) !important; }
    }
    .print-only { display: none; }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel" data-presets="react">
/* =========================================================================
   SEAM Hair Finder
   - Single-file React app (CDN React 18 + Tailwind Play CDN + Babel standalone)
   - 15問の診断 → スコアリング → 診断タイプ判定 → カテゴリ別ルーティン提案
   ========================================================================= */

const { useState, useMemo, useEffect, useRef } = React;

/* ---------- 質問データ ---------- */
const Q = [
  {
    id: 'concerns',
    type: 'chip-multi',
    max: 3,
    eyebrow: 'Concerns',
    title: '今いちばん気になる髪の悩みは？',
    note: '当てはまるものを最大3つまで選んでください。',
    options: [
      { v: 'dry',         label: '乾燥',                 score: { dryness: 2 } },
      { v: 'frizz',       label: '広がり',               score: { dryness: 1, frizz: 1 } },
      { v: 'wave',        label: 'うねり・くせ',         score: { frizz: 2 } },
      { v: 'rough',       label: 'パサつき',             score: { dryness: 2, damage: 1 } },
      { v: 'tangle',      label: '絡まり',               score: { damage: 2 } },
      { v: 'noShine',     label: 'ツヤ不足',             score: { dryness: 1, damage: 1 } },
      { v: 'split',       label: '枝毛・切れ毛',         score: { damage: 3 } },
      { v: 'damage',      label: 'ダメージ',             score: { damage: 3 } },
      { v: 'colorFade',   label: 'カラーの色落ち',       score: { colorFade: 3 } },
      { v: 'grayFade',    label: '白髪染めの色落ち',     score: { colorFade: 2, aging: 1 } },
      { v: 'volumeDown',  label: 'ボリューム不足',       score: { volumeLoss: 2 } },
      { v: 'topFlat',     label: 'トップがぺたんとする', score: { volumeLoss: 2, aging: 1 } },
      { v: 'scalpDry',    label: '頭皮の乾燥・かゆみ',   score: { scalpDryness: 3 } },
      { v: 'scalpOily',   label: '頭皮のベタつき・におい', score: { scalpOiliness: 3 } },
      { v: 'thinning',    label: '抜け毛・細毛',         score: { aging: 2, volumeLoss: 1 } },
    ],
  },
