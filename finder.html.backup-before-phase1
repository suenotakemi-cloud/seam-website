/* ---------- HairChart ---------- */
function HairChart({ chart }) {
  const entries = Object.entries(chart);
  return (
    <div className="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-5">
      {entries.map(([label, v]) => {
        const pct = (v / 5) * 100;
        const level = levelLabel(v);
        const tone = level === 'Keep' ? 'text-charcoal/70' : level === 'Care' ? 'text-roseAccent' : 'text-gold';
        const barColor = level === 'Intensive Care' ? '#B8945A' : level === 'Care' ? '#C9A089' : '#3D3833';
        return (
          <div key={label}>
            <div className="flex items-baseline justify-between">
              <span className="font-serif text-[14.5px] text-ink">{label}</span>
              <span className={`font-mono tracking-widest2 text-[10.5px] uppercase ${tone}`}>{level}</span>
            </div>
            <div className="mt-2 h-px bg-line/80 relative">
              <div
                className="absolute left-0 anim-bar"
                style={{
                  width: `${Math.max(4, pct)}%`,
                  background: barColor,
                  height: '2px',
                  top: '-0.5px',
                }}
              />
            </div>
            <div className="mt-1.5 flex justify-between text-[10px] tracking-widest2 uppercase text-charcoal/35 nums">
              <span>0</span><span>1</span><span>2</span><span>3</span><span>4</span><span>5</span>
            </div>
          </div>
        );
      })}
    </div>
  );
}

