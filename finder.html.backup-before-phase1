function determineType(scores, answers) {
  const s = scores;
  const straighten = answers.straighten;
  const perm       = answers.perm;

  if (s.scalpDryness   >= 4) return 'scalpDry';
  if (s.scalpOiliness  >= 4) return 'scalpOily';
  if (s.bleachHistory  >= 5 || s.longHairHistory >= 3) return 'bleachEnds';

  const hasStraighten = straighten && straighten !== 'none';
  if (hasStraighten && (s.frizz >= 3 || s.heatDamage >= 4)) return 'straightFrizz';

  if (s.heatDamage     >= 5) return 'heat';

  const hasPerm = perm && perm !== 'none' && perm !== 'past';
  if (hasPerm && s.curl >= 3) return 'permLoose';

  if (s.colorFade      >= 4) return 'colorFade';
  if (s.volumeLoss + s.aging >= 5) return 'aging';
  if (s.dryness >= 4 || s.damage >= 4) return 'dry';

  const total = Object.values(s).reduce((a,b)=>a+b,0);
  if (total < 6) return 'beginner';

  const proxy = {
    bleachEnds: s.bleachHistory + s.longHairHistory,
    heat: s.heatDamage,
    colorFade: s.colorFade,
    dry: s.dryness,
    aging: s.aging + s.volumeLoss,
    straightFrizz: s.frizz,
    permLoose: s.curl,
    scalpDry: s.scalpDryness,
    scalpOily: s.scalpOiliness,
  };
  return Object.keys(proxy).sort((a,b)=>proxy[b]-proxy[a])[0];
}

