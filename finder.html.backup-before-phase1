/* ---------- pickPinnedProducts — 必須提案ルール ---------- */
// アイロン使用→熱保護ベースミスト / 外出多→UVスプレー / 湿気広がり→ワンダーシールド / ブリーチ→リピッドブースター+ミラクル
function pickPinnedProducts(products, answers, scores) {
  if (!products || !products.length) return [];
  const pinned = [];
  const seen = new Set();
  const a = answers || {};
  const s = scores || {};
  const tools = (a.styling && a.styling.tools) || [];
  const temp = a.styling && a.styling.temp;
  const usesHeat = tools.some(t => /iron|curler/i.test(t)) || ['t140','t160','t180','t200'].includes(temp);
  const outsideLife = (a.lifestyle || []).includes('outside');
  const sunEnv = a.environment === 'sun';
  const humidEnv = a.environment === 'humid' || (a.lifestyle || []).includes('humidity');
  const concerns = a.concerns || [];
  const hasFrizzConcern = concerns.includes('frizz') || concerns.includes('wave') || (s.frizz || 0) >= 3;
  const isBleached = a.bleach && a.bleach !== 'none';

  const add = (id, badge, reason) => {
    if (seen.has(id)) return;
    const p = products.find(x => x.id === id);
    if (!p) return;
    pinned.push({ p, badge, reason });
    seen.add(id);
  };
  const addFiltered = (filterFn, badge, reason, limit = 1) => {
    const matches = products.filter(p => !seen.has(p.id) && filterFn(p));
    matches.slice(0, limit).forEach(p => {
      pinned.push({ p, badge, reason });
      seen.add(p.id);
    });
  };

  // ① アイロン使用 → 熱保護ベースミスト
  if (usesHeat) {
    add('sublimic-wondershield-out', '熱から守るベース',
        'ミルクやオイルの下に重ねるだけで、アイロンの熱と乾燥から芯まで守ります。');
    add('likera-mist', '熱から守るベース',
        '熱を使うほど補修が効く処方。アイロン前のひと吹きで、ダメージ進行を補修に変える代名詞ミスト。');
    // 他の軽め熱保護ミスト
    addFiltered(p =>
      (p.category === 'outbath-water' || p.category === 'leave-in-mist') &&
      (p.functionTags || []).includes('heat-protect') &&
      (p.functionTags || []).includes('lightweight'),
      '熱から守るベース',
      '軽い質感で重ねつけしやすい、ヒートプロテクトミスト。', 1
    );
  }

  // ②-A 外出が多い → UVスプレーのみ (日常レベルの紫外線対策)
  if (outsideLife && !sunEnv) {
    add('loa-uvspray', 'UVスプレー',
        'SPF50+ PA++++ の高UVカットを纏う、香りつきパフュームUVスプレー。外出前のひと吹きで肌と髪を同時に守る。');
    // 同カテゴリ(outbath-water)で uv-care 付きのスプレー型製品
    addFiltered(p =>
      p.category === 'outbath-water' &&
      (p.functionTags || []).includes('uv-care'),
      'UVスプレー',
      '軽やかな質感のUVスプレー。日常使いに重ねつけしやすい一本。', 1
    );
  }

  // ②-B 紫外線環境下が多い → UVスプレー + UV系ヘアケア (海・プール・スポーツ・屋外労働)
  if (sunEnv) {
    add('loa-uvspray', 'UVスプレー',
        'SPF50+ PA++++ の高UVカット。屋外活動・レジャーの必需品となる、ウォータープルーフ仕様のUVスプレー。');
    add('sublimic-wondershield-out', 'UV系ヘアケア',
        '紫外線・湿気・熱を一本で守るマルチガードベース。日差しが強い環境の万能シールド。');
    add('syspro-solar-sunoil', 'UV系ヘアケア',
        'UVケア機能付きの軽やかなヘアオイル。海・プール・スポーツの前に重ねたい一本。');
    add('syspro-solar-sealing', 'UV系ヘアケア',
        '髪表面に薄膜を作るUVシーリングクリーム。レジャー前の徹底ガードに。');
    add('syspro-solar-sh', 'UV系ヘアケア',
        'UV・塩素・海水ダメージのリセットケアシャンプー。日差しを浴びた日の夜のリカバリーに。');
  }

  // ③ 湿気で広がる → ワンダーシールド (humid環境 OR フリッツ強)
  if (hasFrizzConcern && humidEnv) {
    add('sublimic-wondershield-out', '湿気ガード',
        '湿気・うねり・広がりに72時間効くシールド処方。湿度の高い季節の必需品。');
  } else if (hasFrizzConcern) {
    add('sublimic-wondershield-out', '湿気ガード',
        '湿気で広がりやすい人に。一本で湿気・熱・紫外線をブロックする万能シールド。');
  }

  // ④ ブリーチ毛 → リピッドブースター + アルタイム R インテンスマスク
  if (isBleached) {
    add('syspro-extra-lipidbooster', 'ブリーチ救済',
        'ブリーチで失われた脂質を集中補給するプレトリートメント。シャンプー前に塗布する救世主。');
    add('wella-ultimerepair-mask', 'ブリーチ救済',
        '90秒でダメージサインを最大99%補修する、ウエラの "奇跡のミラクルマスク"。');
  }

  return pinned;
}

