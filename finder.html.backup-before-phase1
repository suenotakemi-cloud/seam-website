function buildWhyAccordion(typeId, answers, scores, karte, description) {
  const code = karte?.origin?.code;
  const typeShort = (typeof TYPE_SHORT_NAME !== 'undefined') ? TYPE_SHORT_NAME[code] : null;
  const concernKeys = (answers?.concerns) || [];
  const concernLabels = concernKeys
    .slice(0, 3)
    .map(k => (CONCERN_CHIP_LABEL[k]?.label || ''))
    .filter(Boolean)
    .join('・');

  // Q1: なぜこのタイプ?  ← description の最初の段落 + キャラ名 framing
  const q1Body = (description && description[0])
    ? description[0]
    : 'あなたの回答全体から見えた傾向で、このタイプにご紹介しています。';

  // Q2: どの悩みが影響?  ← concerns + description の2段落目
  const q2Body = concernLabels
    ? `あなたが選んだ「${concernLabels}」が、今回の結果に強く影響しています。${description?.[1] ? ' ' + description[1] : ''}`
    : (description?.[1] || 'ご回答内容のバランスから、今回のタイプを導き出しています。');

  // Q3: 毎日のケアで変わるところは?
  const q3Body = DAILY_CARE_NOTE_BY_TYPE[typeId] || DAILY_CARE_NOTE_BY_TYPE.beginner;

  // Q4: 季節でどう変わる?
  const q4Body = SEASON_NOTE_BY_TYPE[typeId] || SEASON_NOTE_BY_TYPE.beginner;

  return [
    { title: 'なぜこのタイプになったの?',         body: q1Body, hint: typeShort ? `→ ${typeShort.jp}` : null },
    { title: 'どの悩みが強く影響したの?',         body: q2Body, hint: concernLabels ? `→ ${concernLabels}` : null },
    { title: '毎日のケアで変わりやすいところは?', body: q3Body },
    { title: '季節でどう変わる?',                 body: q4Body },
  ];
}

