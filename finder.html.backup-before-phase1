  sleepLight:   '寝つきが悪い',
  bodyHeavy:    '体のだるさ',
  well:         '特に気にならない',
};

function pickHeadSpaRecs(answers) {
  const a = answers || {};
  const w = a.wellness || [];
  const concerns = a.concerns || [];
  const recs = [];

  // ヘッドスパに興味がない場合は提案しない(薄毛も含めて)
  if (a.headSpaInterest === 'no') return null;

  // 薄毛・抜け毛があれば、スカルプ(育毛サポート)を最優先で
  // ※ ただし headSpaInterest が 'yes' か未回答のときのみ
  if (concerns.includes('thinning')) {
    const sp = HEAD_SPA_RECS.find(x => x.id === 'scalp-growth');
    if (sp) recs.push({ ...sp, matchCount: 99 });
  }

  // ヘッドスパに興味あり + ウェルネス未回答 のときは、デフォルトコースを提案
  if (a.headSpaInterest === 'yes' && (w.length === 0 || (w.length === 1 && w.includes('well')))) {
    const refresh = HEAD_SPA_RECS.find(x => x.id === 'refresh');
    if (refresh && !recs.some(r => r.id === refresh.id)) recs.push({ ...refresh, matchCount: 1 });
    return recs;
  }

  // ウェルネス傾向で推奨
  if (w.length === 0 || (w.length === 1 && w.includes('well'))) {
    return recs.length ? recs : null;
  }

  const scored = HEAD_SPA_RECS
    .filter(s => !s.forThinning)
    .map(spa => ({ ...spa, matchCount: spa.triggers.filter(t => w.includes(t)).length }))
    .filter(s => s.matchCount > 0)
    .sort((a, b) => b.matchCount - a.matchCount);

  // 3つ以上の悩みがあるなら、Deep + 個別2つ
  if (w.length >= 3) {
    const deep = HEAD_SPA_RECS.find(s => s.fullCare);
    const others = scored.filter(s => !s.fullCare).slice(0, 2);
    recs.push(...(deep ? [{ ...deep, matchCount: w.length }] : []), ...others);
  } else {
    // 1〜2個 → 該当する専門スパを優先表示(Deep は出さない)
    const individualSpas = scored.filter(s => !s.fullCare).slice(0, 2);
    recs.push(...individualSpas);
  }

  // 重複除去
  const seen = new Set();
  return recs.filter(s => { if (seen.has(s.id)) return false; seen.add(s.id); return true; });
}

