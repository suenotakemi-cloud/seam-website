/* ---------- カルテ保存/共有 ---------- */
// PDFファイル名: SEAM_HAIR_FINDER_KARTE_YYYY-MM-DD.pdf
// ブラウザの印刷ダイアログを利用して、iOS/Android/PC全てで「保存・共有」を提供する。
//   - iOS Safari: 印刷プレビュー → 共有シート（AirDrop / ファイル / LINE 等）
//   - Android Chrome: 印刷プレビュー → "PDF として保存" → 共有
//   - PC: 印刷ダイアログから "PDF として保存"
function saveOrShareKarte() {
  const date = new Date().toISOString().slice(0,10);
  const filename = `SEAM_HAIR_FINDER_KARTE_${date}`;
  const originalTitle = document.title;
  document.title = filename;
  setTimeout(() => {
    window.print();
    setTimeout(() => { document.title = originalTitle; }, 800);
  }, 10);
}

// Web Share API が使える端末ではURL共有のオプションも提供（補助的）
async function tryShareKarteUrl() {
  if (navigator.share) {
    try {
      await navigator.share({
        title: 'SEAM Hair Finder — 髪のメモ',
        text: '今日の髪のメモを共有します。',
        url: location.href,
      });
      return true;
    } catch (e) {
      return false;
    }
  }
  return false;
}

function buildChart(scores, answers) {
  const items = answers.items || [];
  const moistureUsage = items.includes('mask') || items.includes('milk') || items.includes('treatment');

  return {
    '水分不足':     clamp(scores.dryness, 5),
    '内部補修不足': clamp(scores.damage + (moistureUsage ? 0 : 1), 5),
    '熱ダメージ':   clamp(scores.heatDamage, 5),
    '毛先履歴':     clamp(scores.bleachHistory * 0.7 + scores.longHairHistory, 5),
    '頭皮環境':     clamp(scores.scalpDryness + scores.scalpOiliness, 5),
    'ボリューム':   clamp(scores.volumeLoss + scores.aging * 0.5, 5),
    'うねり':       clamp(scores.frizz, 5),
    'ツヤ':         clamp(scores.dryness * 0.5 + scores.damage * 0.5 + scores.colorFade * 0.5, 5),
  };
}

