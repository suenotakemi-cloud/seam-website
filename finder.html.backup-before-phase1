function findPopularProduct(originId, products) {
  if (!products) return null;
  const hint = POPULAR_BY_TYPE[originId];
  if (!hint) return null;
  // brand + concernTag でフィルタしてシャンプーを選ぶ
  const candidates = products.filter(p => {
    if (p.category !== 'shampoo') return false;
    if (hint.brandHint && p.brand && !p.brand.toLowerCase().includes(hint.brandHint.toLowerCase().replace(/\s+/g,''))) {
      // 部分一致(大文字小文字無視・空白無視)
      const a = (p.brand || '').toLowerCase().replace(/\s+/g,'');
      const b = hint.brandHint.toLowerCase().replace(/\s+/g,'');
      if (!a.includes(b) && !b.includes(a)) return false;
    }
    return true;
  });
  // concernHint に合うものを優先
  if (hint.concernHint && hint.concernHint.length > 0) {
    const matched = candidates.find(p => (p.concernTags || []).some(t => hint.concernHint.includes(t)));
    if (matched) return { p: matched, blurb: hint.blurb, fallbackName: hint.name };
  }
  if (candidates.length > 0) return { p: candidates[0], blurb: hint.blurb, fallbackName: hint.name };
  return null;
}

