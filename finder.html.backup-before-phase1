function buildStylistMemo(answers, scores, flags, karte) {
  const a = answers || {};
  // 年齢「答えない」(noanswer) のときはシートから "年齢" 自体を完全に出さない
  const ageVisible = a.age && a.age !== 'noanswer' && STYLIST_MEMO_AGE[a.age];
  const memo = {
    // ── ① お客様情報 ──
    clientAge:    ageVisible ? STYLIST_MEMO_AGE[a.age] : '',
    clientLength: STYLIST_MEMO_LENGTH[a.length] || '',
    // ── ② 髪の性格(キャラ) ──
    type:        karte?.origin?.name || '—',
    typeCode:    karte?.origin?.code || '',
    typeEn:      karte?.origin?.nameEn || '',
    goalType:    karte?.mainGoal?.name || '',
    // ── ③ 髪の現状 ──
    currentState: [],
    rootVolume:  STYLIST_MEMO_ROOT[a.rootVolume] || '',
    scalp:       [],
    // ── ④ 履歴 ──
    historyColor:   [],
    historyPerm:    [],
    // ── ⑤ 必須申告(アレルギー / 過去のトラブル) ──
    mandatory: [],
    // ── ⑥ 日常ケア ──
    heat:        [],
    items:       [],
    // ── ⑦ 希望 ──
    goal:        '',
    concerns:    [],
    // 補助
    cautions:    [],
    knowSelf:    [],
    wellness:    [],
    isDeep:      false,
  };

  // ── ② 任意で wellness / 体調(ヘッドスパ希望者のみ) ──
  const wellness = a.wellness || [];
  for (const w of wellness) {
    if (w !== 'well' && WELLNESS_LABEL[w]) memo.wellness.push(WELLNESS_LABEL[w]);
  }

  // ── ③ 髪の現状 ──
  if (a.thickness && STYLIST_MEMO_THICKNESS[a.thickness]) memo.currentState.push(STYLIST_MEMO_THICKNESS[a.thickness]);
  if (a.density   && STYLIST_MEMO_DENSITY[a.density])     memo.currentState.push(STYLIST_MEMO_DENSITY[a.density]);
  if (a.wave      && STYLIST_MEMO_WAVE[a.wave])           memo.currentState.push(STYLIST_MEMO_WAVE[a.wave]);
  if (a.scalpType && STYLIST_MEMO_SCALP[a.scalpType])         memo.scalp.push(STYLIST_MEMO_SCALP[a.scalpType]);
  if (a.scalpSensitivity && STYLIST_MEMO_SCALP_SENS[a.scalpSensitivity]) memo.scalp.push(STYLIST_MEMO_SCALP_SENS[a.scalpSensitivity]);

  // ── ④ 履歴 — カラー系 ──
  if (a.color && STYLIST_MEMO_COLOR[a.color])         memo.historyColor.push(STYLIST_MEMO_COLOR[a.color]);
  if (a.colorFreq && STYLIST_MEMO_COLOR_FREQ[a.colorFreq]) memo.historyColor.push(STYLIST_MEMO_COLOR_FREQ[a.colorFreq]);
  if (a.grayHair === 'yes')                            memo.historyColor.push('白髪染めをしている');
  if (a.grayFreq && STYLIST_MEMO_GRAY_FREQ[a.grayFreq])   memo.historyColor.push(STYLIST_MEMO_GRAY_FREQ[a.grayFreq]);
  if (a.bleach && STYLIST_MEMO_BLEACH[a.bleach])      memo.historyColor.push(STYLIST_MEMO_BLEACH[a.bleach]);
  if (a.bleachLocation && STYLIST_MEMO_BLEACH_LOC[a.bleachLocation]) memo.historyColor.push(STYLIST_MEMO_BLEACH_LOC[a.bleachLocation]);
  // ── ④ 履歴 — 矯正・パーマ系 ──
  if (a.straighten && STYLIST_MEMO_STRAIGHT[a.straighten]) memo.historyPerm.push(STYLIST_MEMO_STRAIGHT[a.straighten]);
  if (a.perm && STYLIST_MEMO_PERM[a.perm])            memo.historyPerm.push(STYLIST_MEMO_PERM[a.perm]);
  if (a.permType && STYLIST_MEMO_PERM_TYPE[a.permType]) memo.historyPerm.push(STYLIST_MEMO_PERM_TYPE[a.permType]);
  if (a.permLoose && STYLIST_MEMO_PERM_LOOSE[a.permLoose]) memo.historyPerm.push(STYLIST_MEMO_PERM_LOOSE[a.permLoose]);

  // ── ⑤ 必須申告 — アレルギー & 過去のヘアトラブル ──
  if (a.scalpAllergy && STYLIST_MEMO_SCALP_ALLERGY[a.scalpAllergy]) {
    memo.mandatory.push(STYLIST_MEMO_SCALP_ALLERGY[a.scalpAllergy]);
  }
  for (const t of (a.hairTrouble || [])) {
    if (STYLIST_MEMO_HAIR_TROUBLE[t]) memo.mandatory.push(STYLIST_MEMO_HAIR_TROUBLE[t]);
  }

  // ── ⑥ 日常ケア — アイロン・温度 + アイテム ──
  const tools = (a.styling && a.styling.tools) || [];
  const temp  = a.styling && a.styling.temp;
  if (tools.includes('ironDaily'))    memo.heat.push('ストレートアイロンを毎日使う');
  if (tools.includes('ironWeekly'))   memo.heat.push('ストレートアイロンを週に数回使う');
  if (tools.includes('curlerDaily'))  memo.heat.push('コテを毎日使う');
  if (tools.includes('curlerWeekly')) memo.heat.push('コテを週に数回使う');
  if (tools.includes('bangsDaily'))   memo.heat.push('前髪だけ毎日アイロン');
  if (tools.includes('rare'))         memo.heat.push('アイロン・コテはほとんど使わない');
  if (temp === 't200') memo.heat.push('普段の温度は200°C以上');
  else if (temp === 't180') memo.heat.push('普段の温度は180°C');
  else if (temp === 't160') memo.heat.push('普段の温度は160°C');
  else if (temp === 't140') memo.heat.push('普段の温度は140°C以下');
  // heatProtect は配列。複数選択に対応してすべてカルテに反映
  const hpList = Array.isArray(a.heatProtect) ? a.heatProtect : (a.heatProtect ? [a.heatProtect] : []);
  for (const hp of hpList) {
    if (STYLIST_MEMO_HEAT_PROTECT[hp]) memo.heat.push(STYLIST_MEMO_HEAT_PROTECT[hp]);
  }
  for (const it of (a.items || [])) {
    if (STYLIST_MEMO_ITEMS[it]) memo.items.push(STYLIST_MEMO_ITEMS[it]);
  }

  // ── ⑦ 希望 — 悩み & ゴール ──
  for (const c of (a.concerns || [])) {
    if (STYLIST_MEMO_CONCERN_LABEL[c]) memo.concerns.push(STYLIST_MEMO_CONCERN_LABEL[c]);
  }
  if (a.goalTexture && STYLIST_MEMO_GOAL[a.goalTexture]) memo.goal = STYLIST_MEMO_GOAL[a.goalTexture];

  // 注意点
  if (flags?.heatColorWarning)  memo.cautions.push('カラーの褪色に注意したい');
  if (flags?.heatBleachWarning) memo.cautions.push('施術前は熱履歴を必ず申告したい');

  // 自分でわかっていること
  if (karte?.origin?.hiddenConcern) memo.knowSelf.push(karte.origin.hiddenConcern);

  // 詳細回答(Mode B)が含まれていれば isDeep
  memo.isDeep = !!(a.age || a.rootVolume || a.scalpType || a.colorFreq || a.grayHair || a.bleachLocation || a.permType || a.heatProtect || a.scalpAllergy || a.hairTrouble);

  return memo;
}

