function getAxisComment(label, score) {
  const map = AXIS_COMMENT_MAP[label];
  if (!map) return '';
  if (score >= 70) return map.high;
  if (score >= 40) return map.mid;
  return map.low;
}

function deriveDiagnosisSummary(karte, answers, scores, chart) {
  if (!karte || !karte.origin) return null;
  const origin = karte.origin;
  const radar = karte.radar || [3, 3, 3, 3, 3];
  const code = origin.code || '';
  const typeNumber = TYPE_NUMBER_MAP[code] || '—';
  const typeShort = TYPE_SHORT_NAME[code] || { jp:'あなたの髪質型', en:'YOUR HAIR TYPE', need:'最適なケア' };

  // レーダーラベル + スコア(20-100に変換: radar 1-5 → 20/40/60/80/100)
  const labels = ['透明感', '艶', 'まとまり', '華やぎ', '頭皮'];
  const radarItems = labels.map((l, i) => ({
    label: l,
    score: Math.round((radar[i] || 3) * 20),
  }));

  // ★3 verdict — 最弱の項目から「総合診断」と「優先ケア」を生成
  const sorted = [...radarItems].sort((a,b) => a.score - b.score);
  const weakest = sorted[0];
  const second = sorted[1];
  const verdictMap = {
    '透明感':'キューティクルが乱れ、光の反射が弱い',
    '艶':'ツヤ感が低下し、毛髪表面が荒れている',
    'まとまり':'広がりやすく、まとまりにくい',
    '華やぎ':'ボリューム・密度感の物足りなさ',
    '頭皮':'頭皮環境の整えが必要',
  };
  const carePriorityMap = {
    '透明感':'補修', '艶':'補修', 'まとまり':'保湿+質感調整', '華やぎ':'ハリ・コシ強化', '頭皮':'頭皮ケア',
  };
  const overallVerdict = `${verdictMap[weakest.label] || ''}状態。`;
  const carePriorityList = [...new Set([carePriorityMap[weakest.label], carePriorityMap[second.label], '継続ケア'])].filter(Boolean);

  // 悩みチップ (最大4つ、ない場合は characterから推定)
  const userConcerns = (answers?.concerns || []);
  let concernChips = userConcerns
    .map(c => CONCERN_CHIP_LABEL[c])
    .filter(Boolean)
    .slice(0, 4);
  // フォールバック: hiddenConcernから推定
  if (concernChips.length === 0) {
    if (origin.id.includes('dry') || origin.id.includes('rabbit') || origin.id.includes('arctic'))
      concernChips = [CONCERN_CHIP_LABEL.dry, CONCERN_CHIP_LABEL.rough, CONCERN_CHIP_LABEL.tangle, CONCERN_CHIP_LABEL.noShine];
    else if (origin.id.includes('wave') || origin.id.includes('alpaca') || origin.id.includes('afghan'))
      concernChips = [CONCERN_CHIP_LABEL.wave, CONCERN_CHIP_LABEL.frizz, CONCERN_CHIP_LABEL.rough, CONCERN_CHIP_LABEL.tangle];
    else if (origin.id.includes('cloud') || origin.id.includes('sheep') || origin.id.includes('lion'))
      concernChips = [CONCERN_CHIP_LABEL.volumeDown, CONCERN_CHIP_LABEL.frizz, CONCERN_CHIP_LABEL.rough, CONCERN_CHIP_LABEL.dry];
    else
      concernChips = [CONCERN_CHIP_LABEL.dry, CONCERN_CHIP_LABEL.noShine, CONCERN_CHIP_LABEL.damage, CONCERN_CHIP_LABEL.tangle];
  }

  // 強み (originの強み + character)
  const strengths = [];
  if (origin.strength) strengths.push(origin.strength);
  if (origin.charmHint) strengths.push(origin.charmHint);
  if (strengths.length < 3) strengths.push('丁寧なケアでより輝ける素質');

  // 課題 (radar の弱い項目 + hiddenConcern)
  const challenges = [];
  const weak = radarItems.filter(r => r.score <= 40).map(r => r.label);
  if (weak.length > 0) challenges.push(`${weak.slice(0,2).join('・')}が課題`);
  if (origin.hiddenConcern) challenges.push(origin.hiddenConcern);
  if (challenges.length < 3) challenges.push('日々のケア習慣を整える余地あり');

  // ケアアプローチ4ステップ (動的に主課題から導出)
  const lowestScore = Math.min(...radarItems.map(r => r.score));
  const careSteps = [];
  // Step 1: いつも何を補うか
  if (radar[1] <= 3 || (scores?.dryness || 0) >= 3 || userConcerns.includes('dry')) {
    careSteps.push({ icon:'💧', title:'うるおい補給', description:'水分を与え、保湿力を高める' });
  } else {
    careSteps.push({ icon:'✦', title:'毎日のクレンジング', description:'やさしく汚れだけを落とす' });
  }
  // Step 2: ダメージ補修
  if (userConcerns.includes('damage') || userConcerns.includes('split') || (scores?.damage || 0) >= 3) {
    careSteps.push({ icon:'❉', title:'ダメージ補修', description:'キューティクルを整え、ダメージをケア' });
  } else {
    careSteps.push({ icon:'☘', title:'髪を健やかに', description:'内側から強くしなやかに' });
  }
  // Step 3: 質感コントロール
  if (userConcerns.includes('frizz') || userConcerns.includes('wave')) {
    careSteps.push({ icon:'〰', title:'質感コントロール', description:'広がりを抑え、まとまりやすく' });
  } else if (userConcerns.includes('volumeDown') || userConcerns.includes('topFlat')) {
    careSteps.push({ icon:'↑', title:'ボリュームアップ', description:'根元から軽やかに立ち上げる' });
  } else {
    careSteps.push({ icon:'✺', title:'ツヤを引き出す', description:'光を反射する髪へ仕上げる' });
  }
  // Step 4: 継続ケア
  careSteps.push({ icon:'◯', title:'継続ケア', description:'毎日のケアで理想の髪へ導く' });

  return {
    typeNumber, typeShort,
    overallVerdict, carePriorityList,
    radarItems, concernChips,
    strengths: strengths.slice(0,3),
    challenges: challenges.slice(0,3),
    careSteps,
  };
}

