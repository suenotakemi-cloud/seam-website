                ? 'bg-ink text-ivory hover:bg-charcoal'
                : 'bg-mist text-charcoal/40 cursor-not-allowed',
            ].join(' ')}
          >
            <span className={valid ? 'text-goldLight' : 'text-charcoal/40'}>
              {safeIdx >= total - 1 ? 'Submit' : 'Next'}
