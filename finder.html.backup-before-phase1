function clampVal(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

function computeKarteRadar(answers, scores) {
  const a = answers || {};
  const s = scores || {};

  let lightness = 3;
  if (a.thickness === 'thin')   lightness += 1;
  if (a.thickness === 'thick')  lightness -= 1;
  if (a.density === 'low')      lightness += 1;
  if (a.density === 'high')     lightness -= 1;
  if (s.bleachHistory >= 3)     lightness += 1;
  lightness = clampVal(Math.round(lightness), 1, 5);

  let luster = 4;
  if (s.damage >= 5)        luster -= 2;
  else if (s.damage >= 3)   luster -= 1;
  if (s.heatDamage >= 4)    luster -= 1;
  if (s.colorFade >= 3)     luster -= 1;
  if (s.bleachHistory >= 4) luster -= 1;
  luster = clampVal(Math.round(luster), 1, 5);

  let smoothness = 4;
  if (a.wave === 'humid' || a.wave === 'surface') smoothness -= 1;
  if (a.wave === 'root'  || a.wave === 'midEnd')  smoothness -= 2;
  if (a.wave === 'whole')                          smoothness -= 3;
  if (a.wave === 'straightened')                   smoothness += 1;
  if (s.frizz >= 3) smoothness -= 1;
  smoothness = clampVal(Math.round(smoothness), 1, 5);

  let volume = 3;
  if (a.thickness === 'thick') volume += 1;
  if (a.thickness === 'thin')  volume -= 1;
  if (a.density === 'high')    volume += 1;
  if (a.density === 'low')     volume -= 1;
  if (s.volumeLoss >= 2)       volume -= 1;
  if (a.wave === 'humid' || a.wave === 'whole') volume += 1;
  volume = clampVal(Math.round(volume), 1, 5);

  let scalp = 4;
  if (s.scalpDryness  >= 3) scalp -= 2;
  else if (s.scalpDryness  >= 2) scalp -= 1;
  if (s.scalpOiliness >= 3) scalp -= 2;
  else if (s.scalpOiliness >= 2) scalp -= 1;
  scalp = clampVal(Math.round(scalp), 1, 5);

  return [lightness, luster, smoothness, volume, scalp];
}

function selectOriginAnimalId(answers, scores, radar) {
  const a = answers || {};
  const s = scores || {};
  const [light, lust, smooth, vol, scp] = radar;

  // ── 極端なパターン優先 ──
  // sky-finch: 細毛+低密度+低ボリュームの "ぺたんとボリュームレス" 専用(rootVolume:flat 必須)
  if (a.thickness === 'thin' && a.density === 'low' && (a.rootVolume === 'flat' || a.rootVolume === 'tendFlat') && vol <= 1) return 'sky-finch';
  if (a.thickness !== 'thick' && s.scalpOiliness >= 3)            return 'moonlit-persian';
  if (a.wave === 'whole' && s.scalpDryness >= 3)                   return 'snow-samoyed';
  if (a.wave === 'whole' && ['shoulderDown','chestUp','long'].includes(a.length)) return 'silk-afghan';
  if (a.wave === 'whole')                                          return 'snow-samoyed';

  if (a.thickness === 'thick' && a.density === 'high')             return 'proud-lion';

  if (a.thickness === 'thick' && s.damage >= 3)                    return 'silent-panther';
  if (a.thickness === 'thick' && a.density === 'normal')           return 'silent-panther';
  if (a.thickness === 'thick')                                     return 'irish-setter';

  if ((a.wave === 'humid' || a.wave === 'surface') && a.thickness === 'thin') return 'breeze-poodle';
  if (a.wave === 'humid' || a.wave === 'surface')                  return 'wave-alpaca';
  if (a.wave === 'midEnd' || a.wave === 'root')                    return 'wave-alpaca';

  // ── thin 専用 ──
  if (a.thickness === 'thin') {
    if (s.scalpDryness >= 2 && a.density !== 'low')               return 'cloud-sheep';     // 細毛 + 乾燥頭皮(普通密度)
    if (s.scalpDryness >= 2 || a.environment === 'dry')           return 'arctic-fox';      // 細毛 + 低密度乾燥
    if (a.density === 'low')                                       return 'silk-fennec';     // 細毛 + 低密度(rootVolume不問)
    if (a.rootVolume === 'lift' && s.damage < 2 && scp >= 4)      return 'dappled-fawn';    // 細毛 + 普通密度 + ふんわり立ち上がり
    return 'soft-rabbit';                                                                    // 細毛 デフォルト
  }

  // ── normal thickness 専用 ──
  if (s.scalpDryness >= 2 || s.scalpOiliness >= 2)                 return 'still-fold';     // 普通 + 頭皮トラブル(cloud-sheep より先に判定)
  if (s.damage < 2 && (a.goalTexture === 'glossy' || a.goalTexture === 'moist')) return 'velvet-cat';
  if (a.rootVolume === 'lift' && s.damage < 2 && scp >= 4)         return 'meerkat';        // 普通 + ふんわり + 低ダメージ + 健やかな頭皮
  return 'osmanthus-shiba';                                                                   // 普通 デフォルト
}

const KARTE_GOAL_TEXTURE_TO_DIR = {
  moist:'C', glossy:'B', firm:'D', smooth:'C', airy:'D', soft:'A',
};
const KARTE_GOAL_INTENT_TO_DIR = {
  growLong:'C', keepColor:'A', firm:'D', easy:'C', ends:'C', idle:'A',
};

function selectGoalDirection(answers, radar) {
  const a = answers || {};
  if (a.goalTexture && KARTE_GOAL_TEXTURE_TO_DIR[a.goalTexture]) return KARTE_GOAL_TEXTURE_TO_DIR[a.goalTexture];
  if (a.goal && KARTE_GOAL_INTENT_TO_DIR[a.goal])                return KARTE_GOAL_INTENT_TO_DIR[a.goal];
  // フォールバック: もっとも低い軸を伸ばす
  const order = ['A','B','C','D'];
  const idx = [0,1,2,3].sort((x,y) => radar[x] - radar[y])[0];
  return order[idx];
}

function selectPoeticStates(answers, scores, maxCount = 2) {
  const matched = KARTE_POETIC_STATES
    .filter(st => { try { return st.match(scores, answers); } catch(e){ return false; } })
    .sort((a,b) => b.priority - a.priority);
  // 必ず1つは出す
  const picked = matched.slice(0, maxCount);
  if (picked.length) return picked;
  const fallback = KARTE_POETIC_STATES.find(s => s.id === 'calm') || KARTE_POETIC_STATES[KARTE_POETIC_STATES.length - 1];
  return [fallback];
}

function selectAdviceKey(scores) {
  const s = scores || {};
  if (s.heatDamage >= 4)     return 'heat';
  if (s.damage >= 5)         return 'damage';
  if (s.scalpDryness >= 2 || s.scalpOiliness >= 2) return 'scalp';
  if (s.frizz >= 3)          return 'frizz';
  if (s.colorFade >= 3)      return 'color';
  if (s.dryness >= 3)        return 'dry';
  if (s.volumeLoss >= 2)     return 'volume';
  return 'calm';
}

function deriveTargetRadar(currentRadar, direction) {
  const t = [...currentRadar];
  // 軸: [透明感, 艶, まとまり, 華やぎ, 頭皮]
  const boost = (i, n) => { t[i] = Math.min(5, t[i] + n); };
  if (direction === 'A') { boost(0, 2); boost(1, 1); } // 透明感の道
  if (direction === 'B') { boost(1, 2); boost(2, 1); } // 艶の道
  if (direction === 'C') { boost(2, 2); boost(1, 1); } // まとまりの道
  if (direction === 'D') { boost(3, 2); boost(1, 1); } // 華やぎの道
  // 頭皮は常に少し改善
  boost(4, 1);
  return t;
}

function resolveKarteAnimal(answers, scores) {
  const radar = computeKarteRadar(answers, scores);
  // キャラ既知ショートカット: ユーザーが picker で選んだ id、または共有URLの id を最優先
  const forcedId = answers && (answers._knownOriginId || answers._sharedOriginId);
  const originId = (forcedId && KARTE_ORIGIN_ANIMALS[forcedId])
    ? forcedId
    : selectOriginAnimalId(answers, scores, radar);
  const origin = KARTE_ORIGIN_ANIMALS[originId];

  const direction = selectGoalDirection(answers, radar);
  const mainGoalId = origin.targets[direction];

  const subDirs = ['A','B','C','D'].filter(d => d !== direction);
  const subGoals = subDirs.map(d => ({ dir:d, id: origin.targets[d] }));

  const states = selectPoeticStates(answers, scores, 2);
  const stateText = states.map(s => s.text).join('、');

  const adviceKey = selectAdviceKey(scores);
  const adviceText = KARTE_ADVICE[adviceKey];

  const targetRadar = deriveTargetRadar(radar, direction);

  return {
    radar, targetRadar,
    originId, origin,
    direction,
    mainGoalId, mainGoal: KARTE_GOAL_ANIMALS[mainGoalId],
    subGoals: subGoals.map(g => ({ dir:g.dir, id:g.id, goal: KARTE_GOAL_ANIMALS[g.id] })),
    stateText, states,
    adviceKey, adviceText,
  };
}

/* ---------- KarteEvolutionMark — 原型→進化のセレモニー ---------- */
function KarteEvolutionMark({ size = 100, intersect = true, replayKey = 0 }) {
  const s = size;
  // IntersectionObserver でビューポート入りの瞬間を捉える
  const ref = useRef(null);
  const [active, setActive] = useState(!intersect);

  useEffect(() => {
    // replayKey が変わったらアニメ再生(一旦 false→ 次の frame で true)
    if (replayKey > 0) {
      setActive(false);
      const id = setTimeout(() => setActive(true), 60);
      return () => clearTimeout(id);
    }
  }, [replayKey]);

  useEffect(() => {
    if (!intersect) return;
    const el = ref.current;
    if (!el || typeof IntersectionObserver === 'undefined') { setActive(true); return; }
    const io = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) { setActive(true); io.disconnect(); }
    }, { threshold: 0.4 });
    io.observe(el);
    return () => io.disconnect();
  }, [intersect]);

  return (
    <div ref={ref} className="relative inline-flex items-center justify-center gap-3 sm:gap-5">
      {/* 原型(左・薄く小さく) */}
      <div className={`relative ${active ? 'karte-evo-origin' : 'opacity-0'}`} style={{ width: s*0.62, height: s*0.62 }}>
