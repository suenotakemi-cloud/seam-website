// items 回答(現使用) → 商品カテゴリ への対応
const USAGE_TO_CATEGORY = {
  shampoo:    ['shampoo','scalp-shampoo','scalp-cleanser'],
  treatment:  ['treatment'],
  mask:       ['hair-mask','mask'],
  oil:        ['leave-in-oil','out-bath-oil','outbath-oil','outbath-butter'],
  milk:       ['leave-in-milk','out-bath-milk','outbath-milk','outbath-cream'],
  scalp:      ['scalp-essence','scalp-shampoo'],
  essence:    ['scalp-essence','leave-in-essence','booster'],
  heatMist:   ['leave-in-mist','outbath-mist','outbath-water','outbath-mousse'],
};

function getUnusedCategories(answers) {
  const items = answers?.items || [];
  const used = new Set();
  for (const it of items) {
    (USAGE_TO_CATEGORY[it] || []).forEach(c => used.add(c));
  }
  // すべてのカテゴリのうち、使っていないもの
  const allCats = new Set();
  Object.values(USAGE_TO_CATEGORY).forEach(arr => arr.forEach(c => allCats.add(c)));
  const unused = [];
  for (const c of allCats) if (!used.has(c)) unused.push(c);
  return unused;
}

function buildShowcase(products, answers, scores, flags) {
  if (!products || products.length === 0) return null;
  const userTags  = (typeof buildUserTags === 'function') ? buildUserTags(answers, scores) : { base:[], state:[], goal:[], scalp:[], heat:[], color:[], perm:[], age:[] };
  const hardRules = (typeof checkHardRules === 'function') ? checkHardRules(userTags, answers, scores) : [];
  const isDeep    = (userTags.scalp?.length || userTags.heat?.length || userTags.color?.length || userTags.perm?.length || userTags.age?.length || 0) > 0;
  const unusedCategories = new Set(getUnusedCategories(answers));

  // 業務用(salonOnly)・販売しない商品はカタログから除外
  const filtered = products.filter(p => !p.salonOnly);
  // 全商品をスコアリング
  const scored = filtered.map(p => {
    const base    = scoreSeamProduct(p, answers, scores, flags);
    const deep    = (isDeep && typeof scoreProductDeep === 'function') ? scoreProductDeep(p, userTags, hardRules) : 0;
    const penalty = (isDeep && typeof applyPenalties === 'function') ? applyPenalties(p, userTags) : 0;
    // 未使用カテゴリの商品は「いま一番おすすめ」としてブースト(+25)
    const unusedBoost = unusedCategories.has(p.category) ? 25 : 0;
    return { p, s: Math.max(0, base + deep - penalty + unusedBoost), _unusedBoost: unusedBoost > 0 };
  }).filter(x => x.s > 0);

  // カテゴリごとに上位5件を抽出
  // JSON側の表記ゆれ(out-bath-oil/outbath-oil/leave-in-oil等)を正規化して集約
  const byCategory = {};
  for (const item of scored) {
    const key = normalizeCategory(item.p.category);
    if (!key) continue;
    if (!byCategory[key]) byCategory[key] = [];
    byCategory[key].push(item);
  }
  for (const k in byCategory) byCategory[k].sort((a,b) => b.s - a.s);

  // ★ 役割ベースのキュレートラベル
  const ROLE_LABEL = {
    primary:     'もっとも合いやすい提案',
    alternative: '同じ方向で選べるもうひとつ',
    different:   '少し印象を変えるならこちら',
  };

  // 表示カテゴリ — 3商品 (主役 + 代替 + 別方向) で構成
  const sections = [];
  const seen = new Set();
  for (const cat of SHOWCASE_CATEGORIES) {
    const key = normalizeCategory(cat.id);
    if (seen.has(key)) continue;
    seen.add(key);
    const items = byCategory[key];
    if (!items || items.length === 0) continue;

    const top = items[0];
    const rest = items.slice(1);

    // "Different Direction": 1〜2位とは別ブランド・別ラインから選ぶ
    // (同ブランドが続くのを防ぎ「別の選択肢」感を出す)
    const topBrand = (top.p.brand || '').toLowerCase();
    const secondCandidate = rest[0];
    const secondBrand = (secondCandidate?.p?.brand || '').toLowerCase();
    let alt = secondCandidate || null;
    let diff = null;
    for (const cand of rest.slice(1)) {
      const candBrand = (cand.p.brand || '').toLowerCase();
      if (candBrand !== topBrand && candBrand !== secondBrand) {
        diff = cand;
        break;
      }
    }
    // diff が見つからなければ rest の中で 3 番目を採用
    if (!diff && rest.length >= 2) diff = rest[1];

    const composed = [];
    if (top)  composed.push({ ...top,  role: 'primary',     roleLabel: ROLE_LABEL.primary });
    if (alt)  composed.push({ ...alt,  role: 'alternative', roleLabel: ROLE_LABEL.alternative });
    if (diff) composed.push({ ...diff, role: 'different',   roleLabel: ROLE_LABEL.different });

    sections.push({ id: key, label: cat.label, desc: cat.desc, primary: cat.primary !== false, items: composed });
  }
  return sections;
}

function ProductMatchDots({ percent }) {
