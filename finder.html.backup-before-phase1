  colorFade:  ['color-fade', 'multi-bleach'],
  grayFade:   ['gray-fade', 'color-fade'],
  volumeDown: ['volume-down', 'no-volume', 'flat', 'thin-hair', 'fine-hair', 'no-firmness'],
  topFlat:    ['top-flat', 'flat', 'no-volume', 'thin-hair', 'fine-hair'],
  scalpDry:   ['scalp-dry', 'scalp-sensitive'],
  scalpOily:  ['scalp-oily', 'buildup', 'scalp-odor', 'dandruff'],
  thinning:   ['thinning', 'hairloss', 'thin-hair', 'fine-hair', 'no-firmness', 'no-volume'],
};
function concernMatches(c, productConcernTags) {
  const tags = CONCERN_TO_TAGS[c] || (CONCERN_TO_TAG[c] ? [CONCERN_TO_TAG[c]] : []);
  for (const t of tags) {
    if (productConcernTags.includes(t)) return true;
  }
  return false;
}
// 並び順スコア: タグが先頭に近いほど "そのラインの主要悩み" として強くマッチング
function concernPositionBoost(c, productConcernTags) {
  const tags = CONCERN_TO_TAGS[c] || (CONCERN_TO_TAG[c] ? [CONCERN_TO_TAG[c]] : []);
  let bestIdx = -1;
  for (const t of tags) {
    const idx = productConcernTags.indexOf(t);
    if (idx !== -1 && (bestIdx === -1 || idx < bestIdx)) bestIdx = idx;
  }
  if (bestIdx === -1) return 0;
  // 先頭(idx=0) → +15, 2番目 → +12, 3番目 → +9, 4番目 → +6, 5番目以降 → +3
  return [15, 12, 9, 6, 3][Math.min(bestIdx, 4)] || 3;
}
