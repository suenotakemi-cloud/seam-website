  return canvas.toDataURL('image/png');
}

function drawCanvasPentagonDark(ctx, cx, cy, radius, values) {
  const angleFor = (i) => (-Math.PI / 2) + (i * 2 * Math.PI / 5);
  for (let lv = 1; lv <= 5; lv++) {
    const r = (lv / 5) * radius;
    ctx.beginPath();
    for (let i = 0; i < 5; i++) {
      const a = angleFor(i);
      const x = cx + r * Math.cos(a);
      const y = cy + r * Math.sin(a);
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.strokeStyle = lv === 5 ? 'rgba(217,190,147,0.45)' : 'rgba(217,190,147,0.18)';
    ctx.lineWidth = lv === 5 ? 1.4 : 0.9;
    ctx.stroke();
  }
  ctx.strokeStyle = 'rgba(217,190,147,0.18)';
  ctx.lineWidth = 0.9;
  for (let i = 0; i < 5; i++) {
    const a = angleFor(i);
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + radius * Math.cos(a), cy + radius * Math.sin(a));
    ctx.stroke();
  }
  ctx.beginPath();
  for (let i = 0; i < 5; i++) {
    const v = values[i] || 3;
    const r = (v / 5) * radius;
    const a = angleFor(i);
    const x = cx + r * Math.cos(a);
    const y = cy + r * Math.sin(a);
    if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
  }
  ctx.closePath();
  ctx.fillStyle = 'rgba(184,148,90,0.28)';
  ctx.fill();
  ctx.strokeStyle = '#B8945A';
  ctx.lineWidth = 2;
  ctx.stroke();
  ctx.fillStyle = '#B8945A';
  for (let i = 0; i < 5; i++) {
    const v = values[i] || 3;
    const r = (v / 5) * radius;
    const a = angleFor(i);
    const x = cx + r * Math.cos(a);
    const y = cy + r * Math.sin(a);
    ctx.beginPath();
    ctx.arc(x, y, 5, 0, Math.PI * 2);
    ctx.fill();
  }
}

async function saveStylistMemoAsSnsImage(memo, filename) {
  const W = 1080, H = 1920;
  const canvas = document.createElement('canvas');
  canvas.width = W; canvas.height = H;
  const ctx = canvas.getContext('2d');

  // 背景
  const bgGrad = ctx.createLinearGradient(0, 0, 0, H);
  bgGrad.addColorStop(0, '#FAF8F4');
  bgGrad.addColorStop(1, '#F2EEE6');
  ctx.fillStyle = bgGrad;
  ctx.fillRect(0, 0, W, H);

  // ゴールドライン上下
  ctx.fillStyle = '#B8945A';
  ctx.fillRect(60, 60, W - 120, 1);
  ctx.fillRect(60, H - 60, W - 120, 1);

  const fontMono = "'Montserrat', 'Helvetica Neue', Arial, sans-serif";
  const fontSerif = "'Cormorant Garamond', 'Noto Serif JP', serif";
  const fontJP = "'Noto Serif JP', 'Cormorant Garamond', serif";

  let y = 130;
  const padX = 90;

  // ヘッダー
  ctx.fillStyle = '#B8945A';
  ctx.font = `500 22px ${fontMono}`;
  ctx.textAlign = 'left';
  ctx.fillText('— FOR YOUR STYLIST', padX, y);

  y += 50;
  ctx.fillStyle = '#1A1815';
  ctx.font = `400 56px ${fontJP}`;
  ctx.fillText('わたしの髪のこと', padX, y);

  // 日付(右上)
  ctx.fillStyle = '#8C7A63';
  ctx.font = `400 20px ${fontMono}`;
  ctx.textAlign = 'right';
  ctx.fillText(new Date().toISOString().slice(0,10), W - padX, 130);

  ctx.textAlign = 'left';
  y += 30;
  ctx.fillStyle = '#E2DDD3';
  ctx.fillRect(padX, y, W - padX*2, 1);

  // 項目を順次描画する helper
  const drawSection = (label, value, options = {}) => {
    if (!value || (Array.isArray(value) && value.length === 0)) return;
    y += 50;
    ctx.fillStyle = '#B8945A';
    ctx.font = `500 22px ${fontMono}`;
    ctx.fillText(label, padX, y);
    y += 42;
    ctx.fillStyle = '#1A1815';
    ctx.font = `400 ${options.large ? 36 : 28}px ${fontJP}`;
    if (Array.isArray(value)) {
      value.forEach(line => {
        ctx.fillText(`・${line}`, padX, y);
        y += 40;
      });
    } else {
      ctx.fillText(value, padX, y);
    }
  };

  // 髪タイプ(大)
  if (memo.type) {
    y += 30;
    ctx.fillStyle = '#B8945A';
    ctx.font = `500 22px ${fontMono}`;
    ctx.fillText('髪タイプ', padX, y);
    y += 50;
    ctx.fillStyle = '#1A1815';
    ctx.font = `400 56px ${fontJP}`;
    ctx.fillText(memo.type, padX, y);
    if (memo.typeCode) {
      ctx.fillStyle = '#8C7A63';
      ctx.font = `400 22px ${fontMono}`;
      ctx.fillText(`  ${memo.typeCode}`, padX + ctx.measureText(memo.type).width, y);
    }
    if (memo.goalType) {
      y += 38;
      ctx.fillStyle = '#8C7A63';
      ctx.font = `400 24px ${fontJP}`;
      ctx.fillText(`目指すのは ${memo.goalType}`, padX, y);
    }
  }

  if (memo.length)      drawSection('いまの長さ', memo.length);
  if (memo.age)         drawSection('年代', memo.age);
  if (memo.scalp && memo.scalp.length) drawSection('頭皮の状態', memo.scalp);
  if (memo.rootVolume)  drawSection('根元の様子', memo.rootVolume);
  if (memo.history && memo.history.length)   drawSection('最近したこと', memo.history.slice(0, 4));
  if (memo.concerns && memo.concerns.length) drawSection('気になっていること', memo.concerns.slice(0, 4));
  if (memo.heat && memo.heat.length)         drawSection('アイロン・コテ', memo.heat.slice(0, 3));
  if (memo.goal)        drawSection('なりたい仕上がり', memo.goal);
  if (memo.wellness && memo.wellness.length) drawSection('気になる症状', memo.wellness.slice(0, 3));

  // フッター
  ctx.fillStyle = '#B8945A';
  ctx.font = `500 18px ${fontMono}`;
  ctx.textAlign = 'center';
  ctx.fillText('— SEAM · HAIR MEMO', W/2, H - 100);
  ctx.fillStyle = '#8C7A63';
  ctx.font = `400 14px ${fontMono}`;
  ctx.fillText(`${memo.typeEn || ''}  ·  seam.site`, W/2, H - 75);

  const link = document.createElement('a');
  link.download = filename || `SEAM-memo-${new Date().toISOString().slice(0,10)}.png`;
  link.href = canvas.toDataURL('image/png');
  link.click();
}

function drawCanvasPentagon(ctx, cx, cy, radius, values) {
  const angleFor = (i) => (-Math.PI / 2) + (i * 2 * Math.PI / 5);
  const labels = ['透明感', '艶', 'まとまり', '華やぎ', '頭皮'];

  // グリッド
  for (let lv = 1; lv <= 5; lv++) {
    const r = (lv / 5) * radius;
    ctx.beginPath();
    for (let i = 0; i < 5; i++) {
      const a = angleFor(i);
      const x = cx + r * Math.cos(a);
      const y = cy + r * Math.sin(a);
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.strokeStyle = lv === 5 ? '#D6C7B0' : '#E7E4DE';
    ctx.lineWidth = lv === 5 ? 1.4 : 1.0;
    ctx.stroke();
  }

  // 軸線
  ctx.strokeStyle = '#E7E4DE';
  ctx.lineWidth = 1;
  for (let i = 0; i < 5; i++) {
    const a = angleFor(i);
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + radius * Math.cos(a), cy + radius * Math.sin(a));
    ctx.stroke();
  }

  // データ
  ctx.beginPath();
  for (let i = 0; i < 5; i++) {
    const v = values[i] || 3;
    const r = (v / 5) * radius;
    const a = angleFor(i);
    const x = cx + r * Math.cos(a);
    const y = cy + r * Math.sin(a);
    if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
  }
  ctx.closePath();
  ctx.fillStyle = 'rgba(184,148,90,0.16)';
  ctx.fill();
  ctx.strokeStyle = '#B8945A';
  ctx.lineWidth = 2;
  ctx.stroke();

  // 頂点ドット
  ctx.fillStyle = '#B8945A';
  for (let i = 0; i < 5; i++) {
    const v = values[i] || 3;
    const r = (v / 5) * radius;
    const a = angleFor(i);
    const x = cx + r * Math.cos(a);
    const y = cy + r * Math.sin(a);
    ctx.beginPath();
    ctx.arc(x, y, 5, 0, Math.PI * 2);
    ctx.fill();
  }

  // ラベル
  ctx.fillStyle = '#3D3833';
  ctx.font = "500 14px 'Montserrat', sans-serif";
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  for (let i = 0; i < 5; i++) {
    const a = angleFor(i);
    const lr = radius + 30;
    const x = cx + lr * Math.cos(a);
    const y = cy + lr * Math.sin(a);
    ctx.fillText(labels[i], x, y - 8);
    ctx.fillStyle = '#B8945A';
    ctx.font = "400 18px 'Cormorant Garamond', serif";
    ctx.fillText(String(values[i] || 3), x, y + 10);
    ctx.fillStyle = '#3D3833';
    ctx.font = "500 14px 'Montserrat', sans-serif";
  }
}

