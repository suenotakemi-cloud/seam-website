          <span
            className={[
              'w-4 h-4 border inline-flex items-center justify-center shrink-0 rounded-[1px]',
              yesActive ? 'border-ivory bg-ivory' : 'border-line group-hover:border-ink',
            ].join(' ')}
            aria-hidden
          >
            {yesActive && (
              <svg viewBox="0 0 12 12" className="w-2.5 h-2.5">
                <path d="M2 6.5 L 5 9 L 10 3" stroke="#1A1815" strokeWidth="1.5" fill="none" strokeLinecap="round" strokeLinejoin="round" />
              </svg>
            )}
          </span>
        </button>

        <button
          type="button"
          onClick={handleNo}
          className={[
            'group px-4 sm:px-5 py-4 border transition-all flex items-center justify-between gap-3 rounded-[2px] text-left',
            noActive ? 'bg-ink text-ivory border-ink' : 'bg-white/70 text-charcoal border-line hover:border-ink',
          ].join(' ')}
        >
          <span>
            <span className={['block font-mono tracking-widest2 text-[9.5px] uppercase mb-1',
              noActive ? 'text-goldLight' : 'text-charcoal/45'].join(' ')}>No</span>
            <span className={['block font-serif text-[15.5px] sm:text-[16.5px]',
              noActive ? 'text-ivory' : 'text-ink'].join(' ')}>{(noneOpt && noneOpt.label) || 'していない'}</span>
          </span>
          <span
            className={[
              'w-4 h-4 border inline-flex items-center justify-center shrink-0 rounded-[1px]',
              noActive ? 'border-ivory bg-ivory' : 'border-line group-hover:border-ink',
            ].join(' ')}
            aria-hidden
          >
            {noActive && (
              <svg viewBox="0 0 12 12" className="w-2.5 h-2.5">
                <path d="M2 6.5 L 5 9 L 10 3" stroke="#1A1815" strokeWidth="1.5" fill="none" strokeLinecap="round" strokeLinejoin="round" />
              </svg>
            )}
          </span>
        </button>
      </div>

      {/* Detail options (only when Yes) */}
      {showDetails && (
        <div className="mt-6 anim-fade-up">
