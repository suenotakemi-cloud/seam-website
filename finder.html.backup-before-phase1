          <g stroke="#D9BE93" strokeWidth="0.9" fill="none" strokeLinecap="round" opacity="0.65">
            <path d="M50 28 L57 50 L50 72 L43 50 Z" />
            <circle cx="50" cy="50" r="3.2" fill="#D9BE93" stroke="none" />
          </g>
        </svg>
      </div>

      {/* 矢印 */}
      <div className={`relative ${active ? 'karte-evo-arrow' : 'opacity-0'}`} aria-hidden>
        <svg viewBox="0 0 40 8" width={s*0.45} height="8" className="opacity-70">
          <line x1="0" y1="4" x2="34" y2="4" stroke="#D9BE93" strokeWidth="1" />
