const QUIZ_CHAPTERS = [
  { id:'now',     index:1, title:'髪の悩みと特徴',     subTitle:'まず、いまの悩みと髪のタイプを伺います。',         startIdx:0,  endIdx:4  },
  { id:'history', index:2, title:'髪の履歴',           subTitle:'これまでの施術と、アイロンの使い方を伺います。',   startIdx:5,  endIdx:9  },
  { id:'daily',   index:3, title:'いまの生活',         subTitle:'普段の習慣と、まわりの環境を伺います。',           startIdx:10, endIdx:13 },
  { id:'goal',    index:4, title:'目指したい仕上がり', subTitle:'これから目指したい髪を伺います。',                 startIdx:14, endIdx:15 },
  { id:'salon',   index:5, title:'サロンでの相談',     subTitle:'ヘッドスパなど、サロンでのご提案について伺います。', startIdx:16, endIdx:17 },
];
function getChapterFor(idx) {
  return QUIZ_CHAPTERS.find(c => idx >= c.startIdx && idx <= c.endIdx) || QUIZ_CHAPTERS[0];
}
function isChapterStart(idx) {
  return QUIZ_CHAPTERS.some(c => c.startIdx === idx);
}

/* ---------- Quiz ---------- */
function isAnswered(q, val) {
  if (val == null) return false;
  if (q.type === 'heat-tools') {
    const tools = (val && val.tools) || [];
    const temp  = val && val.temp;
    // 「ほとんど使わない」を選んだ場合は温度設定不要
    if (tools.includes('rare')) return true;
    return tools.length > 0 && !!temp;
  }
  if (Array.isArray(val)) return val.length > 0;
  return true;
}

function buildModeASequence(answers) {
  return Q
    .map((q, i) => ({ q, originalIdx: i }))
    .filter(({ q }) => {
      if (typeof q.when !== 'function') return true;
      try { return !!q.when(answers); } catch (e) { return true; }
    });
}

function Quiz({ answers, setAnswers, onComplete, onBackHome }) {
  const sequence = useMemo(() => buildModeASequence(answers), [answers]);
  const total = sequence.length;
  const [idx, setIdx] = useState(0);
  const safeIdx = Math.min(idx, total - 1);
  const entry = sequence[safeIdx];
  const q = entry?.q;
  const value = q ? answers[q.id] : null;
  const valid = q ? isAnswered(q, value) : false;
  const chapter = entry ? getChapterFor(entry.originalIdx) : QUIZ_CHAPTERS[0];

  // この設問が章の最初に表示されるかを、現在のシーケンスから判定
  const showChapterIntro = useMemo(() => {
    if (!entry) return false;
    const firstInChapter = sequence.find(e => getChapterFor(e.originalIdx)?.id === chapter.id);
    return firstInChapter && firstInChapter.q.id === entry.q.id;
  }, [entry, sequence, chapter]);

  const setValue = (v) => setAnswers(prev => ({ ...prev, [q.id]: v }));

  const next = () => {
    if (!valid) return;
    if (safeIdx >= total - 1) onComplete();
    else setIdx(safeIdx + 1);
  };
  const back = () => {
    if (safeIdx === 0) onBackHome();
    else setIdx(safeIdx - 1);
  };

  useEffect(() => { window.scrollTo({ top: 0, behavior: 'instant' }); }, [safeIdx]);

  if (!q) return null;

  return (
    <div className="min-h-[100svh] bg-finder relative pb-32 sm:pb-36">
      <TopBar step={safeIdx + 1} total={total} />
      <div className="pt-[78px]">
        <ProgressBar current={safeIdx + 1} total={total} />
      </div>

      <main className="mx-auto max-w-2xl px-5 sm:px-8 pt-8 sm:pt-14 relative z-10">
        <div key={q.id} className="anim-quiz">
          {/* Chapter marker */}
          <div className="flex items-center gap-3 mb-6 sm:mb-8">
            <span className={`font-mono tracking-widest2 text-[9.5px] uppercase text-gold nums inline-block ${showChapterIntro ? 'milestone-pulse' : ''} px-2 py-0.5`}>
              Chapter {String(chapter.index).padStart(2,'0')}
            </span>
            <span className="h-px w-6 bg-gold/40" />
            <span className="font-serif text-[13px] sm:text-[14px] text-charcoal">
              {chapter.title}
            </span>
          </div>

          {showChapterIntro && (
            <div className="anim-quiz mb-7 sm:mb-9 border-l-2 border-gold pl-4 sm:pl-5" style={{ animationDelay:'120ms' }}>
              <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55">
                ━ {chapter.id === 'now' ? 'はじめに' : `Chapter ${String(chapter.index).padStart(2,'0')}`} ━
              </p>
              <p className="mt-2 text-[13.5px] sm:text-[15px] text-ink leading-[1.85]">
                {chapter.subTitle}
              </p>
            </div>
          )}

          {/* Editorial Q header */}
          <div className="flex items-start gap-5 sm:gap-7">
            <div className="shrink-0 -mt-1">
              <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/55 mb-1">Question</p>
              <p className="font-serif text-[44px] sm:text-[58px] leading-none text-ink nums tracking-tight">
                {String(safeIdx + 1).padStart(2,'0')}
              </p>
              <p className="font-mono tracking-widest2 text-[9.5px] uppercase text-charcoal/40 mt-1 nums">
                / {String(total).padStart(2,'0')}
              </p>
            </div>
            <div className="flex-1 min-w-0 pt-1">
              <p className="font-mono tracking-widest2 text-[10.5px] uppercase text-gold mb-2">— {q.eyebrow}</p>
              <h2 className="font-serif text-[22px] sm:text-[28px] leading-[1.4] text-ink">
                {q.title}
              </h2>
            </div>
          </div>
          <div className="mt-5 h-px bg-line" />
          {q.note && <p className="mt-4 text-[12.5px] sm:text-[13px] text-charcoal/70 leading-[1.85]">{q.note}</p>}

          <QuestionCard question={q} value={value} onChange={setValue} />
        </div>
      </main>

      <nav className="fixed bottom-0 inset-x-0 bg-gradient-to-t from-ivory via-ivory/95 to-ivory/0 pt-6 pb-5 sm:pb-7 z-20">
        <div className="mx-auto max-w-2xl px-5 sm:px-8 flex items-center justify-between gap-4">
          <button
            onClick={back}
            className="font-mono tracking-widest2 text-[10.5px] sm:text-[11px] uppercase text-charcoal/65 hover:text-ink transition-colors inline-flex items-center gap-2"
          >
            <span className="inline-block w-5 h-px bg-charcoal/40" />
            {safeIdx === 0 ? 'Home' : 'Back'}
          </button>
          <button
            onClick={next}
            disabled={!valid}
            className={[
              'inline-flex items-center justify-center gap-3 px-6 sm:px-9 py-3.5 sm:py-4 rounded-[2px] font-mono text-[10.5px] sm:text-[11px] tracking-widest2 uppercase transition-all',
